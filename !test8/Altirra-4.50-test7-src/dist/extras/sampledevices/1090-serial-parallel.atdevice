// PBI serial/parallel I/O card example
//
// This is a partial implementation of the unreleased Atari 1090 Serial/Parallel
// Card.
//
// PBI ID: 1 ($02)
//
// Addressing when selected:
//  $D100-D17F: RIOT RAM
//  $D180-D19F: RIOT registers (not implemented)
//  $D1A0-D1A3: 6551 ACIA 1
//  $D1A4-D1A7: 6551 ACIA 2 (not implemented)
//  $D1A8-D1AB: Parallel port data latch
//  $D1AC-D1AF: Parallel port control latch
//
// Note that the only known firmware for this prototype does not support the
// serial port -- it registers an R: device but the entry points are stubbed.
// Alternative firmware is necessary for it to work.

option "name": "1090 Serial/Parallel I/O Card";

SerialPort serial_port;
PrinterPort printer_port;

Thread recv_thread;
Thread xmit_thread;
Thread error_thread;
Condition xmit_restart;
Condition recv_restart;

PBIDevice pbi_device: {
    device_id: $02,
    has_irq: true
};

Segment firmware: {
    size: 2048,
    source: "1090-ParaSerial-2716_crc-1bdb5.bin"
};

const int DEVICE_RAM_SIZE = 128;

Segment device_ram: {
    size: DEVICE_RAM_SIZE
};

MemoryLayer firmware_layer: {
    name: "PBI Serial/Parallel I/O Firmware",
    address: $D800,
    size: $0800,
    segment: {
        source: firmware,
        offset: 0,
        mode: "ro"
    },
    auto_pbi: true
};

///////////////////////////////////////////////////////////////////////////

function void transfer_restart();

const int ACIA_CTL_BAUD = $0F;
const int ACIA_STAT_PARITY = $01;
const int ACIA_STAT_FRAMING = $02;
const int ACIA_STAT_OVERRUN = $04;
const int ACIA_STAT_RXFULL = $08;
const int ACIA_STAT_TXEMPTY = $10;
const int ACIA_STAT_IRQ = $80;
const int ACIA_CMD_NORXIRQ = $02;
const int ACIA_CMD_TXIRQ = $0C;

int baud_rate = 300;
int cycles_per_byte = 1000;

int acia_recv_shifter = -1;
int acia_recv_data = -1;
int acia_xmit_shifter = -1;
int acia_xmit_data = -1;
int acia_status = 0;
int acia_control = 0;
int acia_command = 0;

function void acia_update_baud() {
    int code = acia_control & ACIA_CTL_BAUD;

    if (code == 0)
        baud_rate = 0;
    else if (code == 1)
        baud_rate = 50;
    else if (code == 2)
        baud_rate = 75;
    else if (code == 3)
        baud_rate = 110;
    else if (code == 4)
        baud_rate = 135;
    else if (code == 5)
        baud_rate = 150;
    else if (code == 6)
        baud_rate = 300;
    else if (code == 7)
        baud_rate = 600;
    else if (code == 8)
        baud_rate = 1200;
    else if (code == 9)
        baud_rate = 1800;
    else if (code == 10)
        baud_rate = 2400;
    else if (code == 11)
        baud_rate = 3600;
    else if (code == 12)
        baud_rate = 4800;
    else if (code == 13)
        baud_rate = 7200;
    else if (code == 14)
        baud_rate = 9600;
    else
        baud_rate = 19200;

    cycles_per_byte = 0;

    if (baud_rate > 0)
        cycles_per_byte = serial_port.baud_to_cycles_per_byte(baud_rate);

    transfer_restart();
}

function int acia_read_data() {
    // clear receive data register full
    acia_status &= ~ACIA_STAT_RXFULL;

    return acia_recv_data;
}

function void acia_write_data() {
    if (acia_xmit_shifter < 0) {
        acia_xmit_shifter = $value;
        xmit_restart.signal();

        // raise transmitter IRQ
        if ((acia_command & ACIA_CMD_TXIRQ) == $04) {
            acia_status |= ACIA_STAT_IRQ;
            pbi_device.assert_irq();
        }
    } else {
	acia_xmit_data = $value;

        // clear transmitter empty
        acia_status &= ~ACIA_STAT_TXEMPTY;
    }
}

function int acia_read_status() {
    int status = acia_status;

    if (acia_status & ACIA_STAT_IRQ) {
        acia_status &= ~ACIA_STAT_IRQ;
        pbi_device.negate_irq();
    }

    // clear overrun, framing, and parity error bits on read
    acia_status &= ~(ACIA_STAT_PARITY | ACIA_STAT_FRAMING | ACIA_STAT_OVERRUN);

    return status;
}

function void acia_write_reset() {
    acia_command &= $E0;
}

function int acia_read_command() {
    return acia_command;
}

function void acia_write_command() {
    acia_command = $value;
}

function int acia_read_control() {
    return acia_control;
}

function void acia_write_control() {
    if (acia_control == $value)
        return;

    acia_control = $value;

    acia_update_baud();

    if ((acia_control & ACIA_CMD_TXIRQ) == $04) {
        if ((acia_status & (ACIA_STAT_TXEMPTY | ACIA_STAT_IRQ)) == ACIA_STAT_TXEMPTY) {
            acia_status |= ACIA_STAT_IRQ;
            pbi_device.assert_irq();
        }
    }
}

///////////////////////////////////////////////////////////////////////////

function void xmit_routine() {
    loop {
        if (cycles_per_byte == 0) {
            xmit_restart.wait();
        } else {
            int v = acia_xmit_shifter;
            acia_xmit_shifter = acia_xmit_data;
            acia_xmit_data = -1;

            // set transmitter data empty flag
            acia_status |= ACIA_STAT_TXEMPTY;

            // raise transmitter IRQ
            if ((acia_command & ACIA_CMD_TXIRQ) == $04) {
                acia_status |= ACIA_STAT_IRQ;
                pbi_device.assert_irq();
            }

            Thread.sleep(cycles_per_byte);

            if (v >= 0)
                serial_port.write(v, baud_rate);
        }
    }
}

function void recv_routine() {
    loop {
        int ch = serial_port.read_wait(baud_rate);

        acia_recv_data = ch;

        if (acia_status & ACIA_STAT_RXFULL) {
            // overflow - signal overrun
            acia_status |= ACIA_STAT_OVERRUN;
        } else {
            // signal receive data register full
            acia_status |= ACIA_STAT_RXFULL;
        }

        // raise receive IRQ if enabled
        if (!(acia_command & ACIA_CMD_NORXIRQ)) {
            acia_status |= ACIA_STAT_IRQ;
            pbi_device.assert_irq();
        }

        if (cycles_per_byte == 0) {
            recv_restart.wait();
        } else {
            Thread.sleep(cycles_per_byte);
        }
    }
}

function void error_routine() {
    loop {
        int err = serial_port.wait_error();

        if (err == 1) {
            // framing error
            acia_status |= ACIA_STAT_FRAMING;
        }
    }
}

function void transfer_restart() {
    recv_restart.signal();
    xmit_restart.signal();
}

///////////////////////////////////////////////////////////////////////////

int riot_drb;
int parallel_ctl;
int parallel_data;

function void riot_reset() {
    riot_drb = $FF;
    parallel_ctl = 0;
    parallel_data = 0;
}

// PA7 (R): SELECT
// PA6 (R): /ERROR
// PA5 (R): BUSY
// PA4 (R): /ACK
// PA3 (R): Paper end
// PA2 (R): Serial port 2 receive data (RXD)
// PA1 (R): Serial port 2 ring indicator (RI)
// PA0 (R): Serial port 1 ring indicator (RI)
function int riot_read_dra() {
    return $50;
}

// PB0-PB7 -> parallel port data bus
function int riot_read_drb() {
    return riot_drb;
}

function void riot_write_drb() {
    riot_drb = $value;
}

function void parallel_write_ctl() {
    // write data on rising edge of /STROBE (D7)
    if ($value & ~parallel_ctl & $80) {
        printer_port.write_raw(parallel_data);
    }
    
    parallel_ctl = $value;
}

function void parallel_write_data() {
    parallel_data = $value;
}

///////////////////////////////////////////////////////////////////////////

MemoryLayer control_regs: {
    name: "PBI Serial/Parallel I/O Registers",
    address: $D100,
    size: $0100,
    control: [
        {
            address: $D100,
            size: 128,
            mode: "r",
            script: function { return device_ram.read_byte($address & $7F); }
        },
        {
            address: $D100,
            size: 128,
            mode: "w",
            script: function { device_ram.write_byte($address & $7F, $value); }
        },

        {
            address: $D1A4,
            size: 4,
            mode: "r",
            data: $00,
        },

        {
            address: $D180,
            mode: "r",
            script: function { return riot_read_dra(); }
        },
        {
            address: $D182,
            mode: "r",
            script: function { return riot_read_drb(); }
        },
        {
            address: $D182,
            mode: "w",
            script: function { return riot_write_drb(); }
        },

        {
            address: $D1A0,
            mode: "r",
            script: function { return acia_read_data(); },
            debug_script: function { return acia_recv_data; }
        },
        {
            address: $D1A0,
            mode: "w",
            script: function { acia_write_data(); }
        },
        {
            address: $D1A1,
            mode: "r",
            script: function { return acia_read_status(); },
            debug_script: function { return acia_status; }
        },
        {
            address: $D1A1,
            mode: "w",
            script: function { acia_write_reset(); }
        },
        {
            address: $D1A2,
            mode: "r",
            script: function { return acia_command; }
        },
        {
            address: $D1A2,
            mode: "w",
            script: function { acia_write_command(); }
        },
        {
            address: $D1A3,
            mode: "r",
            script: function { return acia_control; }
        },
        {
            address: $D1A3,
            mode: "w",
            script: function { acia_write_control(); }
        },
        {
            address: $D1A8,
            size: 4,
            mode: "w",
            script: function { parallel_write_data(); }
        },
        {
            address: $D1AC,
            size: 4,
            mode: "w",
            script: function { parallel_write_ctl(); }
        },
    ],
    auto_pbi: true
};

event "cold_reset": function {
    acia_status = ACIA_STAT_TXEMPTY;
    acia_control = $00;
    acia_command = $00;

    riot_reset();

    recv_thread.run(recv_routine);
    xmit_thread.run(xmit_routine);
    error_thread.run(error_routine);
};
