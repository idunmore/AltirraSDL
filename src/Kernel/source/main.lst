   958 				;==========================================================================
   959 = E4C9			ScreenGetStatus = CIOExitSuccess
   960
   961 				;==========================================================================
   962 				; Given a color byte, mask it off to the pertinent bits and reflect it
   963 				; throughout a byte. The byte is converted from ATASCII to Internal
   964 				; if the mode uses byte encoding.
   965 				;
   966 				; Entry:
   967 				;	A = color value
   968 				;
   969 				; Exit:
   970 				;	A = folded color byte
   971 				;	Y = encoding mode
   972 				;	DMASK = right-justified bit mask
   973 				;	DELTAC = left-justified bit mask
   974 				;
   975 				; Modified:
   976 				;	HOLD1, ADRESS
   977 				;
   978 F6D3			.proc ScreenFoldColor
   979 F6D3 A6 57			ldx		dindex
   980 F6D5 BC C9 F2			ldy		ScreenEncodingTab,x			;0 = 8-bit, 1 = 4-bit, 2 = 2-bit, 3 = 1-bit
   981 F6D8 BE DD F2 86 77		mvx		ScreenPixelMasks+4,y deltac
   982 F6DD BE D9 F2 8E A0 02		mvx		ScreenPixelMasks,y dmask
   983 F6E3 30 0B			bmi		fold_byte
   984 F6E5 2D A0 02			and		dmask
   985 F6E8 19 DD FD			ora		ScreenEncodingOffsetTable-1,y
   986 F6EB AA				tax
   987 F6EC BD 53 F2			lda		ScreenEncodingTable,x
   988 F6EF 60				rts
   989 					
   990 F6F0			fold_byte:
   991 					;convert byte from ATASCII to Internal -- this is required for gr.1
   992 					;and gr.2 to work correctly, and harmless for other modes
   993
   994 				;==========================================================================
   995 				; Convert an ATASCII character to displayable INTERNAL format.
   996 				;
   997 				; Entry:
   998 				;	A = ATASCII char
   999 				;
  1000 				; Exit:
  1001 				;	A = INTERNAL char
  1002 				;
  1003 = F6F0			.def :ScreenConvertATASCIIToInternal
  1004 						;ATASCII	Internal
  1005 						;00-1F		40-5F
  1006 						;20-3F		00-1F
  1007 						;40-5F		20-3F
  1008 						;60-7F		60-7F
  1009
  1010 F6F0 0A					asl
  1011 F6F1 08					php
  1012 F6F2 E9 3F				sbc		#$3f		;00>60, 20>00, 40>20, 60>40
  1013 F6F4 10 02 49 40				spl:eor	#$40		;00>40, 20>00, 40>20, 60>60
  1014 F6F8 28					plp
  1015 F6F9 6A					ror
  1016 F6FA 60					rts
  1017 				.endp
  1018
  1019
  1020 				;==========================================================================
  1021 F6FB			.proc ScreenSpecial
  1022 F6FB A5 22			lda		iccomz
  1023 F6FD C9 11			cmp		#$11
  1024 F6FF F0 05			beq		ScreenDrawLineFill	;draw line
  1025 F701 C9 12			cmp		#$12
  1026 F703 F0 01			beq		ScreenDrawLineFill	;fill
  1027 F705 60				rts
  1028 				.endp
  1029
  1030 				;==========================================================================
  1031 				;
  1032 				; Inputs:
  1033 				;	COLCRS,ROWCRS = next point
  1034 				;	OLDCOL,OLDROW = previous point
  1035 				;	ATACHR = color/character to use
  1036 				;
  1037 				; Outputs:
  1038 				;	OLDCOL,OLDROW = next point
  1039 				;
  1040 				; Behavior:
  1041 				;	- In GR.0:
  1042 				;		- Cursor is not drawn, even with CRSINH=0
  1043 				;		- OLDADR is updated to ending location, but not OLDCHR. If CRSINH=0,
  1044 				;		  this can lead to a subsequent E: write stomping the last line draw
  1045 				;		  cell with the under-cursor char from the last time the cursor was
  1046 				;		  drawn elsewhere.
  1047 				;
  1048 				; Some test cases:
  1049 				;	- Ryba Pila
  1050 				;	- SPACEWAY.BAS
  1051 				;	- Worm of Bemer
  1052 				;
  1053 				; The Bresenham algorithm we use (from Wikipedia):
  1054 				;	dx = |x2 - x1|
  1055 				;	dy = |y2 - y1|
  1056 				;	e = dx - dy
  1057 				;
  1058 				;	loop
  1059 				;		plot(x1, y1)
  1060 				;		if x1 == x2 and y1 == y2 then exit
  1061 				;		e2 = 2*e
  1062 				;		if e2 + dy > 0 then
  1063 				;			err = err - dy
  1064 				;			x0 = x0 + sign(dx)
  1065 				;		endif
  1066 				;		if e2 < dx then
  1067 				;			err = err + dx
  1068 				;			y0 = y0 + sign(dy)
  1069 				;		endif
  1070 				;	end
  1071 				;	
  1072 F706			.proc ScreenDrawLineFill
  1073 					;;##TRACE "Drawing line (%d,%d)-(%d,%d) in mode %d" dw(oldcol) db(oldrow) dw(colcrs) db(rowcrs) db(dindex)
  1074 						
  1075 					;initialize bit mask and repeat pertinent pixel bits throughout byte
  1076 F706 AD FD 02			lda		fildat
  1077 F709 20 D3 F6			jsr		ScreenFoldColor
  1078 F70C 8D BC 02			sta		hold4
  1079 F70F AD FB 02			lda		atachr
  1080 F712 20 D3 F6			jsr		ScreenFoldColor
  1081 F715 85 51			sta		hold1
  1082
  1083 F717 20 AE F9			jsr		ScreenSetupPlotPixel
  1084
  1085 					;compute screen pitch
  1086 F71A A0 01			ldy		#1
  1087 F71C 20 88 F9			jsr		ScreenComputeRangeSize
  1088 F71F 85 78			sta		deltac+1
  1089 F721 AA				tax
  1090 F722 A0 00			ldy		#0
  1091
  1092 					;compute abs(dy) and sign(dy)
  1093 F724 A5 54			lda		rowcrs
  1094 F726 38 E5 5A			sub		oldrow
  1095 F729 B0 0C			bcs		going_down
  1096 F72B 49 FF			eor		#$ff					;take abs(dy)
  1097 F72D 69 01			adc		#1						;
  1098 					;negate screen pitch
  1099 F72F 48				pha
  1100 F730 8A				txa
  1101 F731 49 FF			eor		#$ff
  1102 F733 AA				tax
  1103 F734 E8				inx
  1104 F735 88				dey
  1105 F736 68				pla
  1106 F737			going_down:
  1107 F737 86 70			stx		rowac
  1108 F739 85 76			sta		deltar
  1109 F73B 84 71			sty		rowac+1
  1110 					
  1111 					;;##TRACE "dy = %d" db(deltar)
  1112 					
  1113 					;compute abs(dx) and sign(dx)
  1114 F73D A2 00			ldx		#0
  1115 F73F A5 55			lda		colcrs
  1116 F741 38 E5 5B			sub		oldcol
  1117 F744 85 72			sta		colac
  1118 F746 A5 56			lda		colcrs+1
  1119 F748 E5 5C			sbc		oldcol+1
  1120 F74A B0 10			bcs		going_right
  1121 F74C 49 FF			eor		#$ff
  1122 F74E A8				tay
  1123 F74F A5 72			lda		colac
  1124 F751 49 FF			eor		#$ff
  1125 F753 69 01			adc		#1
  1126 F755 85 72			sta		colac
  1127 F757 98				tya
  1128 F758 69 00			adc		#0
  1129 F75A A2 CC			ldx		#left_shift_8-right_shift_8
  1130 F75C			going_right:
  1131 F75C 85 73			sta		colac+1
  1132
  1133 					;;##TRACE "dx = %d" dw(colac)
  1134 					
  1135 					;set up x shift routine
  1136 F75E 8A				txa
  1137 F75F A6 57			ldx		dindex
  1138 F761 BC C9 F2			ldy		ScreenEncodingTab,x
  1139 F764 18				clc
  1140 F765 79 B2 F7			adc		shift_lo_tab,y
  1141 F768 85 64			sta		adress
  1142 F76A A9 F7			lda		#>left_shift_8
  1143 F76C 85 65			sta		adress+1
  1144 F76E 85 75			sta		endpt+1
  1145 					
  1146 					;set up x fill shift routine
  1147 F770 B9 B2 F7			lda		shift_lo_tab,y
  1148 F773 18				clc
  1149 F774 69 D9			adc		#fill_right_8-right_shift_8
  1150 F776 85 74			sta		endpt
  1151 					
  1152 					;compute initial error accumulator in frmadr (dx-dy)
  1153 F778 A6 72			ldx		colac
  1154 F77A 8A				txa
  1155 F77B 38 E5 76			sub		deltar
  1156 F77E 85 68			sta		frmadr
  1157 F780 A4 73			ldy		colac+1				;leave dx in y:x for max() below
  1158 F782 98				tya
  1159 F783 E9 00			sbc		#0
  1160 F785 85 69			sta		frmadr+1
  1161
  1162 					;compute max(dx, dy) based on sign of (dx - dy)
  1163 F787 B0 04			bcs		dx_larger
  1164 F789 A0 00			ldy		#0
  1165 F78B A6 76			ldx		deltar
  1166 F78D			dx_larger:
  1167 F78D 86 7E			stx		countr
  1168 F78F 84 7F			sty		countr+1
  1169
  1170 F791 98				tya
  1171 F792 D0 03			bne		not_empty
  1172 F794 8A				txa
  1173 F795 F0 0D			beq		skip_showcursor
  1174 F797			not_empty:
  1175 					
  1176 					;;##TRACE "Pixel count = %d" dw(countr)
  1177 					
  1178 					;enter pixel loop (this will do a decrement for us)
  1179 F797 4C 07 F8			jmp		next_pixel
  1180
  1181 				;----------------------------------------------
  1182 F79A			done:
  1183 F79A 20 01 FE			jsr		ScreenSetLastPosition
  1184
  1185 					;RYBA PILA requires the quirky behavior of the last character of a non-zero length
  1186 					;DRAWTO being stomped by the character saved from the cursor draw of the last PLOT
  1187 					;(write to S:). Note that we must NOT do this for length 0 or it breaks SPACEWAY.
  1188 F79D A4 57			ldy		dindex
  1189 F79F D0 03			bne		skip_showcursor
  1190 F7A1 20 C8 FC			jsr		EditorRecomputeCursorAddr
  1191 F7A4			skip_showcursor:
  1192 F7A4 A0 01			ldy		#1
  1193 F7A6 60				rts
  1194
  1195 				;----------------------------------------------	
  1196 F7A7			fill_done:
  1197 F7A7 86 6E			stx		bitmsk
  1198 F7A9 4C 07 F8			jmp		next_pixel
  1199
  1200 				;----------------------------------------------	
  1201 F7AC			do_fill:
  1202 F7AC A4 6F			ldy		shfamt				;load current byte offset
  1203 F7AE A6 6E			ldx		bitmsk				;save current bitmask
  1204 F7B0 D0 33			bne		fill_start			;!! - unconditional
  1205
  1206 				;----------------------------------------------		
  1207 F7B2			shift_lo_tab:
  1208 F7B2 F0				dta		<right_shift_8	
  1209 F7B3 EA				dta		<right_shift_4	
  1210 F7B4 EC				dta		<right_shift_2	
  1211 F7B5 ED				dta		<right_shift_1
  1212
  1213 				;----------------------------------------------	
  1214 F7B6			left_shift_4:
  1215 F7B6 0A				asl
  1216 F7B7 0A				asl
  1217 F7B8			left_shift_2:
  1218 F7B8 0A				asl
  1219 F7B9			left_shift_1:
  1220 F7B9 0A				asl
  1221 F7BA 90 05			bcc		left_shift_ok
  1222 F7BC			left_shift_8:
  1223 F7BC C6 6F			dec		shfamt
  1224 F7BE AD A0 02			lda		dmask
  1225 F7C1			left_shift_ok:
  1226 F7C1 D0 31			bne		post_xinc			;!! - unconditional
  1227
  1228 				;----------------------------------------------	
  1229 F7C3			fill_right_4:
  1230 F7C3 4A				lsr
  1231 F7C4 4A				lsr
  1232 F7C5			fill_right_2:
  1233 F7C5 4A				lsr
  1234 F7C6			fill_right_1:
  1235 F7C6 4A				lsr
  1236 F7C7 90 09			bcc		fill_right_ok
  1237 F7C9			fill_right_8:
  1238 F7C9 A5 77			lda		deltac
  1239 F7CB C8				iny
  1240 F7CC C4 78			cpy		deltac+1
  1241 F7CE 90 02 A0 00			scc:ldy	#0
  1242 F7D2			fill_right_ok:
  1243 F7D2 85 6E			sta		bitmsk
  1244 F7D4 F0 D1			beq		fill_done
  1245 F7D6			fill_loop:
  1246 F7D6 B1 66			lda		(toadr),y			;load screen byte
  1247 F7D8 24 6E			bit		bitmsk				;mask to current pixel
  1248 F7DA D0 CB			bne		fill_done			;exit loop if non-zero
  1249 F7DC 4D BC 02			eor		hold4				;XOR with fill color
  1250 F7DF 25 6E			and		bitmsk				;mask change bits to current pixel
  1251 F7E1 51 66			eor		(toadr),y			;merge with screen byte
  1252 F7E3 91 66			sta		(toadr),y			;save screen byte
  1253 F7E5			fill_start:
  1254 F7E5 A5 6E			lda		bitmsk
  1255 F7E7 6C 74 00			jmp		(endpt)
  1256
  1257 				;----------------------------------------------	
  1258 F7EA			right_shift_4:
  1259 F7EA 4A				lsr
  1260 F7EB 4A				lsr
  1261 F7EC			right_shift_2:
  1262 F7EC 4A				lsr
  1263 F7ED			right_shift_1:
  1264 F7ED 4A				lsr
  1265 F7EE 90 04			bcc		right_shift_ok
  1266 F7F0			right_shift_8:
  1267 F7F0 E6 6F			inc		shfamt
  1268 F7F2 A5 77			lda		deltac
  1269 F7F4			right_shift_ok:
  1270 					;fall through to post_xinc
  1271 F7F4			post_xinc:
  1272 F7F4 85 6E			sta		bitmsk
  1273 F7F6			no_xinc:
  1274
  1275 					;plot pixel
  1276 					;;##TRACE "Plotting at $%04X+%d with mask $%02X" dw(toadr) db(shfamt) db(bitmsk)	
  1277 F7F6 A4 6F			ldy		shfamt
  1278 F7F8 A5 51			lda		hold1
  1279 F7FA 51 66			eor		(toadr),y
  1280 F7FC 25 6E			and		bitmsk
  1281 F7FE 51 66			eor		(toadr),y
  1282 F800 91 66			sta		(toadr),y
  1283
  1284 					;do fill if needed
  1285 F802 A5 22			lda		iccomz
  1286 F804 4A				lsr
  1287 F805 90 A5			bcc		do_fill
  1288 					
  1289 F807			next_pixel:
  1290 					;loop back for next pixel
  1291 F807 A5 7E			lda		countr
  1292 F809 D0 04			bne		next_pixel_2
  1293 F80B C6 7F			dec		countr+1
  1294 F80D 30 8B			bmi		done
  1295 F80F			next_pixel_2:
  1296 F80F C6 7E			dec		countr
  1297
  1298 					;!! - fall through to pixel loop
  1299
  1300 					;------- pixel loop state -------
  1301 					;	(zp)	frmadr		error accumulator
  1302 					;	(zp)	toadr		current row address
  1303 					;	(abs)	dmask		right-justified bit mask
  1304 					;	(zp)	deltac		left-justified bit mask
  1305 					;	(zp)	bitmsk		current bit mask
  1306 					;	(zp)	shfamt		current byte offset within row
  1307 					;	(zp)	rowac		y step address increment/decrement (note different from Atari OS)
  1308 					;	(zp)	adress		left/right shift routine
  1309 					;	(zp)	deltac+1	screen pitch, in bytes (for fill)
  1310 					;	(zp)	endpt		right shift routine
  1311 					;	(zp)	colac		dy
  1312 F811			pixel_loop:
  1313 					;compute 2*err
  1314 					;;##TRACE "Error accum = %d (dx=%d, dy=%d(%d))" dsw(frmadr) dw(colac) db(deltar) dsw(rowac)
  1315 F811 A5 68			lda		frmadr
  1316 F813 0A				asl
  1317 F814 A8				tay
  1318 F815 A5 69			lda		frmadr+1
  1319 F817 2A				rol
  1320 F818 AA				tax
  1321 					
  1322 					;check for y increment (2*e < dx, or A:Y < colac)
  1323 F819 98				tya
  1324 F81A 18				clc
  1325 F81B E5 72			sbc		colac
  1326 F81D 8A				txa
  1327 F81E 48				pha
  1328 F81F E5 73			sbc		colac+1
  1329 F821 10 13			bpl		no_yinc
  1330
  1331 F823			do_yinc:
  1332 					;bump y (add/subtract pitch, e += dx)
  1333 F823 A2 02			ldx		#2
  1334 F825			yinc_loop:
  1335 F825 B5 70			lda		rowac,x
  1336 F827 18				clc
  1337 F828 75 66			adc		toadr,x
  1338 F82A 95 66			sta		toadr,x
  1339 F82C B5 71			lda		rowac+1,x
  1340 F82E 75 67			adc		toadr+1,x
  1341 F830 95 67			sta		toadr+1,x
  1342 F832 CA				dex
  1343 F833 CA				dex
  1344 F834 10 EF			bpl		yinc_loop
  1345 F836			no_yinc:
  1346
  1347 					;check for x increment (2*e + dy > 0, or Y:[S] + deltar > 0)
  1348 F836 98				tya
  1349 F837 18				clc
  1350 F838 65 76			adc		deltar
  1351 F83A 68				pla
  1352 F83B 69 00			adc		#0
  1353 F83D 30 B7			bmi		no_xinc
  1354
  1355 					;update error accumulator
  1356 F83F A5 68			lda		frmadr
  1357 F841 38 E5 76			sub		deltar
  1358 F844 85 68			sta		frmadr
  1359 F846 B0 02 C6 69			scs:dec	frmadr+1
  1360
  1361 					;bump x
  1362 F84A A5 6E			lda		bitmsk
  1363 F84C 6C 64 00			jmp		(adress)
  1364
  1365 				.if [right_shift_4 ^ right_shift_8]&$ff00
  1366 					.error "Right draw routines cross page: ",right_shift_4,"-",right_shift_8
  1367 				.endif
  1368 				.if [left_shift_4 ^ left_shift_8]&$ff00
  1369 					.error "Left draw routines cross page: ",left_shift_4,"-",left_shift_8
  1370 				.endif
  1371 				.if [fill_right_4 ^ fill_right_8]&$ff00
  1372 					.error "Fill routines cross page: ",fill_right_4,"-",fill_right_8
  1373 				.endif
  1374 				.if [[right_shift_4^left_shift_4]|[left_shift_4^fill_right_4]]&$ff00
  1375 					.error	"Line/fill routines cross page: ",left_shift_4,',',right_shift_4,',',fill_right_4
  1376 				.endif
  1377
  1378 				.endp
  1379
  1380 				;==========================================================================
  1381 				; Clear the screen.
  1382 				;
  1383 				; Used:
  1384 				;	ADRESS
  1385 				;	TOADR
  1386 				;
  1387 				; Quirks:
  1388 				;	Clears the split-screen text area even if the main screen (S:) receives
  1389 				;	the clear. The In-Store Demonstration Cart depends on this. The cursor
  1390 				;	state of the split screen is NOT reset, so if the cursor was over a
  1391 				;	non-blank character, that character will be restored when the cursor
  1392 				;	moves.
  1393 				;
  1394 				;	The logical line map is always reset.
  1395 				;
  1396 F84F			.proc ScreenClear
  1397 					;first, set up for clearing the split-screen window (4*40 bytes main)
  1398 F84F A0 04			ldy		#4
  1399 					
  1400 					;check if we are in the split screen text window
  1401 F851 A6 7B			ldx		swpflg
  1402 F853 D0 08			bne		is_text_window
  1403 					
  1404 					;nope, it's the main screen... compute size
  1405 F855 A4 57			ldy		dindex
  1406 F857 BE 99 F2			ldx		ScreenHeightShifts,y
  1407 F85A BC A9 F2			ldy		ScreenHeights,x
  1408 F85D			is_text_window:
  1409 F85D 20 88 F9			jsr		ScreenComputeRangeSize
  1410
  1411 					;add 160 bytes to size if not GR.0 -- important to avoid clearing
  1412 					;beyond GR.0 screen (the font breaks in BIKERDAV.BAS otherwise!)
  1413 F860 18				clc
  1414 F861 A6 57			ldx		dindex
  1415 F863 F0 02			beq		is_gr0
  1416 F865 69 A0			adc		#160
  1417 F867			is_gr0:
  1418 F867 A8				tay
  1419 F868 A5 65			lda		adress+1
  1420 F86A 69 00			adc		#0
  1421
  1422 F86C AA				tax
  1423 F86D 65 59			adc		savmsc+1
  1424 F86F 85 67			sta		toadr+1
  1425 F871 A5 58 85 66			mva		savmsc toadr
  1426
  1427 					;As it turns out, there are no cases where the main screen
  1428 					;is an exact number of pages... so we can simply plow into
  1429 					;the clear loop.
  1430 F875 A9 00			lda		#0
  1431 F877			loop:
  1432 F877 88				dey
  1433 F878 91 66			sta		(toadr),y
  1434 F87A D0 FB			bne		loop
  1435 F87C C6 67			dec		toadr+1
  1436 F87E CA				dex
  1437 F87F 10 F6			bpl		loop
  1438
  1439 					;reset coordinates and cursor (we're going to wipe the cursor)
  1440 F881 85 56			sta		colcrs+1
  1441 F883 85 54			sta		rowcrs
  1442 F885 85 5D			sta		oldchr
  1443 					
  1444 					;always reset the logical line map
  1445 F887 A6 57			ldx		dindex
  1446 F889 D0 02			bne		is_graphic_screen
  1447 F88B A5 52			lda		lmargn
  1448 F88D			is_graphic_screen:
  1449 F88D 85 55			sta		colcrs
  1450
  1451 					;always reset the logical line map and exit
  1452 F88F 4C EE FD			jmp		ScreenResetLogicalLineMap
  1453 				.endp
  1454
  1455 				;==========================================================================
  1456 				; Insert a physical line at the current location.
  1457 				;
  1458 				; Entry:
  1459 				;	ROWCRS = row before which to insert new line
  1460 				;	C = 0 if physical line only, C = 1 if should start new logical line
  1461 				;
  1462 				; Modified:
  1463 				;	HOLD1, ADRESS
  1464 				;
  1465 = F893			ScreenInsertLine = ScreenInsertPhysLine.use_c
  1466 F892			.proc ScreenInsertPhysLine
  1467 F892 18				clc
  1468 F893			use_c:
  1469 					;save new logline flag
  1470 F893 08				php
  1471 					
  1472 					;compute addresses
  1473 F894 AC BF 02			ldy		botscr
  1474 F897 88				dey
  1475 F898 20 7E F9			jsr		ScreenComputeToAddrX0
  1476 F89B 20 C8 FD			jsr		EditorNextLineAddr
  1477 					
  1478 					;copy lines
  1479 F89E AE BF 02			ldx		botscr
  1480 F8A1 D0 09			bne		line_loop_start
  1481 F8A3			line_loop:
  1482 F8A3 A0 27			ldy		#39
  1483 F8A5			char_loop:
  1484 F8A5 B1 68			lda		(frmadr),y
  1485 F8A7 91 66			sta		(toadr),y
  1486 F8A9 88				dey
  1487 F8AA 10 F9			bpl		char_loop
  1488 F8AC			line_loop_start:	
  1489 F8AC A5 68			lda		frmadr
  1490 F8AE 85 66			sta		toadr
  1491 F8B0 38				sec
  1492 F8B1 E9 28			sbc		#40
  1493 F8B3 85 68			sta		frmadr
  1494 F8B5 A5 69			lda		frmadr+1
  1495 F8B7 85 67			sta		toadr+1
  1496 F8B9 E9 00			sbc		#0
  1497 F8BB 85 69			sta		frmadr+1
  1498 					
  1499 F8BD CA				dex
  1500 F8BE E4 54			cpx		rowcrs
  1501 F8C0 D0 E1			bne		line_loop
  1502 					
  1503 F8C2			no_copy:
  1504 					;clear the current line
  1505 F8C2 A0 27			ldy		#39
  1506 F8C4 A9 00			lda		#0
  1507 F8C6			clear_loop:
  1508 F8C6 91 66			sta		(toadr),y
  1509 F8C8 88				dey
  1510 F8C9 10 FB			bpl		clear_loop
  1511 					
  1512 					;insert bit into logical line mask
  1513 F8CB 20 77 FD			jsr		EditorGetCurLogicalLineInfo
  1514 					
  1515 F8CE 28				plp
  1516 F8CF B0 02 A9 00			scs:lda	#0
  1517 F8D3 85 51			sta		hold1
  1518
  1519 F8D5 A9 00			lda		#0
  1520 F8D7 38				sec
  1521 F8D8 FD C1 E4			sbc		ReversedBitMasks,x			;-bit
  1522 F8DB 0A				asl
  1523 F8DC 39 B2 02			and		logmap,y
  1524 F8DF 18				clc
  1525 F8E0 79 B2 02			adc		logmap,y
  1526 F8E3 6A				ror
  1527 F8E4 05 51			ora		hold1
  1528 F8E6 99 B2 02			sta		logmap,y
  1529 					
  1530 F8E9 88				dey
  1531 F8EA 10 03 6E B3 02		spl:ror	logmap+1
  1532 F8EF 88				dey
  1533 F8F0 10 03 6E B4 02		spl:ror	logmap+2
  1534 F8F5 60				rts
  1535 				.endp
  1536
  1537 				;==========================================================================
  1538 				; Hide the screen cursor, if it is present.
  1539 				;
  1540 				; Modified:
  1541 				;	Y
  1542 				;
  1543 				; Preserved:
  1544 				;	A
  1545 				;
  1546 F8F6			.proc ScreenHideCursor	
  1547 					;erase the cursor
  1548 F8F6 48				pha
  1549 F8F7 A0 00			ldy		#0
  1550 F8F9 A5 5D			lda		oldchr
  1551 F8FB 91 5E			sta		(oldadr),y
  1552 F8FD 68				pla
  1553 F8FE			no_cursor:
  1554 F8FE 60				rts
  1555 				.endp
  1556
  1557 				;==========================================================================
  1558 F8FF			.proc	ScreenCheckPosition
  1559 					;Check for ROWCRS out of range. Note that for split screen modes we still
  1560 					;check against the full height!
  1561 F8FF AD BF 02			lda		botscr
  1562 F902 A6 57			ldx		dindex
  1563 F904 D0 04			bne		rowcheck_not_gr0
  1564 F906 24 7B			bit		swpflg
  1565 F908 30 06			bmi		rowcheck_gr0
  1566 F90A			rowcheck_not_gr0:
  1567 F90A BC 99 F2			ldy		ScreenHeightShifts,x
  1568 F90D B9 A9 F2			lda		ScreenHeights,y
  1569 F910			rowcheck_gr0:
  1570 					;Clamp RMARGN to 39 (required for ARTILLERY.BAS). Yes, this still happens
  1571 					;even if the screen is not GR.0 and we're plotting above the screen split.
  1572 F910 A0 27			ldy		#39
  1573 F912 C4 53			cpy		rmargn
  1574 F914 B0 02			bcs		rmargn_ok
  1575 F916 84 53			sty		rmargn
  1576 F918			rmargn_ok:
  1577 F918 18				clc
  1578 F919 E5 54			sbc		rowcrs
  1579 F91B B0 0E			bcs		rowcheck_pass	
  1580 F91D			invalid_position:
  1581
  1582 					;If the cursor is out of range, reset it within bounds.
  1583 F91D A0 00			ldy		#0
  1584 F91F 84 56			sty		colcrs+1		;X high = 0
  1585 F921 8A				txa
  1586 F922 D0 02 A4 52			sne:ldy	lmargn
  1587 F926 84 55			sty		colcrs			;X low = X origin
  1588
  1589 F928 A0 8D			ldy		#CIOStatCursorRange
  1590 F92A 60				rts
  1591 					
  1592 F92B			rowcheck_pass:
  1593 					;check width
  1594 F92B BC AE F2			ldy		ScreenPixelWidthIds,x
  1595 F92E A5 55			lda		colcrs
  1596 F930 D9 BF F2			cmp		ScreenPixelWidthsLo,y
  1597 F933 A5 56			lda		colcrs+1
  1598 F935 F9 C4 F2			sbc		ScreenPixelWidthsHi,y
  1599 F938 B0 E3			bcs		invalid_position
  1600
  1601 					;check for BREAK
  1602 F93A A0 FF			ldy		#$ff
  1603 F93C A5 11			lda		brkkey
  1604 F93E D0 04			bne		no_break
  1605 F940 84 11			sty		brkkey
  1606 F942 A0 7F			ldy		#CIOStatBreak-1
  1607 F944			no_break:
  1608 F944 C8				iny
  1609 F945 60				rts
  1610 				.endp
  1611
  1612 				;==========================================================================
  1613 				; Swap between the main screen and the split screen.
  1614 				;
  1615 				; Conventionally, the main screen is left as the selected context when
  1616 				; the display handler is not active.
  1617 				;
  1618 				; Inputs:
  1619 				;	C = 0	for main screen
  1620 				;	C = 1	for split screen
  1621 				;
  1622 				; Modified:
  1623 				;	X
  1624 				;
  1625 				; Preserved:
  1626 				;	A
  1627 				;	
  1628 				;==========================================================================
  1629 				; Swap in the text screen (main if gr.0, split otherwise).
  1630 				;
  1631 F946			.proc	EditorSwapToText
  1632 					;set C=0 (main) if gr.0, C=1 (split) otherwise
  1633 F946 A0 17			ldy		#23
  1634 F948 CC BF 02			cpy		botscr
  1635
  1636 = F94B			.def :ScreenSwap = *
  1637 					;check if the correct set is in place
  1638 F94B 48				pha
  1639 F94C A9 00			lda		#0
  1640 F94E 65 7B			adc		swpflg
  1641 F950 F0 14			beq		already_there
  1642 					
  1643 					;Nope, we need to swap. Conveniently, the data to be swapped
  1644 					;is in a 12 byte block:
  1645 					;
  1646 					;	ROWCRS ($0054)		TXTROW ($0290)
  1647 					;	COLCRS ($0055)		TXTCOL ($0291)
  1648 					;	DINDEX ($0057)		TINDEX ($0293)
  1649 					;	SAVMSC ($0058)		TXTMSC ($0294)
  1650 					;	OLDROW ($005A)		TXTOLD ($0296)
  1651 					;	OLDCOL ($005B)		TXTOLD ($0297)
  1652 					;	OLDCHR ($005D)		TXTOLD ($0299)
  1653 					;	OLDADR ($005E)		TXTOLD ($029A)
  1654 					
  1655 F952 A2 0B			ldx		#11
  1656 F954			swap_loop:
  1657 F954 B5 54			lda		rowcrs,x
  1658 F956 BC 90 02			ldy		txtrow,x
  1659 F959 94 54			sty		rowcrs,x
  1660 F95B 9D 90 02			sta		txtrow,x
  1661 F95E CA				dex
  1662 F95F 10 F3			bpl		swap_loop
  1663 					
  1664 					;invert swap flag
  1665 F961 8A				txa
  1666 F962 45 7B			eor		swpflg
  1667 F964 85 7B			sta		swpflg
  1668 					
  1669 F966			already_there:
  1670 F966 68				pla
  1671 F967 60				rts
  1672 				.endp
  1673
  1674 				;==========================================================================
  1675 				; Compute character address.
  1676 				;
  1677 				; Entry:
  1678 				;	X = byte index
  1679 				;	Y = line index
  1680 				;
  1681 				; Exit:
  1682 				;	A:X = address
  1683 				;
  1684 				; Used:
  1685 				;	ADRESS
  1686 				;
  1687 F968			.proc	ScreenComputeAddr
  1688 F968 20 88 F9			jsr		ScreenComputeRangeSize
  1689 F96B 85 64			sta		adress
  1690 F96D 8A				txa
  1691 F96E 18				clc
  1692 F96F 65 64			adc		adress			;row*10,20,40+col
  1693 F971 90 02 E6 65			scc:inc	adress+1
  1694 F975 18				clc
  1695 F976 65 58			adc		savmsc
  1696 F978 AA				tax
  1697 F979 A5 65			lda		adress+1
  1698 F97B 65 59			adc		savmsc+1
  1699 F97D 60				rts
  1700 				.endp
  1701
  1702 				;==========================================================================
  1703 = F980			ScreenComputeToAddr = ScreenComputeToAddrX0.with_x
  1704 F97E			.proc	ScreenComputeToAddrX0
  1705 F97E A2 00			ldx		#0
  1706 F980			with_x:
  1707 F980 20 68 F9			jsr		ScreenComputeAddr
  1708 F983 86 66			stx		toadr
  1709 F985 85 67			sta		toadr+1
  1710 F987 60				rts
  1711 				.endp
  1712
  1713 				;==========================================================================
  1714 				; Compute size, in bytes, of a series of lines.
  1715 				;
  1716 				; Entry:
  1717 				;	Y = line count
  1718 				;
  1719 				; Exit:
  1720 				;	ADRESS+1	High byte of size
  1721 				;	A			Low byte of size
  1722 				;	
  1723 				; Preserved:
  1724 				;	X
  1725 				;
  1726 				; Modified:
  1727 				;	Y
  1728 				;
  1729 F988			.proc	ScreenComputeRangeSize
  1730 F988 A9 00 85 65			mva		#0 adress+1
  1731 F98C 84 64			sty		adress
  1732 F98E A4 57			ldy		dindex
  1733 F990 B9 AE F2			lda		ScreenPixelWidthIds,y
  1734 F993 38				sec
  1735 F994 F9 C9 F2			sbc		ScreenEncodingTab,y
  1736 F997 A8				tay
  1737 F998 C8				iny
  1738 F999 A5 64			lda		adress
  1739 F99B 0A				asl
  1740 F99C 26 65			rol		adress+1		;row*2
  1741 F99E 0A				asl
  1742 F99F 26 65			rol		adress+1		;row*4
  1743 F9A1 65 64			adc		adress			;row*5
  1744 F9A3 90 02 E6 65			scc:inc	adress+1
  1745 F9A7			shift_loop:
  1746 F9A7 0A				asl
  1747 F9A8 26 65			rol		adress+1		;row*10,20,40
  1748 F9AA 88				dey
  1749 F9AB 10 FA			bpl		shift_loop
  1750 F9AD 60				rts
  1751 				.endp
  1752
  1753 				;==========================================================================
  1754 				; Setup for pixel plot.
  1755 				;
  1756 				; Entry:
  1757 				;	OLDCOL, OLDROW = position
  1758 				;	DELTAC = left-justified pixel mask
  1759 				;
  1760 				; Exit:
  1761 				;	TOADR = screen row
  1762 				;	SHFAMT = byte offset within row
  1763 				;	BITMSK = shifted bit mask for pixel
  1764 				;
  1765 				; Modified:
  1766 				;	ADRESS
  1767 				;
  1768 = F9B3			ScreenAlignPixel = ScreenSetupPlotPixel.rshift_mask
  1769 F9AE			.proc ScreenSetupPlotPixel
  1770 					;;##TRACE "Folded pixel = $%02X" db(hold1)
  1771 F9AE 20 BD F9			jsr		ScreenSetupPixelAddr
  1772 					
  1773 					;preshift bit mask
  1774 F9B1 A5 77			lda		deltac
  1775 F9B3			rshift_mask:
  1776 F9B3 CA				dex
  1777 F9B4 30 04			bmi		xmaskshift_done
  1778 F9B6			xmaskshift_loop:
  1779 F9B6 4A				lsr
  1780 F9B7 CA				dex
  1781 F9B8 10 FC			bpl		xmaskshift_loop
  1782 F9BA			xmaskshift_done:
  1783 F9BA 85 6E			sta		bitmsk
  1784 					
  1785 					;;##TRACE "Initial bitmasks = $%02X $%02X" db(bitmsk) db(dmask)
  1786 F9BC 60				rts
  1787 				.endp
  1788
  1789 				;==========================================================================
  1790 				; Setup for pixel addressing.
  1791 				;
  1792 				; Entry:
  1793 				;	OLDCOL, OLDROW = position (ScreenSetupPixelAddr)
  1794 				;
  1795 				; Exit:
  1796 				;	TOADR = screen row
  1797 				;	SHFAMT = byte offset within row
  1798 				;	X = number of bits from left side of byte to left side of pixel
  1799 				;
  1800 F9BD			.proc ScreenSetupPixelAddr
  1801 					;compute initial address
  1802 F9BD A4 5A			ldy		oldrow
  1803 F9BF 20 7E F9			jsr		ScreenComputeToAddrX0
  1804 					
  1805 					;;##TRACE "Initial row address = $%04X" dw(toadr)
  1806 					
  1807 					;compute initial byte offset
  1808 F9C2 A5 5C			lda		oldcol+1
  1809 F9C4 A6 5B			ldx		oldcol
  1810 F9C6			phase2:
  1811 F9C6 6A				ror
  1812 F9C7 86 6F			stx		shfamt
  1813 F9C9 A9 00			lda		#0
  1814 F9CB A6 57			ldx		dindex
  1815 F9CD BC C9 F2			ldy		ScreenEncodingTab,x
  1816 F9D0 F0 06			beq		no_xshift	
  1817 F9D2			xshift_loop:
  1818 F9D2 66 6F			ror		shfamt
  1819 F9D4 6A				ror
  1820 F9D5 88				dey
  1821 F9D6 D0 FA			bne		xshift_loop
  1822 F9D8			no_xshift:
  1823 F9D8 2A				rol
  1824 F9D9 2A				rol
  1825 F9DA 2A				rol
  1826 F9DB 2A				rol
  1827 F9DC AA				tax
  1828
  1829 					;;##TRACE "Initial row offset = $%02X" db(shfamt)
  1830 F9DD 60				rts
  1831 				.endp
  1832
  1833 				;==========================================================================
  1834 				; ScreenAdvancePosNonMode0
  1835 				;
  1836 F9DE			.proc ScreenAdvancePosNonMode0
  1837 					;advance position
  1838 F9DE E6 55			inc		colcrs
  1839 F9E0 D0 02 E6 56			sne:inc	colcrs+1
  1840 F9E4 A6 57			ldx		dindex
  1841 F9E6 BC AE F2			ldy		ScreenPixelWidthIds,x
  1842 F9E9 BE C4 F2			ldx		ScreenPixelWidthsHi,y
  1843 F9EC E4 56			cpx		colcrs+1
  1844 F9EE D0 0F			bne		graphics_no_wrap
  1845 F9F0 BE BF F2			ldx		ScreenPixelWidthsLo,y
  1846 F9F3 E4 55			cpx		colcrs
  1847 F9F5 D0 08			bne		graphics_no_wrap
  1848
  1849 F9F7			graphics_eol:
  1850 					;move to left side and then one row down -- note that this may
  1851 					;push us into an invalid coordinate, which will result on an error
  1852 					;on the next call if not corrected
  1853 F9F7 A0 00			ldy		#0
  1854 F9F9 84 55			sty		colcrs
  1855 F9FB 84 56			sty		colcrs+1
  1856 F9FD E6 54			inc		rowcrs
  1857 F9FF			graphics_no_wrap:
  1858 F9FF A0 01			ldy		#1
  1859 FA01 60				rts
  1860 				.endp
