    10 E7EC			.proc SIOInit
    11 					;turn off POKEY init mode so polynomial counters and audio run
    12 E7EC A9 03 8D 0F D2		mva		#3 skctl
    13 E7F1 8D 32 02			sta		sskctl
    14 					
    15 					;enable noisy sound (yes, this is actually documented as being inited to
    16 					;3)
    17 E7F4 85 41			sta		soundr
    18 E7F6 60				rts
    19 				.endp
    20
    21 				;==============================================================================
    22 E7F7			.proc SIO
    23 					;set retry counters
    24 E7F7 A9 01 8D BD 02		mva		#$01 dretry
    25 					
    26 					;enter critical section
    27 E7FC 85 42			sta		critic
    28 					
    29 				.if _KERNEL_PBI_SUPPORT
    30 					;attempt PBI transfer
    31 E7FE 20 AF C2			jsr		PBIAttemptSIO
    32 E801 90 03 4C EF E8		scc:jmp	xit_pbi
    33 				.endif
    34
    35 					;we must not save STACKP until after PBI devices are polled -- the
    36 					;BlackBox PBI routines depend on being able to reuse this location
    37 E806 BA				tsx
    38 E807 8E 18 03			stx		stackp
    39 					
    40 					;Set timeout timer address -- MUST be done on each call to SIO, or
    41 					;Cross-Town Crazy Eight hangs on load due to taking over this vector
    42 					;previously. This is guaranteed by the OS Manual in Appendix L, H27.
    43 E80A 20 16 E9			jsr		SIOSetTimeoutVector
    44
    45 					;check for cassette -- needs to match $60 or else Prisma: Alien Ambush
    46 					;fails to load.
    47 E80D A2 00			ldx		#0
    48 E80F AD 00 03			lda		ddevic
    49 E812 C9 60			cmp		#$60
    50 E814 D0 01 CA			sne:dex
    51 E817 8E 0F 03			stx		casflg
    52
    53 					;init POKEY hardware
    54 E81A 20 69 E9			jsr		SIOInitHardware
    55
    56 					;go do cassette now
    57 E81D 2C 0F 03			bit		casflg
    58 E820 10 03			bpl		retry_command
    59 E822 4C E2 EA			jmp		SIOCassette	
    60 					
    61 E825			retry_command:
    62 					;We try 13 times to get a command accepted by a device; after that it
    63 					;counts as a device failure and we try one more round of 13 tries.
    64 E825 A9 0D 8D 9C 02		mva		#$0d cretry
    65 					
    66 E82A			retry_command_2:
    67 					;init command buffer
    68 E82A AD 00 03			lda		ddevic
    69 E82D 18				clc
    70 E82E 6D 01 03			adc		dunit
    71 E831 38				sec
    72 E832 E9 01			sbc		#1
    73 E834 8D 3A 02			sta		cdevic
    74
    75 E837 AD 02 03 8D 3B 02		mva		dcomnd		ccomnd
    76 E83D AD 0A 03 8D 3C 02		mva		daux1		caux1
    77 E843 AD 0B 03 8D 3D 02		mva		daux2		caux2
    78 						
    79 					;assert command line
    80 E849 A9 34 8D 03 D3		mva		#$34		pbctl
    81
    82 					;wait ~600us to ensure 750us minimum delay (~1k cycles or ~10 scanlines)
    83 E84E A2 05			ldx		#5
    84 E850 AC 0B D4			ldy		vcount
    85 E853			cmddelay:
    86 E853 CC 0B D4 F0 FB		cpy:req	vcount
    87 E858 C8				iny
    88 E859 CA				dex
    89 E85A D0 F7			bne		cmddelay
    90
    91 					;send command frame
    92 E85C A9 00 85 3C			mva		#0			nocksm
    93 E860 A9 02			lda		#>cdevic
    94 E862 85 33			sta		bufrhi
    95 E864 85 35			sta		bfenhi
    96 E866 A9 3A 85 32			mva		#<cdevic	bufrlo
    97 E86A A9 3E 85 34			mva		#<caux2+1	bfenlo
    98 E86E 20 CE E9			jsr		SIOSend
    99 E871 30 67			bmi		xit
   100 						
   101 					;wait for the ACK
   102 E873 20 21 E9			jsr		SIOWaitForACK
   103 E876 10 0A			bpl		ackOK
   104 					
   105 E878			command_error:
   106 E878 20 3E EA			jsr		SIOReceiveStop
   107 E87B CE 9C 02			dec		cretry
   108 E87E 10 AA			bpl		retry_command_2
   109 E880 30 4D			bmi		transfer_error
   110
   111 E882			ackOK:
   112
   113 					;check if we should send a data frame
   114 E882 2C 03 03			bit		dstats
   115 E885 10 0D			bpl		no_send_frame
   116 					
   117 					;setup buffer pointers
   118 E887 20 B8 E9			jsr		SIOSetupBufferPointers
   119 					
   120 					;send data frame	
   121 E88A 20 CE E9			jsr		SIOSend
   122 E88D 30 4B			bmi		xit
   123 					
   124 					;wait for ACK
   125 E88F 20 21 E9			jsr		SIOWaitForACK
   126 E892 30 E4			bmi		command_error
   127
   128 E894			no_send_frame:
   129 					
   130 					;setup for receiving complete
   131 E894 A2 FF			ldx		#$ff
   132 E896 86 3C			stx		nocksm
   133
   134 					;setup frame delay for complete
   135 E898 AD 06 03			lda		dtimlo
   136 E89B 6A				ror
   137 E89C 6A				ror
   138 E89D 48				pha
   139 E89E 6A				ror
   140 E89F 29 C0			and		#$c0
   141 E8A1 A8				tay
   142 E8A2 68				pla
   143 E8A3 29 3F			and		#$3f
   144 E8A5 AA				tax
   145
   146 E8A6 A9 01			lda		#1
   147 E8A8 8D 17 03			sta		timflg
   148 E8AB 20 5C E4			jsr		setvbv
   149
   150 E8AE A2 3E			ldx		#<temp
   151 E8B0 86 32			stx		bufrlo
   152 E8B2 E8				inx
   153 E8B3 86 34			stx		bfenlo
   154 E8B5 A2 02			ldx		#>temp
   155 E8B7 86 33			stx		bufrhi
   156 E8B9 86 35			stx		bfenhi
   157 E8BB 20 FF E9			jsr		SIOReceive
   158 E8BE 30 0F			bmi		transfer_error
   159 					
   160 					;Check if we received a C ($43) or E ($45) -- we must NOT abort immediately
   161 					;on a device error, as the device still sends back data we need to read, and
   162 					;Music Studio relies on the data coming back from a CRC error.
   163 					;
   164 					;We also need to accept ACK ($41) here, due to a bug in the stock OS that
   165 					;we need to replicate. The Zero Adjust step in the Indus GT diagnostics
   166 					;fails if we don't replicate this bug.
   167 					;
   168 E8C0 AD 3E 02			lda		temp
   169 E8C3 C9 45			cmp		#$45
   170 E8C5 F0 34			beq		completeOK
   171 E8C7 09 02			ora		#$02
   172 E8C9 C9 43			cmp		#$43
   173 E8CB F0 2E			beq		completeOK
   174 					
   175 					;we received crap... fail it now
   176 E8CD			device_error:
   177 E8CD A0 90			ldy		#SIOErrorDeviceError
   178 					
   179 E8CF			transfer_error:
   180 E8CF 20 3E EA			jsr		SIOReceiveStop
   181
   182 E8D2 CE BD 02			dec		dretry
   183 E8D5 30 03			bmi		device_retries_exhausted
   184 E8D7 4C 25 E8			jmp		retry_command
   185
   186 E8DA			device_retries_exhausted:
   187 E8DA			xit:
   188 E8DA AE 0F 03			ldx		casflg
   189 E8DD D0 0C			bne		leave_cassette_audio_on
   190 E8DF 8E 01 D2			stx		audc1
   191 E8E2 8E 03 D2			stx		audc2
   192 E8E5 8E 05 D2			stx		audc3
   193 E8E8 8E 07 D2			stx		audc4
   194 E8EB			leave_cassette_audio_on:
   195
   196 				.ifdef _KERNEL_816
   197 					;we may be in native mode, so we can't f-up the high byte of the stack pointer
   198 					lda		#1
   199 					xba
   200 					lda		stackp
   201 					tcs
   202 				.else
   203 E8EB AE 18 03			ldx		stackp
   204 E8EE 9A				txs
   205 				.endif
   206
   207 E8EF			xit_pbi:
   208 E8EF A9 00			lda		#0
   209 E8F1 85 42			sta		critic
   210
   211 E8F3 C0 00			cpy		#0			;!! - A=0 must be preserved for LiteDOS
   212 E8F5 8C 03 03			sty		dstats
   213 E8F8 84 30			sty		status
   214 E8FA 60				rts
   215
   216 E8FB			completeOK:		
   217 					;check if we should read a data frame
   218 E8FB 2C 03 03			bit		dstats
   219 E8FE 50 08			bvc		no_receive_frame
   220 					
   221 					;setup buffer pointers
   222 E900 20 B8 E9			jsr		SIOSetupBufferPointers
   223
   224 					;receive the rest of the frame
   225 E903 20 FF E9			jsr		SIOReceive
   226 E906 30 C7			bmi		transfer_error
   227
   228 E908			no_receive_frame:
   229 					;now we can finally shut off the receive IRQ
   230 E908 20 3E EA			jsr		SIOReceiveStop
   231
   232 					;Now check whether we got a device error earlier. If we did, return
   233 					;that instead of success. Check for Error, because we need to accept
   234 					;either ACK or Complete as stated above.
   235 E90B AD 3E 02			lda		temp
   236 E90E C9 45			cmp		#'E'
   237 E910 F0 BB			beq		device_error
   238 					
   239 					;nope, we're good... exit OK.
   240 E912 A0 01			ldy		#SIOSuccess
   241 E914 D0 C4			bne		xit
   242 				.endp
   243
   244 				;==============================================================================
   245 E916			.proc SIOSetTimeoutVector
   246 E916 A9 DC 8D 26 02 A9 + 	mwa		#SIOCountdown1Handler	cdtma1
   247 E920 60				rts
   248 				.endp
   249
   250 				;==============================================================================
   251 E921			.proc SIOWaitForACK
   252 					;setup 2 frame delay for ack
   253 E921 A2 FF			ldx		#$ff
   254 E923 86 3C			stx		nocksm
   255 E925 E8				inx					;X=0 (MSB of timeout duration)
   256 E926 A9 01			lda		#1			;set timer 1
   257 E928 8D 17 03			sta		timflg
   258 E92B A0 02			ldy		#2			;LSB of timeout duration
   259 E92D 84 33			sty		bufrhi		;>temp = 2
   260 E92F 84 35			sty		bfenhi		;>temp+1 = 2
   261 E931 20 5C E4			jsr		setvbv
   262
   263 					;setup for receiving ACK
   264 E934 A2 3E			ldx		#<temp
   265 E936 86 32			stx		bufrlo
   266 E938 E8				inx
   267 E939 86 34			stx		bfenlo		;#<[temp+1]
   268
   269 E93B 20 FF E9			jsr		SIOReceive
   270 					
   271 					;check if we had a receive error
   272 E93E 30 09			bmi		xit
   273 					
   274 					;check if we got an ACK
   275 E940 AD 3E 02			lda		temp
   276 E943 C9 41			cmp		#'A'
   277 E945 F0 02			beq		xit
   278 					
   279 					;doh
   280 E947 A0 8B			ldy		#SIOErrorNAK
   281 E949			xit:
   282 E949 60				rts
   283 				.endp
   284
   285 				;==============================================================================
   286 				;SIO send enable routine
   287 				;
   288 				; This is one of those routines that Atari inadvisably exposed in the OS jump
   289 				; table even though they shouldn't. Responsibilities of this routine are:
   290 				;
   291 				;	- Hit SKCTL to reset serial hardware and init for sending
   292 				;	- Hit SKRES to clear status
   293 				;	- Enable send interrupts
   294 				;	- Configure AUDF3/AUDF4 frequency (19200 baud or 600 baud)
   295 				;	- Set AUDC3/AUDC4 for noisy or non-noisy audio
   296 				;	- Set AUDCTL
   297 				;
   298 				; It does not init any of the SIO variables, only hardware/shadow state.
   299 				;
   300 = E969			SIOInitHardware = SIOSendEnable.init_hardware
   301 E94A			.proc SIOSendEnable
   302 					;enable serial output ready IRQ and suppress serial output complete IRQ
   303 E94A A5 10			lda		pokmsk
   304 E94C 09 10			ora		#$10
   305 E94E 29 F7			and		#$f7
   306 E950 85 10			sta		pokmsk
   307 E952 8D 0E D2			sta		irqen
   308
   309 E955			no_irq_setup:
   310 					;clear forced break mode and reset serial clocking mode to timer 4
   311 					;synchronous; also enable two-tone mode if in cassette mode
   312 E955 AD 32 02			lda		sskctl
   313 E958 29 0F			and		#$0f
   314 E95A 09 20			ora		#$20
   315 E95C AE 0F 03			ldx		casflg
   316 E95F F0 02 09 08			seq:ora	#$08
   317 E963 8D 32 02			sta		sskctl
   318 E966 8D 0F D2			sta		skctl
   319
   320 E969			init_hardware:
   321 					;clock channel 3 and 4 together at 1.79MHz
   322 					;configure pokey timers 3 and 4 for 19200 baud (1789773/(2*40+7) = 19040)
   323 E969 A2 08			ldx		#8
   324 					
   325 					;check if we are doing a cassette transfer; if so, use the cassette
   326 					;register table instead
   327 E96B AD 0F 03			lda		casflg
   328 E96E F0 02			beq		not_cassette
   329 					
   330 E970 A2 11			ldx		#17
   331 					
   332 E972			not_cassette:
   333
   334 = E972			.def :SIOInitPOKEYWithRegOffsetX
   335 					;load POKEY audio registers
   336 E972 A0 08			ldy		#8
   337 E974 BD 9D E9 CA 99 00 + 	mva:rpl	regdata_normal,x- audf1,y-
   338
   339 					;go noisy audio if requested
   340 E97E A5 41			lda		soundr
   341 E980 F0 17			beq		no_noise
   342 					
   343 E982 A9 A8			lda		#$a8
   344 E984 8D 07 D2			sta		audc4
   345 E987 AE 0F 03			ldx		casflg
   346 E98A F0 0D			beq		no_noise
   347 E98C A9 10			lda		#$10
   348 E98E 2C 32 02			bit		sskctl
   349 E991 D0 06			bne		no_noise
   350 E993 8D 01 D2			sta		audc1
   351 E996 8D 03 D2			sta		audc2
   352
   353 E999			no_noise:
   354
   355 					;reset serial status
   356 E999 8D 0A D2			sta		skres
   357 E99C 60				rts
   358
   359 E99D			regdata:
   360 E99D			regdata_normal:
   361 E99D 00				dta		$00		;audf1
   362 E99E A0				dta		$a0		;audc1
   363 E99F 00				dta		$00		;audf2
   364 E9A0 A0				dta		$a0		;audc2
   365 E9A1 28				dta		$28		;audf3
   366 E9A2 A0				dta		$a0		;audc3
   367 E9A3 00				dta		$00		;audf4
   368 E9A4 A0				dta		$a0		;audc4
   369 E9A5 28				dta		$28		;audctl
   370 					
   371 E9A6			regdata_cassette_write:
   372 E9A6 05				dta		$05		;audf1
   373 E9A7 A0				dta		$a0		;audc1
   374 E9A8 07				dta		$07		;audf2
   375 E9A9 A0				dta		$a0		;audc2
   376 E9AA CC				dta		$cc		;audf3
   377 E9AB A0				dta		$a0		;audc3
   378 E9AC 05				dta		$05		;audf4
   379 E9AD A0				dta		$a0		;audc4
   380 E9AE 28				dta		$28		;audctl
   381
   382 E9AF			regdata_cassette_read:
   383 E9AF 00				dta		$00		;audf1
   384 E9B0 A0				dta		$a0		;audc1
   385 E9B1 00				dta		$00		;audf2
   386 E9B2 A0				dta		$a0		;audc2
   387 E9B3 CC				dta		$cc		;audf3
   388 E9B4 A0				dta		$a0		;audc3
   389 E9B5 05				dta		$05		;audf4
   390 E9B6 A0				dta		$a0		;audc4
   391 E9B7 28				dta		$28		;audctl
   392 				.endp
   393
   394 				;==============================================================================
   395 E9B8			.proc SIOSetupBufferPointers
   396 E9B8 18				clc
   397 E9B9 AD 04 03			lda		dbuflo
   398 E9BC 85 32			sta		bufrlo
   399 E9BE 6D 08 03			adc		dbytlo
   400 E9C1 85 34			sta		bfenlo
   401 E9C3 AD 05 03			lda		dbufhi
   402 E9C6 85 33			sta		bufrhi
   403 E9C8 6D 09 03			adc		dbythi
   404 E9CB 85 35			sta		bfenhi
   405 E9CD 60				rts
   406 				.endp
   407
   408 				;==============================================================================
   409 				;SIO send routine
   410 				;
   411 E9CE			.proc SIOSend
   412 					;configure serial port for synchronous transmission
   413 					;enable transmission IRQs
   414 E9CE 78				sei
   415 E9CF 20 4A E9			jsr		SIOSendEnable
   416 					
   417 E9D2 A0 00			ldy		#0
   418 E9D4 84 3A			sty		xmtdon
   419 E9D6 84 30			sty		status
   420 E9D8 84 3B			sty		chksnt
   421 					
   422 					;send first byte and set checksum (must be atomic)
   423 E9DA B1 32			lda		(bufrlo),y
   424 E9DC 8D 0D D2			sta		serout
   425 E9DF 85 31			sta		chksum
   426
   427 					;unmask IRQs
   428 E9E1 58				cli
   429 					
   430 					;wait for transmit to complete or Break to be pressed
   431 E9E2			wait:
   432 E9E2 A5 11			lda		brkkey
   433 E9E4 F0 06			beq		break_detected
   434 E9E6 A5 3A			lda		xmtdon
   435 E9E8 F0 F8			beq		wait
   436 E9EA D0 06			bne		send_completed
   437
   438 E9EC			break_detected:
   439 E9EC A0 80			ldy		#$80
   440 E9EE 84 30			sty		status
   441 E9F0 C6 11			dec		brkkey			;reset brkkey to $FF (init value)
   442 					
   443 E9F2			send_completed:
   444 					;shut off transmission IRQs
   445 E9F2 78				sei
   446 E9F3 A5 10			lda		pokmsk
   447 E9F5 29 E7			and		#$e7
   448 E9F7 85 10			sta		pokmsk
   449 E9F9 8D 0E D2			sta		irqen
   450 E9FC 58				cli
   451
   452 					;we're done
   453 E9FD 98				tya
   454 E9FE 60				rts
   455 				.endp
   456
   457 				;==============================================================================
   458 				; SIO receive routine
   459 				;
   460 				; The exit and entry paths of this routine are time critical when receiving
   461 				; the Complete/Error byte and data frame since there may be no delay at all
   462 				; in between. The exit path needs to exit with the receive IRQ hot but IRQs
   463 				; masked; the entry path in turn needs to keep the IRQ enabled but not unmask
   464 				; IRQs until ready to receive.
   465 				;
   466 E9FF			.proc SIOReceive
   467 E9FF A9 00			lda		#0
   468 EA01			use_checksum:
   469 EA01 85 31			sta		chksum
   470 EA03 A2 00			ldx		#0
   471 EA05 86 39			stx		recvdn			;receive done flag = false
   472 EA07 86 38			stx		bufrfl			;buffer full flag = false
   473 EA09 E8				inx
   474 EA0A 86 30			stx		status			;set status to success (1)
   475
   476 					;configure serial port for asynchronous receive
   477 					;enable receive IRQ
   478 EA0C 78				sei
   479 EA0D AD 32 02			lda		sskctl
   480 EA10 29 8F			and		#$8f
   481 EA12 09 10			ora		#$10
   482 EA14 8D 32 02			sta		sskctl
   483 EA17 8D 0F D2			sta		skctl
   484 EA1A A5 10			lda		pokmsk
   485 EA1C 09 20			ora		#$20
   486 EA1E 85 10			sta		pokmsk
   487 EA20 8D 0E D2			sta		irqen
   488 EA23 58				cli
   489 					
   490 					;Negate command line (if it isn't already negated).
   491 					;
   492 					;Note that we DON'T do this until we are entirely ready to receive,
   493 					;because as soon as we do this we can get data.
   494 EA24 A9 3C 8D 03 D3		mva		#$3c pbctl
   495
   496 					;wait for receive to complete
   497 EA29			wait:
   498 EA29 AD 17 03			lda		timflg			;check for timeout
   499 EA2C F0 0C			beq		timeout			;bail if so
   500 EA2E A4 30			ldy		status			;check for another error code
   501 EA30 30 06			bmi		error			;bail if so
   502 EA32 A5 39			lda		recvdn			;check for receive complete
   503 EA34 F0 F3			beq		wait			;keep waiting if not
   504 EA36 A4 30			ldy		status			;set flags from status, and reload in case recvdn
   505 											;was hit first after IRQ set status
   506 					
   507 EA38			error:
   508 					;Mask interrupts, but exit with them masked. We do this in order to
   509 					;handle the transition from Complete to data frame during receive. There
   510 					;is no guaranteed device delay in between these and some disk drives
   511 					;send back-to-back bytes. In addition, there are demos that have DLIs
   512 					;active during SIO loads. Therefore, we avoid turning off the receive
   513 					;interrupt and instead hold it off to give us the best chance of snagging
   514 					;the first and second bytes successfully, even if delayed.
   515 EA38 78				sei
   516 EA39 60				rts
   517 					
   518 EA3A			timeout:
   519 EA3A A0 8A			ldy		#SIOErrorTimeout
   520 EA3C 78				sei
   521 EA3D 60				rts
   522 				.endp
   523
   524 				;==============================================================================
   525 EA3E			.proc SIOReceiveStop
   526 					;shut off receive IRQs
   527 EA3E A5 10			lda		pokmsk
   528 EA40 29 D7			and		#$d7
   529 EA42 85 10			sta		pokmsk
   530 EA44 8D 0E D2			sta		irqen
   531 EA47 58				cli
   532 EA48 60				rts
   533 				.endp
   534
   535 				;==============================================================================
   536 				; SIO serial input routine
   537 				;
   538 				; DOS 2.0S replaces (VSERIN), so it's critical that this routine follow the
   539 				; rules compatible with DOS. The rules are as follows:
   540 				;
   541 				;	BUFRLO/BUFRHI:	Points to next byte to read. Note that this is different
   542 				;					from (VSEROR)!
   543 				;	BFENLO/BFENHI:	Points one after last byte in buffer.
   544 				;	BUFRFL:			Set when all data bytes have been read.
   545 				;	NOCKSM:			Set if no checksum byte is expected. Cleared after checked.
   546 				;	RECVDN:			Set when receive is complete, including any checksum.	
   547 				;
   548 EA49			.proc SIOInputReadyHandler
   549 EA49 A5 38			lda		bufrfl
   550 EA4B D0 2A			bne		receiveChecksum
   551
   552 					;receive data byte
   553 EA4D 98				tya
   554 EA4E 48				pha
   555 EA4F AD 0D D2			lda		serin
   556 EA52 A0 00			ldy		#$00
   557 EA54 91 32			sta		(bufrlo),y
   558 EA56 18				clc
   559 EA57 65 31			adc		chksum
   560 EA59 69 00			adc		#$00
   561 EA5B 85 31			sta		chksum
   562
   563 					;restore Y now
   564 EA5D 68				pla
   565 EA5E A8				tay
   566 					
   567 					;bump buffer pointer
   568 EA5F E6 32 D0 02 E6 33		inw		bufrlo
   569 					
   570 					;check for EOB
   571 EA65 A5 32			lda		bufrlo
   572 EA67 C5 34			cmp		bfenlo
   573 EA69 A5 33			lda		bufrhi
   574 EA6B E5 35			sbc		bfenhi
   575 EA6D 90 06			bcc		xit
   576
   577 EA6F C6 38			dec		bufrfl					;!! - this was $00 coming in
   578 					
   579 					;should there be a checksum?
   580 EA71 A5 3C			lda		nocksm
   581 EA73 D0 15			bne		skipChecksum
   582 EA75			xit:
   583 EA75 68				pla
   584 EA76 40				rti
   585 					
   586 EA77			receiveChecksum:
   587 					;read and compare checksum
   588 EA77 AD 0D D2			lda		serin
   589 EA7A C5 31			cmp		chksum
   590 EA7C D0 06			bne		checksum_fail
   591 					
   592 EA7E			signal_end:
   593 					;set receive done flag
   594 EA7E A9 FF 85 39			mva		#$ff	recvdn
   595
   596 					;exit
   597 EA82 68				pla
   598 EA83 40				rti
   599
   600 EA84			checksum_fail:
   601 EA84 A9 8F			lda		#SIOErrorChecksum
   602 EA86 85 30			sta		status
   603 EA88 D0 F4			bne		signal_end				;!! - unconditional
   604 					
   605 EA8A			skipChecksum:
   606 					;set receive done flag
   607 EA8A 85 39			sta		recvdn
   608 					
   609 					;clear no checksum flag
   610 EA8C A9 00			lda		#0
   611 EA8E 85 3C			sta		nocksm
   612 EA90 68				pla
   613 EA91 40				rti
   614 				.endp
   615
   616 				;==============================================================================
   617 				; SIO serial output ready routine
   618 				;
   619 				; DOS 2.0S replaces (VSEROR), so it's critical that this routine follow the
   620 				; rules compatible with DOS. The rules are as follows:
   621 				;
   622 				;	BUFRLO/BUFRHI:	On entry, points to one LESS than the next byte to write.
   623 				;	BFENLO/BFENHI:	Points to byte immediately after buffer.
   624 				;	CHKSUM:			Holds running checksum as bytes are output.
   625 				;	CHKSNT:			$00 if checksum not yet sent, $FF if checksum sent.
   626 				;	POKMSK:			Used to enable the serial output complete IRQ after sending
   627 				;					checksum.
   628 				;
   629 EA92			.proc SIOOutputReadyHandler
   630 					;increment buffer pointer
   631 EA92 E6 32			inc		bufrlo
   632 EA94 D0 02			bne		addrcc
   633 EA96 E6 33			inc		bufrhi
   634 EA98			addrcc:
   635
   636 					;compare against buffer end
   637 EA98 A5 32			lda		bufrlo
   638 EA9A C5 34			cmp		bfenlo
   639 EA9C A5 33			lda		bufrhi
   640 EA9E E5 35			sbc		bfenhi			;set flags according to (dst - end)
   641 EAA0 B0 13			bcs		doChecksum
   642
   643 					;save Y
   644 EAA2 98				tya
   645 EAA3 48				pha
   646
   647 					;send out next byte
   648 EAA4 A0 00			ldy		#0
   649 EAA6 B1 32			lda		(bufrlo),y
   650 EAA8 8D 0D D2			sta		serout
   651 					
   652 					;update checksum
   653 EAAB 65 31			adc		chksum
   654 EAAD 69 00			adc		#0
   655 EAAF 85 31			sta		chksum
   656
   657 					;restore registers and exit
   658 EAB1 68				pla
   659 EAB2 A8				tay
   660 EAB3 68				pla
   661 EAB4 40				rti
   662 					
   663 EAB5			doChecksum:
   664 					;send checksum
   665 EAB5 A5 31			lda		chksum
   666 EAB7 8D 0D D2			sta		serout
   667 					
   668 					;set checksum sent flag
   669 EABA A9 FF 85 3B			mva		#$ff	chksnt
   670 					
   671 					;enable output complete IRQ and disable serial output IRQ
   672 EABE A5 10			lda		pokmsk
   673 EAC0 09 08			ora		#$08
   674 EAC2 29 EF			and		#$ef
   675 EAC4 85 10			sta		pokmsk
   676 EAC6 8D 0E D2			sta		irqen
   677 					
   678 EAC9 68				pla
   679 EACA 40				rti
   680 				.endp
   681
   682 				;==============================================================================
   683 EACB			.proc SIOOutputCompleteHandler
   684 					;check that we've sent the checksum
   685 EACB A5 3B			lda		chksnt
   686 EACD F0 0B			beq		xit
   687 					
   688 					;we're done sending the checksum
   689 EACF 85 3A			sta		xmtdon
   690 					
   691 					;need to shut off this interrupt as it is not latched
   692 EAD1 A5 10			lda		pokmsk
   693 EAD3 29 F7			and		#$f7
   694 EAD5 85 10			sta		pokmsk
   695 EAD7 8D 0E D2			sta		irqen
   696
   697 EADA			xit:
   698 EADA 68				pla
   699 EADB 40				rti
   700 				.endp
   701
   702 				;==============================================================================
   703 EADC			.proc SIOCountdown1Handler
   704 					;signal operation timeout
   705 EADC A9 00 8D 17 03		mva		#0	timflg
   706 EAE1 60				rts
   707 				.endp
   708
   709 				;==============================================================================
   710 EAE2			.proc SIOCassette
   711 					;check if it's read sector
   712 EAE2 AD 02 03			lda		dcomnd
   713 EAE5 C9 52			cmp		#$52
   714 EAE7 F0 0F			beq		isread
   715 					
   716 					;check if it's put sector
   717 EAE9 C9 50			cmp		#$50
   718 EAEB F0 05			beq		iswrite
   719
   720 					;nope, bail	
   721 EAED A0 8B			ldy		#SIOErrorNAK
   722 EAEF 4C DA E8			jmp		SIO.xit
   723 					
   724 EAF2			iswrite:
   725 EAF2 20 FE EA			jsr		SIOCassetteWriteFrame
   726 EAF5 4C DA E8			jmp		SIO.xit
   727
   728 EAF8			isread:
   729 EAF8 20 0F EB			jsr		SIOCassetteReadFrame
   730 EAFB 4C DA E8			jmp		SIO.xit
   731 				.endp
   732
   733 				;==============================================================================
   734 EAFE			.proc SIOCassetteWriteFrame
   735 					;wait for pre-record write tone or IRG read delay
   736 EAFE A2 02			ldx		#2
   737 EB00 20 5D EE			jsr		CassetteWaitLongShortCheck
   738
   739 					;set up to transmit
   740 EB03 20 4A E9			jsr		SIOSendEnable
   741 					
   742 					;setup buffer pointers
   743 EB06 20 B8 E9			jsr		SIOSetupBufferPointers
   744 					
   745 					;send data frame
   746 EB09 20 CE E9			jsr		SIOSend
   747 					
   748 					;all done
   749 EB0C 4C DA E8			jmp		SIO.xit
   750 				.endp
   751
   752 				;==============================================================================
   753 				; Read cassette frame
   754 				;
   755 				; Wait for long/short IRG, measure baud rate from sync mark, and read frame.
   756 				;
   757 				; When reading a cassette frame, the audio configuration is expected to be
   758 				; as follows:
   759 				;
   760 				;	Channel 1: Inaudible (31.5KHz)
   761 				;	Channel 2: Inaudible (31.5KHz)
   762 				;	Channel 3: Silent
   763 				;	Channel 4: Audible if enabled in SOUNDR (600Hz modulated by async read)
   764 				;
   765 				; This is necessary for proper tape loading sounds.
   766 				;
   767 EB0F			.proc SIOCassetteReadFrame
   768 					;wait for pre-record write tone or IRG read delay
   769 EB0F A2 04			ldx		#4
   770 EB11 20 5D EE			jsr		CassetteWaitLongShortCheck
   771
   772 					;set to 600 baud, turn on async read to shut off annoying tone
   773 EB14 A2 1A			ldx		#SIOSendEnable.regdata_cassette_read-SIOSendEnable.regdata+8
   774 EB16 20 72 E9			jsr		SIOInitPOKEYWithRegOffsetX
   775 					
   776 EB19 AD 32 02			lda		sskctl
   777 EB1C 29 8F			and		#$8f
   778 EB1E 09 10			ora		#$10
   779 EB20 8D 32 02			sta		sskctl
   780
   781 					;set timeout (approx; no NTSC/PAL switching yet)
   782 EB23 A9 01			lda		#1
   783 EB25 8D 17 03			sta		timflg
   784 EB28 A2 0E			ldx		#>3600
   785 EB2A A0 10			ldy		#<3600
   786 EB2C 20 5D C1			jsr		VBISetVector
   787
   788 					;wait for beginning of frame
   789 EB2F A9 10			lda		#$10		;test bit 4 of SKSTAT
   790 EB31			waitzerostart:
   791 EB31 AC 17 03			ldy		timflg
   792 EB34 F0 2B			beq		timeout
   793 EB36 2C 0F D2			bit		skstat
   794 EB39 D0 F6			bne		waitzerostart
   795 					
   796 					;take first time measurement
   797 EB3B 20 FB EB			jsr		readtimer
   798 EB3E 8C 0D 03			sty		timer1+1
   799 EB41 8D 0C 03			sta		timer1
   800
   801 					;wait for 19 bit transitions
   802 EB44 A9 10			lda		#$10		;test bit 4 of SKSTAT
   803 EB46 A2 0A			ldx		#10			;test 10 pairs of bits
   804 EB48			waitone:
   805 EB48 AC 17 03			ldy		timflg
   806 EB4B F0 14			beq		timeout
   807 EB4D 2C 0F D2			bit		skstat
   808 EB50 F0 F6			beq		waitone
   809 EB52 CA				dex
   810 EB53 F0 11			beq		waitdone
   811 EB55			waitzero:
   812 EB55 AC 17 03			ldy		timflg
   813 EB58 F0 07			beq		timeout
   814 EB5A 2C 0F D2			bit		skstat
   815 EB5D D0 F6			bne		waitzero
   816 EB5F F0 E7			beq		waitone
   817 					
   818 EB61			timeout:
   819 EB61 A0 8A			ldy		#SIOErrorTimeout
   820 EB63 4C DA E8			jmp		SIO.xit	
   821
   822 EB66			waitdone:
   823 					
   824 					;take second time measurement
   825 EB66 20 FB EB			jsr		readtimer
   826 EB69 8D 10 03			sta		timer2
   827 EB6C 8C 11 03			sty		timer2+1
   828 					
   829 					;compute baud rate and adjust pokey divisor
   830 					;
   831 					; counts = (pal ? 156 : 131)*rtdelta + vdelta;
   832 					; lines = counts * 2
   833 					; lines_per_bit = lines / 19
   834 					; cycles_per_bit = lines_per_bit * 114
   835 					; pokey_divisor = cycles_per_bit / 2 - 7
   836 					;
   837 					; -or-
   838 					;
   839 					; pokey_divisor = counts * 2 * 114 / 19 / 2 - 7
   840 					;               = counts * 6 - 7
   841 					;
   842 					;16 bits at 600 baud is nominally 209 scanline pairs. This means that we
   843 					;don't have to worry about more than two frames, which is at least 262
   844 					;scanline pairs or less than 480 baud.
   845 					
   846 					;set frame height - 262 scanlines for NTSC, 312 for PAL
   847 EB6F A2 83			ldx		#131
   848 EB71 AD 14 D0			lda		pal
   849 EB74 4A				lsr
   850 EB75 D0 02 A2 9C			sne:ldx	#156
   851 EB79 8E 15 03			stx		temp3
   852 					
   853 					;compute line difference
   854 EB7C AD 0C 03			lda		timer1
   855 EB7F 20 09 EC			jsr		correct_time
   856 EB82 85 34			sta		bfenlo
   857 					
   858 EB84 AD 10 03			lda		timer2
   859 EB87 20 09 EC			jsr		correct_time
   860 EB8A 18				clc							;!! this decrements one line from the line delta
   861 EB8B E5 34			sbc		bfenlo
   862 EB8D 85 34			sta		bfenlo
   863 EB8F A0 00			ldy		#0
   864 EB91 B0 01 88			scs:dey
   865 					
   866 					;compute frame difference
   867 EB94 AD 11 03			lda		timer2+1
   868 EB97 38 ED 0D 03			sub		timer1+1
   869 EB9B AA				tax
   870 					
   871 					;accumulate frame difference
   872 EB9C F0 0C			beq		no_frames
   873 EB9E A5 34			lda		bfenlo
   874 EBA0			add_frame_loop:
   875 EBA0 18				clc
   876 EBA1 6D 15 03			adc		temp3
   877 EBA4 90 01 C8			scc:iny
   878 EBA7 CA				dex
   879 EBA8 D0 F6			bne		add_frame_loop
   880 EBAA			no_frames:
   881 EBAA 84 35			sty		bfenhi
   882
   883 					;compute lines*6 - 7 = (lines-1)*6 - 1
   884 EBAC 0A				asl							;(lines-1)*2 (lo)
   885 EBAD 26 35			rol		bfenhi				;(lines-1)*2 (hi)
   886 EBAF 85 34			sta		bfenlo
   887 EBB1 A4 35			ldy		bfenhi				;
   888 EBB3 06 34			asl		bfenlo				;(lines-1)*4 (lo)
   889 EBB5 26 35			rol		bfenhi				;(lines-1)*4 (hi)
   890 EBB7 65 34			adc		bfenlo				;(lines-1)*6 (lo)
   891 EBB9 AA				tax							;
   892 EBBA 98				tya							;
   893 EBBB 65 35			adc		bfenhi				;(lines-1)*6 (hi) (and c=0)
   894 EBBD CA				dex							;-1 line, bringing us to -7
   895 EBBE 8E 04 D2			stx		audf3
   896 EBC1 8E EE 02			stx		cbaudl
   897 EBC4 E8				inx
   898 EBC5 D0 02 E9 00			sne:sbc	#0
   899 EBC9 8D 06 D2			sta		audf4
   900 EBCC 8D EF 02			sta		cbaudh
   901 						
   902 					;Reset pokey serial input shift hw.
   903 					;
   904 					;Clearing bits 0-1 sets init mode, which resets the serial I/O shift
   905 					;register machines and is the main thing we need. Bits 4-6 are of lesser
   906 					;importance as they only reset the phase of the serial clocks.
   907 					;
   908 EBCF AE 32 02			ldx		sskctl
   909 EBD2 8A				txa
   910 EBD3 29 8C			and		#$8c
   911 EBD5 8D 0F D2			sta		skctl
   912 					
   913 					;reset serial port status
   914 EBD8 8D 0A D2			sta		skres
   915 					
   916 					;re-enable serial input hw
   917 EBDB 8E 0F D2			stx		skctl
   918 					
   919 EBDE 20 B8 E9			jsr		SIOSetupBufferPointers
   920 					
   921 					;stuff two $55 bytes into the buffer, which we "read" above
   922 EBE1 A9 55			lda		#$55
   923 EBE3 A0 00			ldy		#0
   924 EBE5 A2 02			ldx		#2
   925 EBE7			aaloop:
   926 EBE7 91 32			sta		(bufrlo),y
   927 EBE9 E6 32 D0 02 E6 33		inw		bufrlo
   928 EBEF CA D0 F5			dex:bne	aaloop
   929 					
   930 					;reset checksum for two $55 bytes and receive frame
   931 EBF2 0A				asl
   932 EBF3 85 31			sta		chksum
   933 					
   934 EBF5 20 01 EA			jsr		SIOReceive.use_checksum
   935 EBF8 4C 3E EA			jmp		SIOReceiveStop
   936
   937 				;-------------------------------------------------------------------------
   938 				; We have to be VERY careful when reading (RTCLOK+2, VCOUNT), because
   939 				; the VBI can strike in between. First, we double-check RTCLOK+2 to see
   940 				; if it has changed. If so, we retry the read. Second, we check if
   941 				; VCOUNT=124, which corresponds to lines 248/249. This can correspond to
   942 				; either before or after the VBI -- with CRITIC off the VBI ends around
   943 				; (249, 20-50) -- so we don't know which side of the frame boundary we're
   944 				; on.
   945 				;
   946 EBFB			readtimer:
   947 EBFB A4 14			ldy		rtclok+2
   948 EBFD AD 0B D4			lda		vcount
   949 EC00 C4 14			cpy		rtclok+2
   950 EC02 D0 F7			bne		readtimer
   951 EC04 C9 7C			cmp		#124
   952 EC06 F0 F3			beq		readtimer
   953 EC08 60				rts
   954 					
   955 EC09			correct_time:
   956 EC09 38				sec
   957 EC0A E9 7C			sbc		#124
   958 EC0C B0 03			bcs		time_ok
   959 EC0E 6D 15 03			adc		temp3
   960 EC11			time_ok:
   961 EC11 60				rts
   962 						
   963 				.endp
   964
   249 EC12				_KERNEL_REPORT_MODULE_SIZE 'Serial Input/Output (SIO)', $EDEA-$E944
Macro: _KERNEL_REPORT_MODULE_SIZE [Source: source/main.xasm]
     1 					.echo	'    ', *, ' -> ', *-?@_kernel_lastpt, '(', $EDEA-$E944, ')', '    ', 'Serial Input/Output (SIO)'
     1 				    $EC12 -> $0426($04A6)    Serial Input/Output (SIO)
     3 = EC12				.def ?@_kernel_lastpt = *
Source: source/main.xasm
   250 					
   251 EC12				icl		'disk.s'
Source: source/Shared/disk.s
     1 				;	Altirra - Atari 800/800XL/5200 emulator
     2 				;	Modular Kernel ROM - Disk Routines
     3 				;	Copyright (C) 2008-2016 Avery Lee
     4 				;
     5 				;	Copying and distribution of this file, with or without modification,
     6 				;	are permitted in any medium without royalty provided the copyright
     7 				;	notice and this notice are preserved.  This file is offered as-is,
     8 				;	without any warranty.
     9
    10 EC12			.proc DiskInit
    11 					.if _KERNEL_XLXE
    12 					;set disk sector size to 128 bytes
    13 EC12 A9 80 8D D5 02 A9 + 	mwa		#$80	dsctln
    14 					.endif
    15 EC1C 60				rts
    16 				.endp
    17
    18 				;==========================================================================
    19 				; Disk handler routine (pointed to by DSKINV)
    20 				;
    21 				; Exit:
    22 				;	A = command byte (undocumented; required by Pooyan)
    23 				;	Y = status
    24 				;	N = 1 if error, 0 if success (high bit of Y)
    25 				;	C = 1 if command is >=$21 (undocumented; required by Arcade Machine)
    26 				;
    27 EC1D			.proc DiskHandler
    28 EC1D A9 31 8D 00 03		mva		#$31	ddevic
    29 EC22 A9 0F 8D 06 03		mva		#$0f	dtimlo
    30 					
    31 					;check for status command
    32 EC27 AD 02 03			lda		dcomnd
    33 EC2A 8D 3B 02			sta		ccomnd
    34 EC2D C9 53			cmp		#$53
    35 EC2F D0 20			bne		notStatus
    36
    37 EC31 A9 EA			lda		#<dvstat
    38 EC33 8D 04 03			sta		dbuflo
    39 EC36 A9 02			lda		#>dvstat
    40 EC38 8D 05 03			sta		dbufhi
    41 EC3B 0A				asl							;hack to save a byte to get $04 since >dvstat is $02
    42 EC3C 8D 08 03			sta		dbytlo
    43 EC3F A9 00			lda		#0
    44 EC41 8D 09 03			sta		dbythi
    45 					
    46 EC44 20 6F EC			jsr		do_read
    47 EC47 30 07			bmi		xit
    48 					
    49 					;update format timeout
    50 EC49 AE EC 02 8E 46 02		mvx		dvstat+2 dsktim
    51 EC4F AA				tax
    52 EC50			xit:
    53 EC50 60				rts
    54 					
    55 EC51			notStatus:
    56
    57 					;set disk sector length
    58 					.if _KERNEL_XLXE
    59 EC51 AC D5 02 8C 08 03 + 	mwy		dsctln	dbytlo
    60 					.else
    61 					mwy		#$80 dbytlo
    62 					.endif
    63 					
    64 					;check for put/write
    65 					.if _KERNEL_XLXE
    66 EC5D C9 50			cmp		#$50
    67 EC5F F0 1D			beq		do_write
    68 					.endif
    69 EC61 C9 57			cmp		#$57
    70 EC63 F0 19			beq		do_write
    71 					
    72 					;check for format, or else assume it's a read command ($52) or similar
    73 EC65 C9 21			cmp		#$21
    74 EC67 D0 06			bne		do_read
    75
    76 					;it's format... use the format timeout
    77 EC69 AD 46 02 8D 06 03		mva		dsktim dtimlo
    78
    79 EC6F			do_read:
    80 EC6F A9 40			lda		#$40
    81 EC71			do_io:
    82 EC71 8D 03 03			sta		dstats
    83 EC74 20 59 E4			jsr		siov
    84 					
    85 					;load disk command back into A (required by Pooyan)
    86 					;emulate compare against format command (required by Arcade Machine)
    87 					;sort-of emulate compare against status (required by Micropainter)
    88 EC77 AD 02 03			lda		dcomnd
    89 EC7A C0 00			cpy		#0					;!! Atari800WinPlus's SIO patch doesn't set STATUS
    90 EC7C 38				sec
    91 EC7D 60				rts
    92
    93 EC7E			do_write:
    94 EC7E A9 80			lda		#$80
    95 EC80 D0 EF			bne		do_io
    96 				.endp
   252 EC82				_KERNEL_REPORT_MODULE_SIZE 'Disk Handler', $EE78-$EDEA
Macro: _KERNEL_REPORT_MODULE_SIZE [Source: source/main.xasm]
     1 					.echo	'    ', *, ' -> ', *-?@_kernel_lastpt, '(', $EE78-$EDEA, ')', '    ', 'Disk Handler'
     1 				    $EC82 -> $0070($008E)    Disk Handler
     3 = EC82				.def ?@_kernel_lastpt = *
Source: source/main.xasm
   253 					
   254 EC82				icl		'printer.s'
Source: source/Shared/printer.s
     1 				;	Altirra - Atari 800/800XL/5200 emulator
     2 				;	Modular Kernel ROM - Printer Handler
     3 				;	Copyright (C) 2008-2016 Avery Lee
     4 				;
     5 				;	Copying and distribution of this file, with or without modification,
     6 				;	are permitted in any medium without royalty provided the copyright
     7 				;	notice and this notice are preserved.  This file is offered as-is,
     8 				;	without any warranty.
     9
    10 				;==========================================================================
    11 EC82			.proc PrinterInit
    12 					;set printer timeout to default
    13 EC82 A9 1E 8D 14 03		mva		#30 ptimot
    14 EC87 60				rts
    15 				.endp
    16
    17 				;==========================================================================
    18 				; Printer close
    19 				;
    20 				; Flushes any remaining bytes left in the printer buffer to the printer,
    21 				; if any.
    22 				;
    23 				; Compatibility quirks:
    24 				;	- OS-B fills with $20, while the XL/XE OS fills with $9B.
    25 				;	- If the buffer was exactly filled without an EOL and is thus empty at
    26 				;	  the time of close, no additional EOL is sent. This is arguably a
    27 				;	  bug as it can cause line splicing with the 1025.
    28 				;
    29 = ECAA			PrinterClose = _PrinterPutByte.close_entry
    30
    31 				;==========================================================================
    32 				; Printer put byte
    33 				;
    34 				; Writes a byte into the printer buffer. If the printer buffer is full
    35 				; or an EOL was added, the printer buffer is sent to the printer.
    36 				;
    37 				; Compatibility quirks:
    38 				;	- Must be usable without prior Open, or Monkey Wrench II breaks.
    39 				;	- On an EOL, the remainder of the buffer is padded with $20 before
    40 				;	  being sent to the printer, on both OS-B and the XL/XE OS.
    41 				;	- ICAX2Z can be changed on the fly to switch between normal and
    42 				;	  sideways orientation, as it is checked on each put byte.
    43 				;	- If the buffer contains more than 29 characters and the mode is
    44 				;	  switched dynamically from Sideways to Normal mode, OS-B and XLOSv2
    45 				;	  will miss the stop and overrun the printer buffer. On XLOSv2,
    46 				;	  this generally results in a GINTLK hang. We handle this somewhat
    47 				;	  more gracefully but still treat it as a Don't Do That(tm).
    48 				;	- ICAX2Z=0 must be interpreted as Normal, because BASIC uses it
    49 				;	  with LPRINT, and the 1025 will NAK any other orientation.
    50 				;
    51 = EC88			PrinterPutByte = _PrinterPutByte.put_entry
    52
    53 EC88			.proc _PrinterPutByte
    54 EC88			put_entry:
    55 					;Check for sideways mode and compute line size - we must do this on every
    56 					;write as Monkey Wrench II depends on being able to call P: put byte
    57 					;without an open (still broken program behavior, just less crashy now).
    58 EC88 A2 28			ldx		#40
    59 EC8A A4 2B			ldy		icax2z
    60 EC8C C0 53			cpy		#$53
    61 EC8E D0 02 A2 1D			sne:ldx	#29
    62 EC92 8E DF 02			stx		pbufsz
    63
    64 					;increment and load buffer index
    65 EC95 EE DE 02			inc		pbpnt
    66 EC98 AE DE 02			ldx		pbpnt
    67
    68 					;put char
    69 EC9B 9D BF 03			sta		prnbuf-1,x
    70 					
    71 					;if we wrote an EOL, force flush now
    72 EC9E C9 9B			cmp		#$9b
    73 ECA0 F0 10			beq		fill_spaces
    74 							
    75 					;check for end of line and flush if so
    76 ECA2 EC DF 02			cpx		pbufsz
    77 ECA5 B0 16			bcs		fill_done
    78
    79 					;exit success
    80 ECA7			xit:
    81 ECA7 A0 01			ldy		#1
    82 ECA9 60				rts
    83 					
    84 ECAA			close_entry:
    85 					;check if we have anything in the buffer
    86 ECAA AE DE 02			ldx		pbpnt
    87 					
    88 					;exit if buffer is empty
    89 ECAD F0 F8			beq		xit
    90 					
    91 					;If we're building for 800 target, emulate OS-B and fill with $20.
    92 					;If we're building for XL/XE target, emulate XLOSv2 and fill with $9B.
    93 				.if _KERNEL_XLXE
    94 ECAF A9 9B			lda		#$9b
    95 ECB1 2C				dta		{bit $0100}
    96 				.endif
    97
    98 					;fill remainder of buffer with spaces
    99 ECB2			fill_spaces:
   100 ECB2 A9 20			lda		#$20
   101 ECB4			fill_loop:
   102 ECB4 9D C0 03			sta		prnbuf,x
   103 ECB7 E8				inx
   104 ECB8 EC DF 02			cpx		pbufsz
   105 ECBB 90 F7			bcc		fill_loop
   106 ECBD			fill_done:
   107 					
   108 					;send line to printer
   109 ECBD A0 0A			ldy		#10
   110 ECBF B9 E2 EC 99 FF 02 + 	mva:rne	iocbdat-1,y ddevic-1,y-
   111
   112 					;empty buffer
   113 ECC8 8C DE 02			sty		pbpnt
   114
   115 					;set line length
   116 ECCB 8E 08 03			stx		dbytlo
   117
   118 					;Compute AUX1 byte from length.
   119 					;
   120 					;Note that the OS manual is wrong -- this byte needs to go into AUX1 and
   121 					;not AUX2 as the manual says.
   122 					;
   123 					;	normal   (40): 00101000 -> 01001110 ($4E 'N')
   124 					;	sideways (29): 00011101 -> 01010011 ($53 'S')
   125 ECCE BD C5 EC			lda		mode_s-29,x
   126 ECD1 8D 0A 03			sta		daux1			;set AUX1 to indicate width to device
   127 					
   128 					;send to printer and exit
   129 ECD4			do_io:
   130 				.if _KERNEL_XLXE
   131 ECD4 A5 21 8D 01 03		mva		icdnoz dunit
   132 				.endif
   133 ECD9 AD 14 03 8D 06 03		mva		ptimot dtimlo
   134 ECDF 4C 59 E4			jmp		siov
   135
   136 ECE2			mode_s:
   137 ECE2 53				dta		'S'
   138 ECE3			iocbdat:
   139 ECE3 40				dta		$40			;device
   140 ECE4 01				dta		$01			;unit
   141 ECE5 57				dta		$57			;command 'W'
   142 ECE6 80				dta		$80			;input/output mode (write)
   143 ECE7 C0 03			dta		a(prnbuf)	;buffer address
   144 ECE9 00 00			dta		a(0)		;timeout
   145 ECEB 00 00			dta		a(0)		;buffer length
   146 ECED			mode_n:
   147 ECED 4E				dta		'N'
   148
   149 				.if mode_n-mode_s != 11
   150 				.error "N/S lookup misaligned"
   151 				.endif
   152 				.endp
   153
   154 				;==============================================================================
   155 				;==========================================================================
   156 ECEE			.proc PrinterOpen
   157 ECEE A9 00			lda		#0
   158 ECF0 8D DE 02			sta		pbpnt
   159
   160 					;fall through to status to update printer timeout
   161
   162 = ECF3			.def :PrinterGetStatus
   163 					;setup parameter block
   164 ECF3 A2 09			ldx		#9
   165 ECF5 BD 0A ED 9D 00 03 + 	mva:rpl	iocbdat,x ddevic,x-
   166
   167 					;issue status call
   168 ECFE 20 D4 EC			jsr		_PrinterPutByte.do_io
   169 ED01 30 06			bmi		error
   170 					
   171 					;update timeout
   172 ED03 AD EC 02 8D 14 03		mva		dvstat+2 ptimot
   173 					
   174 ED09			error:
   175 ED09 60				rts
   176
   177 ED0A			iocbdat:
   178 ED0A 40				dta		$40			;device
   179 ED0B 01				dta		$01			;unit
   180 ED0C 53				dta		$53			;command 'S'
   181 ED0D 40				dta		$40			;input/output mode (read)
   182 ED0E EA 02			dta		a(dvstat)	;buffer address
   183 ED10 00 00			dta		a(0)		;timeout
   184 ED12 04 00			dta		a(4)		;buffer length
   185 				.endp
   186
