  1371 DC54			.proc fp_reverse_addsub
  1372 DC54			noswap:	
  1373 						;A = FR1 - FR0 - 1 on entry
  1374 						;X = add/sub flag
  1375
  1376 						;complement (~x = -x - 1)
  1377 DC54 49 FF				eor		#$ff
  1378
  1379 						;A = FR0 - FR1
  1380
  1381 						;compute positions for add/subtract	
  1382 DC56 69 03				adc		#3			;A = (FR0) - (FR1) + 4   !! carry is set coming in
  1383
  1384 						;check if FR1 is too small in magnitude to matter
  1385 DC58 30 EF				bmi		fp_rmove
  1386
  1387 						;jump to decimal mode and prepare for add/sub loops
  1388 DC5A F8					sed
  1389 DC5B A8					tay
  1390
  1391 						;copy down exponent from larger number in FR1
  1392 DC5C A5 E0				lda		fr1
  1393 DC5E 85 D4				sta		fr0
  1394
  1395 						;check if we are doing a sum or a difference
  1396 DC60 E0 80				cpx		#$80
  1397 DC62 A2 05				ldx		#5
  1398 DC64 B0 1B				bcs		do_subtract
  1399 							
  1400 						;add mantissas
  1401 DC66			add_loop:
  1402 DC66 B9 D5 00				lda		fr0+1,y
  1403 DC69 75 E0				adc		fr1,x
  1404 DC6B 95 D4				sta		fr0,x
  1405 DC6D CA					dex
  1406 DC6E 88					dey
  1407 DC6F 10 F5				bpl		add_loop
  1408
  1409 						;apply any carries from the common mantissa bytes; we are guaranteed
  1410 						;at least one additional non-common byte, since this path is only
  1411 						;executed for non-equal exponents
  1412 DC71			sum_carryloop:
  1413 DC71 B5 E0				lda		fr1,x
  1414 DC73 69 00				adc		#0
  1415 DC75 95 D4				sta		fr0,x
  1416 DC77 CA					dex
  1417 DC78 D0 F7				bne		sum_carryloop
  1418
  1419 						;if we still carried out, jump out to bump the exponent and shift
  1420 						;a $01 at the top of the mantissa
  1421 DC7A B0 02				bcs		sum_finalize
  1422
  1423 						;exit -- no renormalization required
  1424 DC7C D8					cld
  1425 DC7D 60					rts
  1426
  1427 DC7E			sum_finalize:
  1428 DC7E 4C A9 DA				jmp		fsub.sum_finalize
  1429
  1430 DC81			do_subtract:
  1431 						;subtract FR0 and FR1 mantissas (!! carry is set coming in)
  1432 DC81			sub_loop:
  1433 DC81 B5 E0				lda		fr1,x
  1434 DC83 F9 D5 00				sbc		fr0+1,y
  1435 DC86 95 D4				sta		fr0,x
  1436 DC88 CA					dex
  1437 DC89 88					dey
  1438 DC8A 10 F5				bpl		sub_loop
  1439
  1440 						;propagate borrow up -- always at least one iteration as this
  1441 						;call path is executed with unequal exponents
  1442 DC8C			borrow_loop:
  1443 DC8C B5 E0				lda		fr1,x
  1444 DC8E E9 00				sbc		#0
  1445 DC90 95 D4				sta		fr0,x
  1446 DC92 CA					dex
  1447 DC93 10 F7				bpl		borrow_loop
  1448
  1449 						;if borrowed out the top, invert sign and then subtract from 0
  1450 DC95 90 9E				bcc		fp_fsub_cont.reverse_sub_entry
  1451
  1452 						;no more borrow, normalize and exit
  1453 DC97 4C FF DB				jmp		fp_normalize_cld
  1454 				.endp
