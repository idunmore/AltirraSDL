   979 DADB			.proc fmul
   980
   981 						;We use FR0:FRE as a double-precision accumulator, and copy the
   982 						;original multiplicand value in FR0 to FR1. The multiplier in
   983 						;FR1 is converted to binary digit pairs into FR2.
   984 					
   985 = 00DF			_offset = _fr3+5
   986 = 00E6			_offset2 = fr2
   987
   988 						;if FR0 is zero, we're done
   989 DADB 18					clc
   990 DADC A5 D4				lda		fr0
   991 DADE F0 3B				beq		fp_exit
   992 					
   993 						;if FR1 is zero, zero FR0 and exit
   994 DAE0 A5 E0				lda		fr1
   995 DAE2 F0 19				beq		fp_exit_zero
   996 						
   997 						;compute new exponent and stash (note: C=0 from above)
   998 DAE4 A5 E0				lda		fr1
   999 DAE6 20 01 DB				jsr		fp_adjust_exponent.fmul_entry
  1000 					
  1001 DAE9 E6 D4				inc		fr0
  1002
  1003 						;move fr0 to fr2, converting each digit pair to binary and inverting
  1004 DAEB 20 74 DD				jsr		fp_fmul_fr0_to_binfr2
  1005
  1006 						;clear accumulator through to exponent byte of fr1
  1007 DAEE A0 0C				ldy		#12
  1008 DAF0			clear_loop:
  1009 DAF0 96 D4				stx		fr0,y		;!! - X=0 from previous call
  1010 DAF2 88					dey
  1011 DAF3 D0 FB				bne		clear_loop
  1012
  1013 						;enter decimal mode for main accumulation
  1014 DAF5 F8					sed
  1015
  1016 						;set up for 7 bits per digit pair (0-99 in 0-127)
  1017 DAF6 A0 07				ldy		#7
  1018
  1019 						;jump into the middle of the bit loop, so we can avoid an unnecessary
  1020 						;double after the last bit
  1021 DAF8 4C BF DC				jmp		fp_fmul_innerloop.offloop_entry
  1022 				.endp
  1023
