   758 FCBF			.proc EditorIsSpecial
   759 FCBF			special_binsearch:
   760 FCBF DD 01 FB			cmp		EditorPutByte.special_code_tab,x
   761 FCC2 F0 03			beq		special_found
   762 FCC4 CA				dex
   763 FCC5 10 F8			bpl		special_binsearch
   764 FCC7			special_found:
   765 FCC7 60				rts
   766 				.endp
