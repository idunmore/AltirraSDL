  2096 DF84 BF 04 39 63 03 55			dta		$BF, $04, $39, $63, $03, $55	;A7  = -0.0439630355
  2097 DF8A 3F 10 09 30 12 64			dta		$3F, $10, $09, $30, $12, $64	;A6  =  0.1009301264
  2098 DF90 3F 09 39 08 04 60			dta		$3F, $09, $39, $08, $04, $60	;A5  =  0.0939080460
