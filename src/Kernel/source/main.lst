  2002 DF0F A0 05				ldy		#>fpscr
  2003 DF11 20 D8 DA				jsr		fp_fld1r_fmul		;cannot fail
  2004
  2005 						;add 0.5
  2006 DF14 A2 6C				ldx		#<fpconst_half
  2007 DF16 A0 DF				ldy		#>fpconst_half
  2008 DF18 20 98 DD				jsr		fld1r
  2009 DF1B 20 66 DA				jsr		fadd
  2010 					
  2011 						;stash
  2012 DF1E 20 B6 DD				jsr		fmove
  2013 					
