  1597 				;==========================================================================
  1598 				; FMUL multiplier conversion helper
  1599 				;
  1600 				; This helper is used to convert multiplier digit pair bytes to binary
  1601 				; 0-99 numbers in preparation for generating partial factors from
  1602 				; multiplier bit slices.
  1603 				;
  1604 				; Each byte is also inverted so that a 0 bit means to add. This saves a
  1605 				; CLC per add. This inversion is done for free by a tricky rearrangement
  1606 				; of the math to convert the BCD tens digit.
  1607 				;
  1608 DD74			.proc fp_fmul_fr0_to_binfr2		;$15 bytes
  1609 DD74 A2 05				ldx		#5
  1610 DD76			loop:
  1611 						;extract tens digit
  1612 DD76 B5 D4				lda		fr0,x
  1613 DD78 4A					lsr
  1614 DD79 4A					lsr
  1615 DD7A 4A					lsr
  1616 DD7B 4A					lsr
  1617 DD7C A8					tay
  1618
  1619 						;z = ~(x - (x/16)*10)         (BCD to binary, inverted)
  1620 						;  = -(x - (x/16)*10) - 1
  1621 						;  = ((x/16)*10 - x) - 1
  1622 DD7D 38					sec
  1623 DD7E B9 F6 DF				lda		fp_dectobin_tab,y
  1624 DD81 F5 D4				sbc		fr0,x
  1625 DD83 95 E6				sta		fr2,x
  1626
  1627 DD85 CA					dex
  1628 DD86 D0 EE				bne		loop
  1629
  1630 						;exit X=0 for calling code
  1631 DD88 60					rts
  1632 				.endp
  1633
