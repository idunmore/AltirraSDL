   290
   291 5261 A9 FF				lda		#$ff
   292 5263 8D 83 02				sta		ptrig7
   293 5266 2C 83 02 30 FB			bit:rmi	ptrig7
   294
   295 						;all done, return to boot code with sector 1 loaded at $0400
   296 526B 60					rts
