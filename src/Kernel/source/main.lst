     9
    10 				;==========================================================================
    11 				; Oddly, the keyboard IRQs are not enabled from the keyboard init
    12 				; routine. It's done by the Display Handler instead on open.
    13 				;
    14 FE42			.proc	KeyboardInit
    15 FE42 A2 FF			ldx		#$ff
    16 FE44 8E FC 02			stx		ch
    17 FE47 8E F2 02			stx		ch1
    18 FE4A E8				inx
    19 FE4B 8E F1 02			stx		keydel
    20 FE4E 8E B6 02			stx		invflg
    21 						
    22 					;turn on shift lock
    23 FE51 A9 40 8D BE 02		mva		#$40	shflok
    24 					
    25 					;set keyboard definition table pointer
    26 					.if _KERNEL_XLXE
    27 FE56 A9 2A 85 79 A9 FF + 	mwa		#KeyCodeToATASCIITable keydef
    28 					.endif
    29 FE5E 60				rts
    30 				.endp
    31
    32 = E4C9			KeyboardOpen = CIOExitSuccess
    33 = E4C9			KeyboardClose = CIOExitSuccess
    34
    35 				;==========================================================================
    36 				; K: GET BYTE handler.
    37 				;
    38 				; Behavior:
    39 				;	- Exits with a Break error when break key is pressed.
    40 				;	- Ctrl-1 does not suspend input here (it is handled by S:/E:).
    41 				;	- Ctrl-3 returns an EOF error.
    42 				;	- Caps Lock sets caps mode on OS-A/B depending on Ctrl and Shift key
    43 				;	  state. On the XL/XE OS, pressing Caps Lock alone will enable shift
    44 				;	  lock if no lock is enabled and disable it otherwise.
    45 				;	- Shift/Control lock is applied by K:, but only on alpha keys.
    46 				;	- Inverse mode is also applied by K:. Control characters are excluded:
    47 				;	  1B-1F/7D-7F/9B-9F/FD-FF.
    48 				;	- Any Ctrl+Shift key code (>=$C0) produces a key click but is otherwise
    49 				;	  ignored.
    50 				;	- Despite the OS Manual saying that there are no AUX1/AUX2 bits for
    51 				;	  K:, it actually implements the forced input bit for E: (AUX1 bit 0).
    52 				;	  This carries over to also implementing this bit for C:, which is
    53 				;	  relied upon by Black Lamp and Karateka loaders. This returns an EOL,
    54 				;	  BRKKEY is not checked, the keyboard table is not used, and there is
    55 				;	  no key click sound.
    56 				;
    57 FE5F			.nowarn .proc	_KeyboardGetByte
    58 FE5F			toggle_shift:
    59 					.if _KERNEL_XLXE
    60 					;Caps Lock without Shift or Control is a toggle on the XL/XE line:
    61 					; None -> Shifted
    62 					; Shifted, Control -> None
    63 FE5F AE BE 02			ldx		shflok
    64 FE62 D0 02			bne		caps_off
    65 FE64 A0 40			ldy		#$40
    66 					.endif
    67 FE66			shift_ctrl_on:
    68 FE66			caps_off:
    69 FE66 98				tya
    70 FE67 29 C0			and		#$c0
    71 FE69			write_shflok:
    72 FE69 8D BE 02			sta		shflok
    73
    74 = FE6C			.def :KeyboardGetByte
    75 FE6C A5 2A			lda		icax1z
    76 FE6E 4A				lsr
    77 FE6F A9 9B			lda		#$9b
    78 FE71 B0 50			bcs		forced_input
    79 FE73			waitForChar:
    80 FE73 A2 FF			ldx		#$ff
    81 FE75			waitForChar2:
    82 FE75 A5 11			lda		brkkey
    83 FE77 F0 5A			beq		isBreak
    84 FE79 AD FC 02			lda		ch
    85 FE7C C9 FF			cmp		#$ff
    86 FE7E F0 F5			beq		waitForChar2
    87 					
    88 					;invalidate char
    89 FE80 8E FC 02			stx		ch
    90 					
    91 					;do keyboard click (we do this even for ignored ctrl+shift+keys)
    92 					.if _KERNEL_XLXE
    93 FE83 AC DB 02			ldy		noclik
    94 FE86 D0 05			bne		no_click
    95 					.endif
    96
    97 FE88 A0 0C			ldy		#12
    98 FE8A 20 CC E4			jsr		Bell
    99 FE8D			no_click:
   100
   101 					;ignore char if both ctrl and shift are pressed
   102 FE8D C9 C0			cmp		#$c0
   103 FE8F B0 E2			bcs		waitForChar
   104 								
   105 					;translate char
   106 FE91 A8				tay
   107
   108 					.if _KERNEL_XLXE
   109 FE92 B1 79			lda		(keydef),y
   110 					.else
   111 					lda		KeyCodeToATASCIITable,y
   112 					.endif
   113 					
   114 					;handle special keys (see keytable.s)
   115 FE94 10 10			bpl		valid_key
   116 FE96 C9 81			cmp		#$81
   117 FE98 90 D9			bcc		waitForChar		;$80 - invalid
   118 FE9A F0 2D			beq		isInverse		;$81 - inverse video
   119 FE9C C9 83			cmp		#$83
   120 FE9E 90 BF			bcc		toggle_shift	;$82 - caps lock
   121 FEA0 C9 85			cmp		#$85
   122 FEA2 90 C2			bcc		shift_ctrl_on	;$83 - shift caps lock / $84 - ctrl caps lock
   123 FEA4 F0 32			beq		isCtrl3			;$85 - EOF
   124 					
   125 FEA6			valid_key:
   126 					;check for alpha key
   127 FEA6 C9 61			cmp		#'a'
   128 FEA8 90 0F			bcc		notAlpha
   129 FEAA C9 7B			cmp		#'z'+1
   130 FEAC B0 0B			bcs		notAlpha
   131 					
   132 					;check for shift/control lock
   133 FEAE 2C BE 02			bit		shflok
   134 FEB1 70 04			bvs		doShiftLock
   135 FEB3 10 04			bpl		notAlpha
   136 					
   137 					;do control lock logic
   138 FEB5 29 1F			and		#$1f
   139
   140 FEB7			doShiftLock:
   141 FEB7 29 DF			and		#$df
   142
   143 FEB9			notAlpha:
   144 					;check if we should apply inverse flag -- special characters are excluded
   145 FEB9 A2 0F			ldx		#EditorPutByte.special_code_tab_end_2-EditorPutByte.special_code_tab-1
   146 FEBB 20 BF FC			jsr		EditorIsSpecial
   147 FEBE F0 03			beq		skip_inverse
   148
   149 					;apply inverse flag
   150 FEC0 4D B6 02			eor		invflg
   151 FEC3			skip_inverse:
   152 FEC3			forced_input:
   153
   154 					;return char
   155 FEC3 8D FB 02			sta		atachr			;required or CON.SYS (SDX 4.46) breaks
   156 FEC6 A0 01			ldy		#1
   157 FEC8 60				rts
   158 					
   159 FEC9			isInverse:
   160 FEC9 AD B6 02			lda		invflg
   161 FECC 49 80			eor		#$80
   162 FECE 8D B6 02			sta		invflg
   163 FED1 B0 A0			bcs		waitForChar		;!! - unconditional
   164
   165 FED3			isBreak:
   166 FED3 86 11			stx		brkkey
   167 FED5 A0 80			ldy		#CIOStatBreak
   168 FED7 60				rts
   169 					
   170 FED8			isCtrl3:
   171 FED8 A0 88			ldy		#CIOStatEndOfFile
   172 FEDA 60				rts
   173 				.endp
   174
   175 				;==============================================================================
   176 = E4CB			KeyboardPutByte = CIOExitNotSupported
   177 = E4C9			KeyboardGetStatus = CIOExitSuccess
   178 = E4CB			KeyboardSpecial = CIOExitNotSupported
   179
   180 				;==============================================================================
   181 				; Keyboard IRQ
   182 				;
   183 				; HELP button ($11, $51, and $91):
   184 				; - Affects SRTIMR, ATRACT, KEYDEL, and HELPFG
   185 				; - Does NOT affect CH, CH1
   186 				;
   187 FEDB			.proc	KeyboardIRQ
   188 					;reset software repeat timer
   189 				.if _KERNEL_XLXE
   190 FEDB AD D9 02 8D 2B 02		mva		krpdel	srtimr
   191 				.else
   192 					mva		#$30	srtimr
   193 				.endif
   194 					
   195 					;read new key
   196 FEE1 AD 09 D2			lda		kbcode
   197
   198 				.if _KERNEL_XLXE
   199 					;save key
   200 FEE4 48				pha
   201
   202 					;check for HELP
   203 FEE5 29 3F			and		#$3f
   204 FEE7 C9 11			cmp		#$11
   205 FEE9 D0 06			bne		not_help
   206
   207 					;restore HELP key with original modifiers
   208 FEEB 68				pla
   209 FEEC 8D DC 02			sta		helpfg
   210 FEEF D0 1C			bne		xit2
   211
   212 FEF1			not_help:
   213 					;restore key
   214 FEF1 68				pla
   215 				.endif
   216 					
   217 					;check if it is the same as the prev key
   218 FEF2 CD F2 02			cmp		ch1
   219 FEF5 D0 08			bne		debounced
   220
   221 					;reject key if debounce timer is still running	
   222 FEF7 AD F1 02			lda		keydel
   223 FEFA D0 16			bne		xit
   224 FEFC AD F2 02			lda		ch1	
   225 FEFF			debounced:
   226
   227 					;check for Ctrl+1 to toggle display activity
   228 FEFF C9 9F			cmp		#$9f
   229 FF01 F0 11			beq		is_suspend
   230
   231 					;store key
   232 FF03 8D FC 02			sta		ch
   233 FF06 8D F2 02			sta		ch1
   234
   235 					;reset attract
   236 FF09 A9 00 85 4D			mva		#0		atract
   237 					
   238 FF0D			xit2:
   239 					;reset key delay
   240 FF0D A9 03 8D F1 02		mva		#3 keydel
   241
   242 FF12			xit:
   243 					;all done
   244 FF12 68				pla
   245 FF13 40				rti	
   246
   247 FF14			is_suspend:
   248 					;toggle stop/start flag
   249 FF14 AD FF 02			lda		ssflag
   250 FF17 49 FF			eor		#$ff
   251 FF19 8D FF 02			sta		ssflag
   252 FF1C B0 EF			bcs		xit2			;!! carry set from cmp #$9f!
   253 				.endp
   254
   255 				;==============================================================================
   256 FF1E			.proc	KeyboardBreakIRQ
   257 FF1E A9 00 85 11			mva		#0		brkkey
   258
   259 					;need to clear the suspend flag as BREAK automatically nukes a pending Ctrl+1
   260 FF22 8D FF 02			sta		ssflag
   261 					
   262 					;interestingly, the default break handler forces the cursor back on.
   263 FF25 8D F0 02			sta		crsinh
   264 					
   265 FF28 68				pla
   266 FF29 40				rti
   267 				.endp
   284 					.endif
