  1285 DC00 A0 05			ldy		#5
  1286 DC02			normloop:
  1287 DC02 A5 D4			lda		fr0
  1288 DC04 0A				asl
  1289 DC05 C9 1E			cmp		#(64-49)*2
  1290 DC07 90 1E			bcc		underflow
  1291 					
  1292 DC09 A6 D5			ldx		fr0+1
  1293 DC0B F0 03			beq		need_norm
  1294
  1295 					;Okay, we're done normalizing... check if the exponent is in bounds.
  1296 					;It needs to be within +/-48 to be valid. If the exponent is <-49,
  1297 					;we set it to zero; otherwise, we mark overflow.
  1298 					
  1299 DC0D C9 E2			cmp		#(64+49)*2
  1300 DC0F 60				rts
  1301 					
  1302 DC10			need_norm:
  1303 DC10 C6 D4			dec		fr0
  1304
