   999 				;==========================================================================
  1000 				; Compute the current logical column.
  1001 				;
  1002 				; Exit:
  1003 				;	A = column
  1004 				;	X = inverted row index (0-2 => $ff-$fd)
  1005 				;
  1006 FDAA			.proc	EditorGetLogicalColumn
  1007 					;get starting row of logical line
  1008 FDAA A5 54			lda		rowcrs
  1009 FDAC 20 8F FD			jsr		EditorPhysToLogicalRow
  1010 					
  1011 					;subtract off current row
  1012 FDAF 18				clc
  1013 FDB0 E5 54			sbc		rowcrs
  1014 FDB2 AA				tax
  1015 					
  1016 					;multiply negated difference by 40
  1017 FDB3 BD DE FC			lda		EditorLineLengthTab-$fc,x
  1018 					
  1019 					;add in physical column
  1020 FDB6 65 55			adc		colcrs
  1021 FDB8 60				rts
  1022 				.endp
  1023
  1024 				;==========================================================================
  1025 FDB9			.proc	EditorSetupTabIndex
  1026 FDB9 98				tya
  1027 FDBA 29 07			and		#7
  1028 FDBC AA				tax
  1029 FDBD BD C1 E4			lda		ReversedBitMasks,x
  1030 FDC0 48				pha
  1031 FDC1 98				tya
  1032 FDC2 4A				lsr
  1033 FDC3 4A				lsr
  1034 FDC4 4A				lsr
  1035 FDC5 AA				tax
  1036 FDC6 68				pla
  1037 FDC7 60				rts
  1038 				.endp
  1039
  1040 				;==========================================================================
  1041 				; Copy TOADR to FRMADR and add 40 to TOADR.
  1042 				;
  1043 FDC8			.proc EditorNextLineAddr
  1044 FDC8 A5 66			lda		toadr
  1045 FDCA 85 68			sta		frmadr
  1046 FDCC 18 69 28			add		#40
  1047 FDCF 85 66			sta		toadr
  1048 FDD1 A5 67			lda		toadr+1
  1049 FDD3 85 69			sta		frmadr+1
  1050 FDD5 69 00			adc		#0
  1051 FDD7 85 67			sta		toadr+1
  1052 FDD9 60				rts
  1053 				.endp
  1054
  1055 				;==========================================================================
  1056 FDDA			.proc	EditorLineLengthTab
  1057 FDDA 78 50 28 00			dta		120, 80, 40, 0
  1058 				.endp
