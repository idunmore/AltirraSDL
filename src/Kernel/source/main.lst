   289 					.ifdef _KERNEL_816
   290 					.echo	'Free space: ', $FFE4-*, ' bytes'
   291 					.elif _KERNEL_XLXE
   292 					.echo	'Free space: ', $FFEE-*, ' bytes'
   292 				Free space: $0004 bytes
   293 					.else
   294 					.echo	'Free space: ', $FFFA-*, ' bytes'
   295 					.endif
   296
   297 				;==============================================================================
   298 				; version block (XL/XE)
   299 				;==============================================================================
   300
   301 					.ifdef _KERNEL_816
   302 					org		$ffe4
   303 					dta		a(IntDispatchNativeCop)		;$FFE4
   304 					dta		a(IntDispatchNativeBreak)	;$FFE6
   305 					dta		a(IntDispatchNativeAbort)	;$FFE8
   306 					dta		a(IntDispatchNativeNmi)		;$FFEA
   307 					dta		a(0)						;$FFEC
   308 					dta		a(IntDispatchNativeIrq)		;$FFEE
   309 					dta		$13							;$FFF0
   310 					dta		$02							;$FFF1 option byte - !!CHECKED BY ARCHON
   311 					dta		'CX'						;$FFF2
   312 					dta		a(IntDispatchCop)			;$FFF4
   313 					dta		a(0)						;$FFF6
   314 					dta		a(IntDispatchAbort)			;$FFF8
   315 					.elif _KERNEL_XLXE
   316 FFEA				org		$ffee
   317 FFEE 01 01 13			dta		$01,$01,$13
   318 FFF1 02				dta		$02					;option byte - !!CHECKED BY ARCHON
   319 FFF2 43 58 00 00 00		dta		'CX',$00,$00,$00
   320 FFF7 00				dta		$00
   321 FFF8 00 00			dta		a(0)
   322 					.endif
   323
   324 				;==============================================================================
   325 				; reset vectors
   326 				;==============================================================================
   327 FFFA				org		$fffa
   328 FFFA 8E C1			dta		a(IntDispatchNMI)
   329 FFFC BB EE			dta		a(InitReset)
   330 FFFE A2 C1			dta		a(IntDispatchIRQ)
   331
   332 					end
