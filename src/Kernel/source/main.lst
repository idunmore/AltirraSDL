     1 				    $E7EC -> $0302($022F)    Central Input/Output (CIO)
     3 = E7EC				.def ?@_kernel_lastpt = *
Source: source/main.xasm
   239
   240 					.if !_KERNEL_XLXE
   241 					icl		'vbi.s'
