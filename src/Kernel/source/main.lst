    10 E4EA			.proc CIOInit	
    11 E4EA 38				sec
    12 E4EB A2 70			ldx		#$70
    13 E4ED			iocb_loop:
    14 E4ED A9 FF			lda		#$ff
    15 E4EF 9D 40 03			sta		ichid,x
    16 E4F2 20 5E E7			jsr		CIOSetPutByteClosed
    17 E4F5 8A				txa
    18 E4F6 E9 10			sbc		#$10
    19 E4F8 AA				tax
    20 E4F9 10 F2			bpl		iocb_loop
    21 E4FB 60				rts
    22 				.endp
    23
    24 				;==============================================================================
    25 				;	Character I/O entry vector
    26 				;
    27 				;	On entry:
    28 				;		X = IOCB offset (# x 16)
    29 				;
    30 				;	Returns:
    31 				;		A = depends on operation
    32 				;		X = IOCB offset (# x 16)
    33 				;		Y = status (reflected in P)
    34 				;		P = set based on status (guaranteed by OS Manual)
    35 				;
    36 				;	Notes:
    37 				;		BUFADR must not be touched from CIO. DOS XE relies on this for
    38 				;		temporary storage and breaks if it is modified.
    39 				;
    40 				;	XL/XE mode notes:
    41 				;		HNDLOD is always set to $00 afterward, per Sweet 16 supplement 3.
    42 				;
    43 				;		CIO can optionally attempt a provisional open by doing a type 4 poll
    44 				;		over the SIO bus. This happens unconditionally if HNDLOD is non-zero
    45 				;		and only after the device is not found in HATABS if HNDLOD is zero.
    46 				;		If this succeeds, the IOCB is provisionally opened. Type 4 polling
    47 				;		ONLY happens for direct opens -- it does not happen for a soft open.
    48 				;
    49 E4FC			.proc CIO
    50 					;stash IOCB offset (X) and acc (A)
    51 E4FC 85 2F			sta		ciochr
    52 E4FE 86 2E			stx		icidno
    53 E500 20 13 E5			jsr		process
    54 E503			xit:
    55 					;copy status back to IOCB
    56 E503 A6 2E			ldx		icidno
    57 E505 98				tya
    58 E506 9D 43 03			sta		icsta,x
    59 					
    60 				.if _KERNEL_XLXE
    61 E509 A9 00 8D E9 02		mva		#0 hndlod
    62 				.endif
    63
    64 E50E A5 2F			lda		ciochr
    65
    66 					;set NZ condition codes based on status
    67 					;C=1 needed by GUNDISK.XEX
    68 E510 C0 00			cpy		#0
    69 E512 60				rts
    70 					
    71 E513			process:
    72 					;validate IOCB offset
    73 E513 8A				txa
    74 E514 29 8F			and		#$8f
    75 E516 F0 06			beq		validIOCB
    76 						
    77 					;return invalid IOCB error
    78 E518 A0 86			ldy		#CIOStatInvalidIOCB
    79 E51A 60				rts
    80 					
    81 E51B			cmdInvalid:
    82 					;invalid command <$03
    83 E51B A0 84			ldy		#CIOStatInvalidCmd
    84 E51D 60				rts
    85
    86 E51E			validIOCB:
    87 E51E 20 EB E6			jsr		CIOLoadZIOCB
    88 					
    89 					;check if we're handling the OPEN command
    90 E521 A5 22			lda		iccomz
    91 E523 C9 03			cmp		#CIOCmdOpen
    92 E525 F0 7B			beq		cmdOpen
    93 E527 90 F2			bcc		cmdInvalid
    94 					
    95 					;check if the IOCB is open
    96 E529 A4 20			ldy		ichidz
    97 					
    98 				.if !_KERNEL_XLXE
    99 					bpl		isOpen
   100 				.else
   101 E52B 30 15			bmi		not_open
   102 					
   103 					;check for a provisionally open IOCB
   104 E52D C8				iny
   105 E52E 10 2E			bpl		isOpen
   106 					
   107 					;okay, it's provisionally open... check if it's a close
   108 E530 C9 0C			cmp		#CIOCmdClose
   109 E532 D0 03 4C A2 E6		sne:jmp	cmdCloseProvisional
   110 					
   111 					;check if we're allowed to load a handler
   112 E537 AD E9 02			lda		hndlod
   113 E53A F0 06			beq		not_open
   114 					
   115 					;try to load the handler
   116 E53C 20 9C E7			jsr		CIOLoadHandler
   117 E53F 10 1D			bpl		isOpen
   118 E541 60				rts
   119 				.endif
   120 					
   121 E542			not_open:
   122 					;IOCB isn't open - issue error
   123 					;
   124 					;Special cases;
   125 					; - No error issued for close ($0C). This is needed so that extra CLOSE
   126 					;   commands from BASIC don't trip errors.
   127 					; - Get status ($0D) and special ($0E+) do soft open and close if needed.
   128 					;   $0D case is required for Top Dos 1.5a to boot; $0E+ case is encountered
   129 					;   with R: device XIO commands.
   130 					;
   131 E542 A0 01			ldy		#1
   132 E544 A5 22			lda		iccomz
   133 E546 C9 0C			cmp		#CIOCmdClose
   134 E548 F0 06			beq		ignoreOpen
   135 E54A C9 0D			cmp		#CIOCmdGetStatus
   136 E54C B0 03			bcs		preOpen				;closed IOCB is OK for get status and special
   137 E54E			not_open_handler:
   138 E54E A0 85			ldy		#CIOStatNotOpen
   139 E550			ignoreOpen:
   140 E550 60				rts
   141 					
   142 E551			preOpen:
   143 					;If the device is not open when a SPECIAL command is issued, parse the path
   144 					;and soft-open the device in the zero page IOCB.
   145 E551 20 FA E6			jsr		CIOParsePath
   146
   147 					;check for special command
   148 E554 A5 22			lda		iccomz
   149 E556 C9 0D			cmp		#CIOCmdGetStatus
   150 E558 F0 40			beq		cmdGetStatusSoftOpen
   151 E55A C9 0E			cmp		#CIOCmdSpecial
   152 E55C B0 3F			bcs		cmdSpecialSoftOpen
   153 					
   154 E55E			isOpen:
   155 E55E A6 22			ldx		iccomz
   156 E560 E0 0E			cpx		#CIOCmdSpecial
   157 E562 90 02 A2 0E			scc:ldx	#$0e
   158 					
   159 					;do permissions check
   160 E566 BD A9 E6			lda		perm_check_table-4,x
   161 E569 30 04			bmi		skip_perm_check
   162 E56B 24 2A			bit		icax1z
   163 E56D F0 26			beq		perm_check_fail
   164 E56F			skip_perm_check:
   165
   166 					;load command table vector
   167 E56F BD CA E6			lda		command_table_hi-4,x
   168 E572 48				pha
   169 E573 BD BF E6			lda		command_table_lo-4,x
   170 E576 48				pha
   171 					
   172 					;preload dispatch vector and dispatch to command
   173 E577 BC B4 E6			ldy		vector_preload_table-4,x
   174 E57A			load_vector:
   175 E57A A6 20			ldx		ichidz
   176 E57C BD 1B 03 85 2C BD + 	mwa		hatabs+1,x icax3z
   177 E586 B1 2C			lda		(icax3z),y
   178 E588 AA				tax
   179 E589 88				dey
   180 E58A B1 2C			lda		(icax3z),y
   181 E58C 85 2C			sta		icax3z
   182 E58E 86 2D			stx		icax3z+1
   183 					
   184 					;many commands want to check length=0 on entry
   185 E590 A5 28			lda		icbllz
   186 E592 05 29			ora		icblhz
   187 E594 60				rts
   188
   189 E595			perm_check_fail:
   190 					;at this point we have A=$04 if we failed a get perm check, and A=$08
   191 					;if we failed a put perm check -- these need to be translated to Y=$83
   192 					;and Y=$87.
   193 E595 18				clc
   194 E596 69 7F			adc		#$7f
   195 E598 A8				tay
   196 E599 60				rts
   197
   198 				;--------------------------------------------------------------------------
   199 E59A			cmdGetStatusSoftOpen:
   200 E59A A0 09			ldy		#9
   201 E59C 2C				dta		{bit $0100}
   202 E59D			cmdSpecialSoftOpen:
   203 E59D A0 0B			ldy		#11
   204 E59F			invoke_and_soft_close_xit:
   205 E59F 4C D9 E6			jmp		CIOInvoke
   206 						
   207 				;--------------------------------------------------------------------------
   208 				; Open command ($03).
   209 				;
   210 E5A2			cmdOpen:
   211 					;check if the IOCB is already open
   212 E5A2 A4 20			ldy		ichidz
   213 E5A4 C8				iny
   214 E5A5 F0 03			beq		notAlreadyOpen
   215 					
   216 					;IOCB is already open - error
   217 E5A7 A0 81			ldy		#CIOStatIOCBInUse
   218 E5A9 60				rts
   219 					
   220 E5AA			notAlreadyOpen:
   221 					;attempt to parse and open -- note that this will fail out directly
   222 					;on an unknown device or provisional open
   223 E5AA 20 FA E6			jsr		CIOParsePath
   224
   225 E5AD			open_entry:
   226 					;request open
   227 E5AD A0 01			ldy		#1
   228 E5AF 20 D9 E6			jsr		CIOInvoke
   229
   230 					;move handler ID and device number to IOCB
   231 E5B2 A6 2E			ldx		icidno
   232 E5B4 A5 20 9D 40 03		mva		ichidz ichid,x
   233 E5B9 A5 21 9D 41 03		mva		icdnoz icdno,x
   234
   235 E5BE 98				tya
   236 E5BF 10 01			bpl		openOK
   237 E5C1 60				rts
   238 					
   239 E5C2			openOK:
   240
   241 					;copy PUT BYTE vector for Atari Basic
   242 E5C2 A6 20			ldx		ichidz
   243 E5C4 BD 1B 03 85 2C BD + 	mwa		hatabs+1,x icax3z
   244 E5CE A0 06			ldy		#6
   245 E5D0 B1 2C			lda		(icax3z),y
   246 E5D2 A6 2E			ldx		icidno
   247 E5D4 9D 46 03			sta		icptl,x
   248 E5D7 C8				iny
   249 E5D8 B1 2C			lda		(icax3z),y
   250 E5DA 9D 47 03			sta		icpth,x
   251 E5DD A0 01			ldy		#1
   252 E5DF 60				rts
   253
   254 = E6DC			cmdGetStatus = CIOInvoke.invoke_vector
   255 E5E0			cmdSpecial:
   256 E5E0 20 DC E6			jsr		CIOInvoke.invoke_vector
   257
   258 					;need to copy AUX1/2 back for R:
   259 E5E3 A6 2E			ldx		icidno
   260 E5E5 A5 2A 9D 4A 03		mva		icax1z icax1,x
   261 E5EA A5 2B 9D 4B 03		mva		icax2z icax2,x
   262 E5EF 60				rts
   263 					
   264 				;--------------------------------------------------------------------------
   265 E5F0			cmdGetRecord:
   266 					;check if buffer is full on entry
   267 E5F0 F0 16			beq		cmdGetRecordBufferFull
   268 E5F2			cmdGetRecordLoop:
   269 E5F2			cmdGetRecordGetByte:
   270 					;fetch byte
   271 E5F2 20 DC E6			jsr		CIOInvoke.invoke_vector
   272 E5F5 C0 00			cpy		#0
   273 E5F7 30 1C			bmi		cmdGetRecordXit
   274 					
   275 					;store byte (even if EOL)
   276 E5F9 A2 00			ldx		#0
   277 E5FB 81 24			sta		(icbalz,x)
   278
   279 					;check for EOL
   280 E5FD 49 9B			eor		#$9b
   281 E5FF C9 01			cmp		#1
   282
   283 					;increment buffer pointer and decrement length
   284 E601 20 8C E6			jsr		advance_pointers
   285
   286 					;skip buffer full check if we had an EOL
   287 E604 90 0F			bcc		cmdGetRecordXit
   288
   289 					;loop back for more bytes if buffer not full
   290 E606 D0 EA			bne		cmdGetRecordLoop
   291 					
   292 E608			cmdGetRecordBufferFull:
   293 					;read byte to discard
   294 E608 20 DC E6			jsr		CIOInvoke.invoke_vector
   295 E60B C0 00			cpy		#0
   296 E60D 30 06			bmi		cmdGetRecordXit
   297
   298 					;continue if not EOL
   299 E60F C9 9B			cmp		#$9b
   300 E611 D0 F5			bne		cmdGetRecordBufferFull
   301
   302 					;return truncated record
   303 E613 A0 89			ldy		#CIOStatTruncRecord
   304
   305 E615			cmdGetRecordXit:
   306 E615			cmdGetPutDone:
   307 					;update byte count in IOCB
   308 E615 A6 2E			ldx		icidno
   309 E617 38				sec
   310 E618 BD 48 03			lda		icbll,x
   311 E61B E5 28			sbc		icbllz
   312 E61D 85 28			sta		icbllz		;required by Lightspeed DOS
   313 E61F 9D 48 03			sta		icbll,x
   314 E622 BD 49 03			lda		icblh,x
   315 E625 E5 29			sbc		icblhz
   316 E627 85 29			sta		icblhz
   317 E629 9D 49 03			sta		icblh,x
   318
   319 					;NOMAM 2013 BASIC Ten-Liners disk requires ICBALZ to be untouched :P
   320 E62C BD 44 03 85 24 BD + 	mwa		icbal,x icbalz
   321 					
   322 					;Pacem in Terris requires Y=1 exit.
   323 					;DOS 3.0 with 128K/XE mode requires Y=3 for EOF imminent.
   324 E636 60				rts
   325 					
   326 				;--------------------------------------------------------------------------
   327 E637			cmdGetChars:
   328 E637 F0 15			beq		cmdGetCharsSingle
   329 E639			cmdGetCharsLoop:
   330 E639 20 DC E6			jsr		CIOInvoke.invoke_vector
   331 E63C C0 00			cpy		#0
   332 E63E 30 0B			bmi		cmdGetCharsError
   333 E640 A2 00			ldx		#0
   334 E642 85 2F			sta		ciochr					;required by HOTEL title screen
   335 E644 81 24			sta		(icbalz,x)
   336 E646 20 8C E6			jsr		advance_pointers
   337 E649 D0 EE			bne		cmdGetCharsLoop
   338 E64B			cmdGetCharsError:
   339 E64B 4C 15 E6			jmp		cmdGetPutDone
   340 					
   341 E64E			cmdGetCharsSingle:
   342 E64E 20 DC E6			jsr		CIOInvoke.invoke_vector
   343 E651 85 2F			sta		ciochr
   344 E653 60				rts
   345 					
   346 				;--------------------------------------------------------------------------
   347 				; PUT RECORD handler ($09)
   348 				;
   349 				; Exit:
   350 				;	ICBAL/ICBAH: Not changed
   351 				;	ICBLL/ICBLH: Number of bytes processed
   352 				;
   353 				; If the string does not contain an EOL character, one is printed at the
   354 				; end. Also, in this case CIOCHR must reflect the last character in the
   355 				; buffer and not the EOL. (Required by Atari DOS 2.5 RAMDISK banner)
   356 				;
   357 				; If length=0, the character in the A register is output without an EOL.
   358 				; This behavior is required by the graphics library for Mad Pascal.
   359 				;
   360 E654			cmdPutRecord:
   361 E654 F0 33			beq		cmdPutCharsSingle
   362 E656			cmdPutRecordLoop:
   363 E656 A0 00			ldy		#0
   364 E658 B1 24			lda		(icbalz),y
   365 E65A 20 DC E6			jsr		CIOInvoke.invoke_vector
   366 E65D 98				tya
   367 E65E 30 12			bmi		cmdPutRecordError
   368 E660 20 8C E6			jsr		advance_pointers
   369 E663 F0 08			beq		cmdPutRecordEOL
   370 E665 A9 9B			lda		#$9b
   371 E667 C5 2F			cmp		ciochr
   372 E669 F0 07			beq		cmdPutRecordDone
   373 E66B D0 E7			bne		cmdPutRecord
   374 					
   375 E66D			cmdPutRecordEOL:
   376 E66D A9 9B			lda		#$9b
   377 E66F 20 DC E6			jsr		CIOInvoke.invoke_vector
   378 E672			cmdPutRecordError:
   379 E672			cmdPutRecordDone:
   380 E672 4C 15 E6			jmp		cmdGetPutDone
   381 					
   382 				;--------------------------------------------------------------------------
   383 E675			cmdPutChars:
   384 E675 F0 12			beq		cmdPutCharsSingle
   385 E677			cmdPutCharsLoop:
   386 E677 A0 00			ldy		#0
   387 E679 B1 24			lda		(icbalz),y
   388 E67B 20 DC E6			jsr		CIOInvoke.invoke_vector
   389 E67E 98				tya
   390 E67F 30 F1			bmi		cmdPutRecordError
   391 E681 20 8C E6			jsr		advance_pointers
   392 E684 D0 F1			bne		cmdPutCharsLoop
   393 E686 4C 15 E6			jmp		cmdGetPutDone
   394 E689			cmdPutCharsSingle:
   395 E689 4C DE E6			jmp		CIOInvoke.invoke_vector_ciochr
   396 					
   397 				;--------------------------------------------------------------------------
   398
   399 E68C			advance_pointers:
   400 E68C E6 24 D0 02 E6 25		inw		icbalz
   401 E692 A5 28 D0 02 C6 29 + 	dew		icbllz
   402 E69A D0 02 A5 29			sne:lda	icblhz
   403 E69E 60				rts
   404
   405 				;--------------------------------------------------------------------------
   406 E69F			cmdClose:
   407 E69F 20 DC E6			jsr		CIOInvoke.invoke_vector
   408 E6A2			cmdCloseProvisional:	
   409 E6A2 A6 2E			ldx		icidno
   410 E6A4 20 5E E7			jsr		CIOSetPutByteClosed
   411 E6A7 A9 FF 9D 40 03		mva		#$ff	ichid,x
   412 E6AC 60				rts
   413
   414 E6AD			perm_check_table:
   415 E6AD 04				dta		$04					;$04 (get record)
   416 E6AE 04				dta		$04					;$05 (get record)
   417 E6AF 04				dta		$04					;$06 (get chars)
   418 E6B0 04				dta		$04					;$07 (get chars)
   419 E6B1 08				dta		$08					;$08 (put record)
   420 E6B2 08				dta		$08					;$09 (put record)
   421 E6B3 08				dta		$08					;$0A (put chars)
   422 E6B4 08				dta		$08					;$0B (put chars)
   423 E6B5 FF				dta		$ff					;$0C (close)
   424 E6B6 FF				dta		$ff					;$0D (get status)
   425 E6B7 FF				dta		$ff					;$0E (special)
   426
   427 E6B8			vector_preload_table:
   428 E6B8 05				dta		$05					;$04 (get record)
   429 E6B9 05				dta		$05					;$05 (get record)
   430 E6BA 05				dta		$05					;$06 (get chars)
   431 E6BB 05				dta		$05					;$07 (get chars)
   432 E6BC 07				dta		$07					;$08 (put record)
   433 E6BD 07				dta		$07					;$09 (put record)
   434 E6BE 07				dta		$07					;$0A (put chars)
   435 E6BF 07				dta		$07					;$0B (put chars)
   436 E6C0 03				dta		$03					;$0C (close)
   437 E6C1 09				dta		$09					;$0D (get status)
   438 E6C2 0B				dta		$0b					;$0E (special)
   439
   440 E6C3			command_table_lo:
   441 E6C3 EF				dta		<(cmdGetRecord-1)	;$04
   442 E6C4 EF				dta		<(cmdGetRecord-1)	;$05
   443 E6C5 36				dta		<(cmdGetChars-1)	;$06
   444 E6C6 36				dta		<(cmdGetChars-1)	;$07
   445 E6C7 53				dta		<(cmdPutRecord-1)	;$08
   446 E6C8 53				dta		<(cmdPutRecord-1)	;$09
   447 E6C9 74				dta		<(cmdPutChars-1)	;$0A
   448 E6CA 74				dta		<(cmdPutChars-1)	;$0B
   449 E6CB 9E				dta		<(cmdClose-1)		;$0C
   450 E6CC DB				dta		<(cmdGetStatus-1)	;$0D
   451 E6CD DF				dta		<(cmdSpecial-1)		;$0E
   452
   453 E6CE			command_table_hi:
   454 E6CE E5				dta		>(cmdGetRecord-1)	;$04
   455 E6CF E5				dta		>(cmdGetRecord-1)	;$05
   456 E6D0 E6				dta		>(cmdGetChars-1)	;$06
   457 E6D1 E6				dta		>(cmdGetChars-1)	;$07
   458 E6D2 E6				dta		>(cmdPutRecord-1)	;$08
   459 E6D3 E6				dta		>(cmdPutRecord-1)	;$09
   460 E6D4 E6				dta		>(cmdPutChars-1)	;$0A
   461 E6D5 E6				dta		>(cmdPutChars-1)	;$0B
   462 E6D6 E6				dta		>(cmdClose-1)		;$0C
   463 E6D7 E6				dta		>(cmdGetStatus-1)	;$0D
   464 E6D8 E5				dta		>(cmdSpecial-1)		;$0E
   465 				.endp
   466
   467 				;==========================================================================
   468 				; Invoke device vector.
   469 				;
   470 				; Entry (standard):
   471 				;	A, X = ignored
   472 				;	Y = offset to high vector byte in device table
   473 				;
   474 				; Entry (invoke_vector):
   475 				;	A = byte to pass to PUT CHAR vector
   476 				;	X, Y = ignored
   477 				;
   478 				; Exit:
   479 				;	A = byte returned from GET CHAR vector
   480 				;	Y = status
   481 				;
   482 E6D9			.proc CIOInvoke
   483 E6D9 20 7A E5			jsr		CIO.load_vector		
   484 E6DC			invoke_vector:
   485 E6DC 85 2F			sta		ciochr
   486 E6DE			invoke_vector_ciochr:
   487 E6DE A5 2D			lda		icax3z+1
   488 E6E0 48				pha
   489 E6E1 A5 2C			lda		icax3z
   490 E6E3 48				pha
   491 E6E4 A0 92			ldy		#CIOStatNotSupported
   492 E6E6 A6 2E			ldx		icidno
   493 E6E8 A5 2F			lda		ciochr
   494 E6EA 60				rts
   495 				.endp
   496
   497 				;==========================================================================
   498 				; Copy IOCB to ZIOCB.
   499 				;
   500 				; Entry:
   501 				;	X = IOCB
   502 				;
   503 				; [OSManual p236] "Although both the outer level IOCB and the Zero-page
   504 				; IOCB are defined to be 16 bytes in size, only the first 12 bytes are
   505 				; moved by CIO."	
   506 				;
   507 E6EB			.proc CIOLoadZIOCB
   508 					;We used to do a trick here where we would count Y from $F4 to $00...
   509 					;but we can't do that because the 65C816 doesn't wrap abs,Y within
   510 					;bank 0 even in emulation mode. Argh!
   511 					
   512 E6EB A0 00			ldy		#0
   513 E6ED			copyToZIOCB:
   514 E6ED BD 40 03			lda		ichid,x
   515 E6F0 99 20 00			sta		ziocb,y
   516 E6F3 E8				inx
   517 E6F4 C8				iny
   518 E6F5 C0 0C			cpy		#12	
   519 E6F7 D0 F4			bne		copyToZIOCB
   520 E6F9 60				rts
   521 				.endp
   522
   523 				;==========================================================================
   524 E6FA			.proc CIOParsePath
   525 					;default to device #1
   526 E6FA A2 01			ldx		#1
   527
   528 					;pull first character of filename and stash it
   529 E6FC A1 23			lda		(icbalz-1,x)
   530 E6FE 85 2D			sta		icax4z
   531 						
   532 					;Check for a device number.
   533 					;
   534 					; - D1:-D9: is supported. D0: also gives unit 1, and any digits beyond
   535 					;   the first are ignored.
   536 					;
   537 					; We don't validate the colon anymore -- Atari OS allows opening just "C" to get
   538 					; to the cassette.
   539 					;
   540 E700 A0 01			ldy		#1
   541 E702 B1 24			lda		(icbalz),y
   542 E704 38				sec
   543 E705 E9 30			sbc		#'0'
   544 E707 F0 06			beq		nodevnum
   545 E709 C9 0A			cmp		#10
   546 E70B B0 02			bcs		nodevnum
   547 E70D AA				tax
   548 					
   549 E70E C8				iny
   550 					
   551 E70F			nodevnum:
   552 E70F 86 21			stx		icdnoz
   553 					
   554 				.if _KERNEL_XLXE
   555 					;check if we are doing a true open and if we should do a type 4 poll
   556 E711 A5 22			lda		iccomz
   557 E713 C9 03			cmp		#CIOCmdOpen
   558 E715 D0 3D			bne		skip_poll
   559 					
   560 					;clear DVSTAT+0/+1 to indicate no poll
   561 E717 A9 00			lda		#0
   562 E719 8D EA 02			sta		dvstat
   563 E71C 8D EB 02			sta		dvstat+1
   564 					
   565 					;check if we should do an unconditional poll (HNDLOD nonzero).
   566 E71F AD E9 02			lda		hndlod
   567 E722 D0 05			bne		unconditional_poll
   568 					
   569 					;search handler table
   570 E724 20 69 E7			jsr		CIOFindHandler
   571 E727 F0 34			beq		found
   572 					
   573 E729			unconditional_poll:
   574 					;do type 4 poll
   575 E729 20 7A E7			jsr		CIOPollForDevice
   576 E72C 30 2B			bmi		unknown_device
   577 					
   578 					;mark provisionally open
   579 E72E A6 2E			ldx		icidno
   580 E730 A9 7F 9D 40 03		mva		#$7f ichid,x
   581 E735 A5 2D 9D 4C 03		mva		icax4z icax3,x
   582 E73A AD EC 02 9D 4D 03		mva		dvstat+2 icax4,x
   583 E740 A9 C9 9D 46 03 A9 + 	mwa		#CIOPutByteLoadHandler-1 icptl,x
   584 E74A A5 21 9D 41 03		mva		icdnoz icdno,x
   585
   586 					;do direct exit, bypassing regular open path
   587 E74F 68				pla
   588 E750 68				pla
   589 E751 A0 01			ldy		#1
   590 E753 60				rts
   591
   592 E754			skip_poll:
   593 				.endif
   594
   595 					;search handler table
   596 E754 20 69 E7			jsr		CIOFindHandler
   597 E757 F0 04			beq		found
   598 					
   599 E759			unknown_device:
   600 					;return unknown device error
   601 E759 A0 82			ldy		#CIOStatUnkDevice
   602 E75B 68				pla
   603 E75C 68				pla
   604 E75D			found:
   605 E75D 60				rts
   606 				.endp
   607
   608 				;==========================================================================
   609 E75E			.proc CIOSetPutByteClosed
   610 E75E A9 4D			lda		#<[CIO.not_open_handler-1]
   611 E760 9D 46 03			sta		icptl,x
   612 E763 A9 E5			lda		#>[CIO.not_open_handler-1]
   613 E765 9D 47 03			sta		icpth,x
   614 E768 60				rts
   615 				.endp
   616
   617 				;==========================================================================
   618 				; Attempt to find a handler entry in HATABS.
   619 				;
   620 E769			.proc CIOFindHandler
   621 					;search for handler
   622 E769 A5 2D			lda		icax4z
   623 E76B A2 21			ldx		#11*3
   624 E76D			findHandler:
   625 E76D DD 1A 03			cmp		hatabs,x
   626 E770 F0 05			beq		foundHandler
   627 E772 CA				dex
   628 E773 CA				dex
   629 E774 CA				dex
   630 E775 10 F6			bpl		findHandler
   631 E777			foundHandler:
   632 					;store handler ID
   633 E777 86 20			stx		ichidz
   634 E779 60				rts
   635 				.endp
   636
   637 				;==========================================================================
   638 				; Poll SIO bus for CIO device
   639 				;
   640 				; Issues a type 4 poll ($4F/$40/devname/devnumber).
   641 				;
   642 				.if _KERNEL_XLXE
   643 E77A			.proc CIOPollForDevice
   644 E77A A5 2D			lda		icax4z
   645 E77C 8D 0A 03			sta		daux1
   646 E77F A5 21			lda		icdnoz
   647 E781 8D 0B 03			sta		daux2
   648 					
   649 E784 A2 09			ldx		#9
   650 E786 BD 92 E7 9D 00 03 + 	mva:rpl	cmd_tab,x ddevic,x-
   651 					
   652 E78F 4C 59 E4			jmp		siov
   653 					
   654 E792			cmd_tab:
   655 E792 4F				dta		$4f		;device
   656 E793 01				dta		$01		;unit
   657 E794 40				dta		$40		;command
   658 E795 40				dta		$40		;status (transfer flags)
   659 E796 EA				dta		<dvstat	;dbuflo
   660 E797 02				dta		>dvstat	;dbufhi
   661 E798 40				dta		$40		;dtimlo
   662 E799 00				dta		$00		;unused
   663 E79A 04				dta		$04		;dbytlo
   664 E79B 00				dta		$00		;dbythi
   665 				.endp
   666 				.endif
   667
   668 				;==========================================================================
   669 				; Load handler for a provisionally open IOCB.
   670 				;
   671 				.if _KERNEL_XLXE
   672 E79C			.proc CIOLoadHandler
   673 					;load handler over SIO bus
   674 E79C AD EC 02 8D D1 02 + 	mwa		dvstat+2 loadad
   675 E7A8 A6 2E			ldx		icidno
   676 E7AA BD 4D 03 8D 00 03		mva		icax4,x ddevic
   677 E7B0 18				clc
   678 E7B1 20 0E C5			jsr		PHLoadHandler
   679 E7B4 B0 11			bcs		fail
   680 					
   681 					;let's see if we can look up the handler now
   682 E7B6 A6 2E			ldx		icidno
   683 E7B8 BD 4C 03 85 2D		mva		icax3,x icax4z
   684 E7BD 20 69 E7			jsr		CIOFindHandler
   685 E7C0 D0 05			bne		fail
   686 					
   687 					;follow through with open
   688 E7C2 20 AD E5			jsr		CIO.open_entry
   689 E7C5 10 02			bpl		ok
   690 E7C7			fail:
   691 E7C7 A0 82			ldy		#CIOStatUnkDevice
   692 E7C9			ok:
   693 E7C9 60				rts
   694 				.endp
   695 				.endif
   696
   697 				;==========================================================================
   698 				; PUT BYTE handler for provisionally open IOCBs.
   699 				;
   700 				; This handler is used when an IOCB has been provisionally opened pending
   701 				; a handler load over the SIO bus. It is used when a direct call is made
   702 				; through ICPTL/ICPTH. If HNDLOD=0, the call fails as handler loading is
   703 				; not set up; if it is nonzero, the handler is loaded over the SIO bus and
   704 				; then the PUT BYTE call continues if everything is good.
   705 				;
   706 				.if _KERNEL_XLXE
   707 E7CA			.proc CIOPutByteLoadHandler
   708 					;save off A/X
   709 E7CA 85 2F			sta		ciochr
   710 E7CC 86 2E			stx		icidno
   711 						
   712 					;check if we're allowed to load a handler and bail if not
   713 E7CE AD E9 02			lda		hndlod
   714 E7D1 F0 10			beq		load_error
   715
   716 					;copy IOCB to ZIOCB
   717 E7D3 20 EB E6			jsr		CIOLoadZIOCB
   718
   719 					;try to load the handler
   720 E7D6 20 9C E7			jsr		CIOLoadHandler
   721 E7D9 30 08			bmi		load_error
   722 					
   723 					;all good... let's invoke the standard handler
   724 E7DB A0 07			ldy		#7
   725 E7DD 20 D9 E6			jsr		CIOInvoke
   726 E7E0 4C E5 E7			jmp		xit
   727 					
   728 E7E3			load_error:
   729 E7E3 A0 82			ldy		#CIOStatUnkDevice
   730 E7E5			xit:
   731 E7E5 08				php
   732 E7E6 A5 2F			lda		ciochr
   733 E7E8 A6 2E			ldx		icidno
   734 E7EA 28				plp
   735 E7EB 60				rts
   736 				.endp
   737 				.endif
   236 					.endif
   237
   238 E7EC				_KERNEL_REPORT_MODULE_SIZE 'Central Input/Output (CIO)', $E6D5-$E4A6
