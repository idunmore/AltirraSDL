    24 EEB8			.nowarn .proc _InitReset
    25 EEB8			run_diag:
    26 					; start diagnostic cartridge
    27 EEB8 6C FE BF			jmp		($bffe)
    28
    29 = EEBB			.def :InitReset
    30 					;mask interrupts and initialize CPU
    31 EEBB 78				sei
    32 EEBC D8				cld
    33 EEBD A2 FF			ldx		#$ff
    34 EEBF 9A				txs
    35 					
    36 				.if _KERNEL_XLXE
    37 					;wait for everything to stabilize (0.1s) (XL/XE only)
    38 EEC0 A0 8C			ldy		#140
    39 EEC2			stabilize_loop:
    40 EEC2 CA D0 FD			dex:rne
    41 EEC5 88				dey
    42 EEC6 D0 FA			bne		stabilize_loop
    43 					
    44 					;check for warmstart signature (XL/XE)
    45 EEC8 A2 02			ldx		#2
    46 EECA			warm_check:
    47 EECA BD 3D 03			lda		pupbt1,x
    48 EECD DD A6 EE			cmp		InitBootSignature,x
    49 EED0 D0 06			bne		cold_boot
    50 EED2 CA				dex
    51 EED3 10 F5			bpl		warm_check
    52 					
    53 EED5 4C 51 EF			jmp		InitWarmStart
    54 				.endif
    55
    56 = EED8			.def :InitColdStart
    57 EED8			cold_boot:
    58 					; 1. initialize CPU
    59 EED8 78				sei
    60 EED9 D8				cld
    61 EEDA A2 FF			ldx		#$ff
    62 EEDC 9A				txs
    63 					
    64 					; 2. clear warmstart flag
    65 EEDD E8				inx
    66 EEDE 86 08			stx		warmst
    67 					
    68 					; 3. test for diagnostic cartridge
    69 EEE0 AD FC BF			lda		$bffc
    70 EEE3 D0 17			bne		not_diag
    71 EEE5 A2 FF			ldx		#$ff
    72 EEE7 EC FF BF			cpx		$bfff			;prevent diagnostic cart from activating if addr is $FFxx
    73 EEEA F0 10			beq		not_diag
    74 EEEC 8E FC BF			stx		$bffc
    75 EEEF CD FC BF			cmp		$bffc
    76 EEF2 8D FC BF			sta		$bffc
    77 EEF5 D0 05			bne		not_diag
    78 					
    79 					; is it enabled?
    80 EEF7 2C FD BF			bit		$bffd
    81 EEFA 30 BC			bmi		run_diag
    82 						
    83 EEFC			not_diag:
    84 					
    85 EEFC 20 82 EF			jsr		InitHardwareReset
    86
    87 					.if _KERNEL_XLXE	
    88 					;check for OPTION and enable BASIC (note that we do NOT set BASICF just yet)
    89 EEFF A9 04			lda		#4
    90 EF01 2C 1F D0			bit		consol
    91 EF04 F0 12			beq		no_basic
    92
    93 				.ifdef _KERNEL_SOFTKICK
    94 					ldx		#$fc
    95 				.else
    96 EF06 A2 FD			ldx		#$fd
    97 				.endif
    98 					
    99 					;check for keyboard present + SELECT or no keyboard + no SELECT and enable game if so
   100 EF08 AD 12 D0			lda		trig2		;check keyboard present (1 = present)
   101 EF0B 0A				asl
   102 EF0C 4D 1F D0			eor		consol		;XOR against select (0 = pressed)
   103 EF0F 29 02			and		#$02
   104 					
   105 				.ifdef _KERNEL_SOFTKICK
   106 					seq:ldx	#$be
   107 				.else
   108 EF11 F0 02 A2 BF			seq:ldx	#$bf
   109 				.endif
   110
   111 EF15 8E 01 D3			stx		portb		;enable GAME or BASIC
   112
   113 EF18			no_basic:
   114 					.endif
   115
   116 					; 4. measure memory -> tramsz
   117 EF18 20 B2 EF			jsr		InitMemory
   118 					
   119 					; 6. clear memory from $0008 up to [tramsz,0]
   120 				.ifdef _KERNEL_SOFTKICK
   121 					ldx		#$50
   122 				.else
   123 EF1B A6 06			ldx		tramsz
   124 				.endif
   125 EF1D A0 08			ldy		#8
   126 EF1F A9 00 85 66			mva		#0 a1
   127 EF23 85 67			sta		a1+1
   128 EF25			clearloop:
   129 EF25 91 66 C8 D0 FB		sta:rne	(a1),y+
   130 EF2A E6 67			inc		a1+1
   131 EF2C CA				dex
   132 EF2D D0 F6			bne		clearloop
   133 					
   134 				.if _KERNEL_XLXE
   135 					;Blip the self test ROM for a second -- this is one way that Altirra detects
   136 					;that Option has been used by the OS. The XL/XE OS does this as part of its
   137 					;ROM checksum routine (which we don't bother with).
   138 EF2F AE 01 D3			ldx		portb
   139 EF32 8A				txa
   140 EF33 29 7F			and		#$7f
   141 EF35 8D 01 D3			sta		portb
   142 EF38 8E 01 D3			stx		portb
   143 				.endif
   144
   145 					; 7. set dosvec to blackboard routine
   146 				.if _KERNEL_USE_BOOT_SCREEN
   147 EF3B A9 9B 85 0A A9 E4 + 	mwa		#SelfTestEntry dosvec
   148 				.else
   149 					mwa		#Blackboard dosvec
   150 				.endif
   151 					
   152 					; 8. set coldstart flag
   153 EF43 CE 44 02			dec		coldst		;!! coldst=0 from clear loop above, now $ff
   154 					
   155 				.if _KERNEL_XLXE
   156 					; set BASIC flag
   157 EF46 AD 01 D3			lda		portb
   158 EF49 29 02			and		#$02
   159 EF4B 8D F8 03			sta		basicf
   160 				.endif
   161
   162 					; 9. set screen margins
   163 					; 10. initialize RAM vectors
   164 					; 11. set misc database values
   165 					; 12. enable IRQ interrupts
   166 					; 13. initialize device table
   167 					; 14. initialize cartridges
   168 					; 15. use IOCB #0 to open screen editor (E)
   169 					; 16. wait for VBLANK so screen is initialized
   170 					; 17. do cassette boot, if it was requested
   171 					; 18. do disk boot
   172 					; 19. reset coldstart flag
   173 					; 20. run cartridges or blackboard
   174 EF4E 4C F0 EF			jmp		InitEnvironment
   175 				.endp
   176
   177 				;==============================================================================
   178 EF51			.proc InitWarmStart
   179 					; A. initialize CPU
   180 					;
   181 					; Undocumented: Check if cold start completed (COLDST=0); if not, force
   182 					; a cold start. ACTris 2.1 relies on this since its boot doesn't reset
   183 					; COLDST. This is also required to work on Atari800WinPLus, which doesn't
   184 					; clear memory on a cold start.
   185 					;
   186 EF51 78				sei								;!! FIRST TWO BYTES CHECKED BY ARCHON
   187 EF52 AD 44 02			lda		coldst
   188 EF55 D0 81			bne		InitColdStart
   189 EF57 D8				cld
   190 EF58 A2 FF			ldx		#$ff
   191 EF5A 9A				txs
   192
   193 					; B. set warmstart flag
   194 EF5B 86 08			stx		warmst
   195 					
   196 					; reinitialize hardware without doing a full clear
   197 EF5D 20 82 EF			jsr		InitHardwareReset
   198 					
   199 					.if _KERNEL_XLXE
   200 					; reinitialize BASIC
   201 EF60 AD F8 03			lda		basicf
   202 EF63 D0 05 A9 FD 8D 01 + 	sne:mva #$fd portb
   203 					.endif
   204 					
   205 					; C. check for diag, measure memory, clear hw registers
   206 EF6A 20 B2 EF			jsr		InitMemory
   207 					
   208 					; D. zero 0010-007F and 0200-03EC (must not clear BASICF).
   209 EF6D A2 60			ldx		#$60
   210 EF6F A9 00			lda		#0
   211 EF71 95 0F CA D0 FB		sta:rne	$0f,x-
   212 					
   213 EF76			dbclear:
   214 EF76 9D 00 02			sta		$0200,x
   215 EF79 9D ED 02			sta		$02ed,x
   216 EF7C E8				inx
   217 EF7D D0 F7			bne		dbclear
   218 					
   219 					; E. steps 9-16 above
   220 					; F. if cassette boot was successful on cold boot, execute cassette init
   221 					; G. if disk boot was successful on cold boot, execute disk init
   222 					; H. same as steps 19 and 20
   223 EF7F 4C F0 EF			jmp		InitEnvironment
   224 				.endp
   225
   226 				;==============================================================================
   227 EF82			.proc InitHardwareReset
   228 					; clear all hardware registers
   229 EF82 A0 00			ldy		#0
   230 EF84 98				tya
   231 EF85			hwclear:
   232 EF85 99 00 D0			sta		$d000,y
   233 EF88 99 00 D2			sta		$d200,y
   234 EF8B 99 00 D4			sta		$d400,y
   235 EF8E C8				iny
   236 EF8F D0 F4			bne		hwclear
   237
   238 					;initialize PIA
   239 EF91 A9 3C			lda		#$3c
   240 EF93 A2 38			ldx		#$38
   241
   242 				.ifdef _KERNEL_SOFTKICK
   243 					stx		pactl		;switch to DDRA
   244 					sty		porta		;portA -> input
   245 					sta		pactl		;switch to IORA
   246 					sty		porta		;portA -> $00
   247 					sta		pbctl		;switch to IORB
   248 					dey
   249 					dey
   250 					sty		portb		;portB -> $FE
   251 					stx		pbctl		;switch to DDRB
   252 					iny
   253 					sty		portb		;portB -> all output
   254 					sta		pbctl		;switch to IORB
   255 				.elseif _KERNEL_XLXE
   256 EF95 8E 02 D3			stx		pactl		;switch to DDRA
   257 EF98 8C 00 D3			sty		porta		;portA -> input
   258 EF9B 8D 02 D3			sta		pactl		;switch to IORA
   259 EF9E 8C 00 D3			sty		porta		;portA -> $00
   260 EFA1 8D 03 D3			sta		pbctl		;switch to IORB
   261 EFA4 88				dey
   262 EFA5 8C 01 D3			sty		portb		;portB -> $FF
   263 EFA8 8E 03 D3			stx		pbctl		;switch to DDRB
   264 EFAB 8C 01 D3			sty		portb		;portB -> all output
   265 EFAE 8D 03 D3			sta		pbctl		;switch to IORB
   266 				.else
   267 					stx		pactl		;switch to DDRA
   268 					stx		pbctl		;switch to DDRB
   269 					sty		porta		;portA -> input
   270 					sty		portb		;portB -> input
   271 					sta		pactl		;switch to IORA
   272 					sta		pbctl		;switch to IORB
   273 					sty		porta		;portA -> $00
   274 					sty		portb		;portB -> $00
   275 				.endif
   276 EFB1 60				rts
   277 				.endp
   278
   279 				;==============================================================================
   280 EFB2			.proc InitMemory	
   281 					; 4. measure memory -> tramsz
   282 EFB2 A0 00			ldy		#$00
   283 EFB4 84 64			sty		adress
   284 EFB6 A2 02			ldx		#$02
   285 EFB8			pageloop:
   286 EFB8 86 65			stx		adress+1
   287 EFBA B1 64			lda		(adress),y
   288 EFBC 49 FF			eor		#$ff
   289 EFBE 91 64			sta		(adress),y
   290 EFC0 D1 64			cmp		(adress),y
   291 EFC2 D0 09			bne		notRAM
   292 EFC4 49 FF			eor		#$ff
   293 EFC6 91 64			sta		(adress),y
   294 EFC8 E8				inx
   295
   296 				.if _KERNEL_XLXE
   297 EFC9 E0 C0			cpx		#$c0
   298 				.else
   299 					cpx		#$d0
   300 				.endif
   301
   302 EFCB D0 EB			bne		pageloop
   303 EFCD			notRAM:
   304 EFCD 86 06			stx		tramsz
   305 					
   306 EFCF 60				rts
   307 				.endp
