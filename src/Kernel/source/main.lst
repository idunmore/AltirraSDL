    38 				;==========================================================================
    39 				; ScreenResetLogicalLineMap
    40 				;
    41 				; Marks all lines as the start of logical lines.
    42 				;
    43 				; Exit:
    44 				;	X = 0
    45 				;
    46 FDEE			.proc ScreenResetLogicalLineMap
    47 FDEE A2 FF			ldx		#$ff
    48 FDF0 8E B2 02			stx		logmap
    49 FDF3 8E B3 02			stx		logmap+1
    50 FDF6 8E B4 02			stx		logmap+2
    51 					
    52 					;reset line read position
    53 FDF9 E8				inx
    54 FDFA 86 6C			stx		bufstr
    55 FDFC A5 52			lda		lmargn
    56 FDFE 85 6D			sta		bufstr+1
    57 					
    58 					;note - X=0 relied on here by EditorOpen
    59 FE00 60				rts
    60 				.endp
    61
    62 				;==========================================================================
    63 				; ScreenSetLastPosition
    64 				;
    65 				; Copies COLCRS/ROWCRS to OLDCOL/OLDROW.
    66 				;
    67 FE01			.proc ScreenSetLastPosition
    68 FE01 A2 02			ldx		#2
    69 FE03			loop:
    70 FE03 B5 54			lda		rowcrs,x
    71 FE05 95 5A			sta		oldrow,x
    72 FE07 CA				dex
    73 FE08 10 F9			bpl		loop
    74 FE0A 60				rts
    75 				.endp
    76
    77 				;==========================================================================
    78 				; ScreenAdvancePosMode0
    79 				;
    80 				; Advance to the next cursor position in reading order, for mode 0.
    81 				;
    82 				; Exit:
    83 				;	C = 1 if no wrap, 0 if wrapped
    84 				;
    85 				; Modified:
    86 				;	X
    87 				;
    88 				; Preserved:
    89 				;	A
    90 				;
    91 FE0B			.proc ScreenAdvancePosMode0
    92 FE0B E6 55			inc		colcrs
    93 FE0D A6 53			ldx		rmargn
    94 FE0F E4 55			cpx		colcrs
    95 FE11 B0 06			bcs		post_wrap
    96 FE13 A6 52			ldx		lmargn
    97 FE15 86 55			stx		colcrs
    98 FE17 E6 54			inc		rowcrs
    99 FE19			post_wrap:
   100 FE19 60				rts
   101 				.endp
   102
   103
   104 				;==========================================================================
   105 				; Output:
   106 				;	Y=1 for convenience
   107 				;
   108 				; (OLDADR) must point to the cursor location with OLDCHR even if the cursor
   109 				; is hidden. This is required by SDX QUICKED.SYS, which always restores the
   110 				; cursor.
   111 				;
   112 				; Success output must be exactly Y=1 and not another positive value, or
   113 				; DARG breaks.
   114 				;
   115 FE1A			.proc ScreenShowCursorAndXitOK
   116 					;;##ASSERT dw(oldadr) >= dw(savmsc)
   117 					;check if the cursor is enabled
   118 FE1A A0 00			ldy		#0
   119 FE1C B1 5E			lda		(oldadr),y
   120 FE1E 85 5D			sta		oldchr
   121 FE20 AE F0 02			ldx		crsinh
   122 FE23 D0 04			bne		cursor_inhibited
   123 FE25 49 80			eor		#$80
   124 FE27 91 5E			sta		(oldadr),y
   125 FE29			cursor_inhibited:
   126 FE29 C8				iny
   127 FE2A 60				rts
   128 				.endp
   129
   130 				;==========================================================================
   131 				; Close screen (S:).
   132 				;
   133 				; This is a no-op in OS-B mode. In XL/XE mode, it reopens the device in
   134 				; Gr.0 if fine scrolling is on, since this is necessary to clear the DLI.
   135 				; This happens even if S: doesn't correspond to the text window. Only
   136 				; the high bit of FINE is checked.
   137 				;
   138 				.if !_KERNEL_XLXE
   139 				ScreenClose = CIOExitSuccess
   140 				.else
   141 FE2B			.proc ScreenClose
   142 FE2B 2C 6E 02			bit		fine
   143 FE2E 30 03			bmi		disable_fine_scrolling
   144 					
   145 FE30 A0 01			ldy		#1
   146 FE32 60				rts
   147
   148 FE33			disable_fine_scrolling:
   149 					;turn off DLI
   150 FE33 A9 40 8D 0E D4		mva		#$40 nmien
   151 					
   152 					;restore vdslst
   153 FE38 A2 55			ldx		#<IntExitHandler_None
   154 FE3A A9 C0			lda		#>IntExitHandler_None
   155 FE3C 20 9F F5			jsr		ScreenOpenGr0.write_vdslst
   156 					
   157 FE3F 4C EE F3			jmp		ScreenOpenGr0
   158 				.endp
   159 				.endif
   160
   161 				;==========================================================================
   162 				.if !_KERNEL_XLXE
   163 					_SCREEN_TABLES_2
   164 				.endif
   276 					.endif
