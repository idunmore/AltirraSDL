  2055 DF52 06 DF			asl		fre+5
  2056 DF54 26 DE			rol		fre+4
  2057 DF56 26 DD			rol		fre+3
  2058 DF58 26 DC			rol		fre+2
  2059 DF5A 26 DB			rol		fre+1
