  1457 DC9A			.proc fp_fmul_innerloop
  1458 = 00DF			_offset = _fr3+5
  1459 = 00E6			_offset2 = fr2
  1460
  1461 						;begin outer loop -- this is where we process one _bit_ out of each
  1462 						;multiplier byte in FR2's mantissa (note that this is inverted in that
  1463 						;it is bytes-in-bits instead of bits-in-bytes)
  1464 DC9A			offloop:
  1465 						;double multiplicand in fr1
  1466 DC9A 18					clc
  1467 DC9B A5 E5				lda		fr1+5
  1468 DC9D 65 E5				adc		fr1+5
  1469 DC9F 85 E5				sta		fr1+5
  1470 DCA1 A5 E4				lda		fr1+4
  1471 DCA3 65 E4				adc		fr1+4
  1472 DCA5 85 E4				sta		fr1+4
  1473 DCA7 A5 E3				lda		fr1+3
  1474 DCA9 65 E3				adc		fr1+3
  1475 DCAB 85 E3				sta		fr1+3
  1476 DCAD A5 E2				lda		fr1+2
  1477 DCAF 65 E2				adc		fr1+2
  1478 DCB1 85 E2				sta		fr1+2
  1479 DCB3 A5 E1				lda		fr1+1
  1480 DCB5 65 E1				adc		fr1+1
  1481 DCB7 85 E1				sta		fr1+1
  1482 DCB9 A5 E0				lda		fr1+0
  1483 DCBB 65 E0				adc		fr1+0
  1484 DCBD 85 E0				sta		fr1+0
  1485
  1486 DCBF			offloop_entry:
  1487 						;begin inner loop -- here we process the same bit in each multiplier
  1488 						;byte, going from byte 5 down to byte 1
  1489 DCBF A2 05				ldx		#5
  1490 DCC1			offloop2:
  1491 						;shift an inverted bit out of multiplier byte
  1492 DCC1 56 E6				lsr		fr2,x
  1493 DCC3 B0 33				bcs		post_addsub
  1494 							
  1495 						;add fr1 to fr0 at offset	
  1496 						.rept 6
  1497 							LDA		FR0+(5-#),X
  1498 							ADC		FR1+(5-#)
  1499 							STA		FR0+(5-#),X
  1500 						.endr
