   768 				;==========================================================================
   769 FCC8			.proc	EditorRecomputeCursorAddr
   770 FCC8 A6 55			ldx		colcrs
   771 FCCA A4 54			ldy		rowcrs
   772 = FCCC			.def :ScreenComputeAddrToOldAdr
   773 FCCC 20 68 F9			jsr		ScreenComputeAddr
   774 FCCF 86 5E			stx		oldadr
   775 FCD1 85 5F			sta		oldadr+1
   776 FCD3 60				rts
   777 				.endp
   778
   779 				;==========================================================================
   780 				; Delete a logical line on screen, and scroll the remainder of the screen
   781 				; upward.
   782 				;
   783 				; Inputs:
   784 				;	A = physical line row to delete
   785 				;
   786 				; Outputs:
   787 				;	DELTAR = number of lines scrolled
   788 				;
   789 = FCD6			EditorDeleteLine = EditorDeleteLine0.use_line
   790 FCD4			.proc	EditorDeleteLine0
   791 FCD4 A9 00			lda		#0
   792 FCD6			use_line:
   793 FCD6 85 51			sta		hold1
   794 FCD8 A2 00			ldx		#0
   795 FCDA 86 76			stx		deltar
   796 						
   797 FCDC			scroll_loop:
   798 					;compute base address and set that as destination
   799 FCDC A4 51			ldy		hold1
   800
   801 				.if _KERNEL_XLXE
   802 FCDE 38				sec
   803 FCDF D0 21			bne		nofine
   804 FCE1 AE 6E 02			ldx		fine
   805 FCE4 F0 1C			beq		nofine
   806 FCE6 A2 00			ldx		#0
   807 FCE8			xloop:
   808 FCE8 A5 14			lda		rtclok+2
   809 FCEA C5 14 F0 FC			cmp:req	rtclok+2
   810 FCEE E8				inx
   811 FCEF 8E 05 D4			stx		vscrol
   812 FCF2 E0 07			cpx		#7
   813 FCF4 D0 F2			bne		xloop
   814 FCF6 A9 10			lda		#32/2
   815 FCF8 CD 0B D4 90 FB		cmp:rcc	vcount
   816 FCFD CD 0B D4 B0 FB		cmp:rcs	vcount
   817 FD02			nofine:
   818 FD02 08				php					;C=0 for fine scroll, C=1 for coarse scroll
   819 				.endif
   820
   821 					;set TOADR to the line to be deleted
   822 FD03 20 7E F9			jsr		ScreenComputeToAddrX0
   823 					
   824 FD06 A6 51			ldx		hold1
   825 FD08 10 0C			bpl		line_loop_start
   826 					
   827 FD0A			line_loop:
   828 					;bump line: FRMADR <- TOADR, TOADR += 40
   829 FD0A 20 C8 FD			jsr		EditorNextLineAddr
   830 					
   831 					;move line -- note that we are copying backwards (TOADR to FRMADR)!
   832 FD0D A0 27			ldy		#39
   833 FD0F B1 66 91 68 88 10 + 	mva:rpl	(toadr),y (frmadr),y-
   834 					
   835 FD16			line_loop_start:
   836 FD16 E8				inx
   837 FD17 EC BF 02			cpx		botscr
   838 FD1A D0 EE			bne		line_loop
   839 					
   840 					;clear the last line
   841 FD1C A0 27			ldy		#39
   842 FD1E A9 00			lda		#0
   843 FD20 91 66 88 10 FB		sta:rpl	(toadr),y-
   844 					
   845 				.if _KERNEL_XLXE
   846 FD25 28				plp
   847 FD26 B0 03			bcs		nofinescroll2
   848 FD28 8D 05 D4			sta		vscrol
   849 FD2B			nofinescroll2:
   850 				.endif
   851 					
   852 FD2B 20 60 FD			jsr		adjust_lines
   853 					
   854 					;delete bits out of the logical mask until we get to the next
   855 					;logical line, computing the number of lines to scroll
   856 FD2E A5 51			lda		hold1
   857 FD30 20 79 FD			jsr		EditorGetLogicalLineInfo
   858 FD33 BE 5D FD			ldx		update_table,y		;get number of masks to shift
   859 FD36 38				sec							;setup to add a new logical line at the end
   860 FD37 F0 09			beq		do_mask				;jump to masking if we're on byte 2
   861 FD39 2E B4 02			rol		logmap+2			;shift byte 2
   862 FD3C CA				dex							;
   863 FD3D F0 03			beq		do_mask				;jump to masking if we're on byte 1
   864 FD3F 2E B3 02			rol		logmap+1			;shift byte 1
   865 FD42			do_mask:
   866 FD42 85 64			sta		adress				;stash mask
   867 FD44 49 FF			eor		#$ff				;invert mask
   868 FD46 39 B2 02			and		logmap,y			;kill target bit
   869 FD49 85 65			sta		adress+1			;stash modified mask
   870 FD4B C6 64			dec		adress				;form mask for LSBs below bit
   871 FD4D 25 64			and		adress				;isolate those bits
   872 FD4F 65 65			adc		adress+1			;shift those up and the bit from the next byte in
   873 FD51 99 B2 02			sta		logmap,y			;write to logmap
   874
   875 FD54 E6 76			inc		deltar				;increment line count
   876 FD56 E6 64			inc		adress				;revert mask
   877 FD58 24 64			bit		adress				;test if we still have a logical line
   878
   879 					;loop back if we need to delete more physical lines
   880 FD5A F0 80			beq		scroll_loop
   881 					
   882 					;all done
   883 FD5C 60				rts
   884 					
   885 FD5D			update_table:
   886 FD5D 02 01 00			dta		2,1,0
   887
   888 FD60			adjust_lines:
   889 FD60 A5 52			lda		lmargn				;prep for line adjustments
   890 					
   891 					;adjust the read row if it is affected by the deletion
   892 FD62 A2 6C			ldx		#<bufstr
   893 FD64 20 69 FD			jsr		adjust_line
   894
   895 					;adjust the cursor row if it is affected by the deletion
   896 FD67 A2 54			ldx		#<rowcrs
   897 FD69			adjust_line:
   898 FD69 B4 00			ldy		0,x						;get row
   899 FD6B C4 51			cpy		hold1					;compare against deletion pos
   900 FD6D 90 07			bcc		adjust_line_above		;nothing to do if it's above del range
   901 FD6F D0 03			bne		adjust_line_below		;skip col adjust if it's below del range
   902 FD71 95 01			sta		1,x						;within range - move cursor to left mgn
   903 FD73 60				rts
   904 FD74			adjust_line_below:
   905 FD74 D6 00			dec		0,x
   906 FD76			adjust_line_above:
   907 FD76 60				rts	
   908 				.endp
   909
   910 				;==========================================================================
   911 = E4C9			EditorGetStatus = CIOExitSuccess
   912 = E4CB			EditorSpecial = CIOExitNotSupported
   913 = E4CB			EditorInit = CIOExitNotSupported
   914
   915 				;==========================================================================
   916 				; Entry:
   917 				;	A = line
   918 				;
   919 				; Exit:
   920 				;	P = bit test status
   921 				;	A = bit mask
   922 				;	X = bit index
   923 				;	Y = mask index
   924 				;
   925 = FD77			EditorGetCurLogicalLineInfo = _EditorGetLogicalLineInfo
   926 = FD79			EditorGetLogicalLineInfo = _EditorGetLogicalLineInfo.use_a
   927 FD77			.proc	_EditorGetLogicalLineInfo
   928 FD77 A5 54			lda		rowcrs
   929 FD79			use_a:
   930 FD79 48				pha
   931 FD7A 4A				lsr
   932 FD7B 4A				lsr
   933 FD7C 4A				lsr
   934 FD7D A8				tay
   935 FD7E 68				pla
   936 FD7F 29 07			and		#7
   937 FD81 AA				tax
   938 FD82 BD C1 E4			lda		ReversedBitMasks,x
   939 FD85 60				rts
   940 				.endp
   941
   942 				;==========================================================================
   943 				; Test whether a physical line is the start of a logical line.
   944 				;
   945 				; Entry:
   946 				;	A = line
   947 				;
   948 				; Exit:
   949 				;	Z = 1 if so, 0 if not
   950 				;
   951 				; Modified:
   952 				;	all registers
   953 				;
   954 FD86			.proc	EditorTestLogicalLineBit
   955 FD86 20 79 FD			jsr		EditorGetLogicalLineInfo
   956 FD89 39 B2 02			and		logmap,y
   957 FD8C 60				rts
   958 				.endp
   959
   960 				;==========================================================================
   961 				; Get the starting physical line for a logical line.
   962 				;
   963 				; Entry:
   964 				;	A = physical line
   965 				;
   966 				; Exit:
   967 				;	A = logical line start
   968 				;
   969 				; Modified:
   970 				;	ADRESS
   971 				;
   972 = FD8F			EditorPhysToLogicalRow = EditorGetCurLogicalRow.use_line
   973 FD8D			.proc	EditorGetCurLogicalRow
   974 FD8D A5 54			lda		rowcrs
   975 FD8F			use_line:
   976 FD8F 85 64			sta		adress
   977 FD91			test_loop:
   978 FD91 A5 64			lda		adress
   979 FD93 20 86 FD			jsr		EditorTestLogicalLineBit
   980 FD96 D0 04			bne		found
   981 FD98 C6 64			dec		adress
   982 FD9A D0 F5			bne		test_loop
   983 FD9C			found:
   984 FD9C A5 64			lda		adress
   985 FD9E 60				rts
   986 				.endp
   987
   988 				;==========================================================================
   989 FD9F			.proc	EditorSwapToScreen_Y1
   990 FD9F A0 01			ldy		#1
   991 = FDA1			.def :EditorSwapToScreen = *
   992 FDA1 84 64			sty		adress
   993 FDA3 18				clc
   994 FDA4 20 4B F9			jsr		ScreenSwap
   995 FDA7 A4 64			ldy		adress
   996 FDA9 60				rts
   997 				.endp
