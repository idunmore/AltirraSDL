  2104 				;==========================================================================
  2105 				; Arctangent coefficients (required by Atari BASIC and Turbo Basic XL)
  2106 				;
  2107 				; The 11 coefficients here form a power series approximation
  2108 				; f(x^2) ~= atn(x)/x. These are not used by the math pack itself and
  2109 				; not officially documented, but are stored in the math pack for use
  2110 				; by Atari BASIC's ATN() function.
  2111 				;
  2112 				; See Ruckdeschel, Table V1.10a, page 172.
  2113 				;
  2114 DFAE					fixadr	$dfae
Macro: FIXADR [Source: source/Shared/mathpack.s]
Source: source/Shared/mathpack.s
  2115 DFAE			fpconst_atncoef:
  2116 DFAE 3E 16 05 44 49 22			dta		$3E, $16, $05, $44, $49, $22	;A10 =  0.001605444922
  2117 DFB4 BE 95 68 38 45 20			dta		$BE, $95, $68, $38, $45, $20	;A9  = -0.009568384520
  2118 DFBA 3F 02 68 79 94 16			dta		$3F, $02, $68, $79, $94, $16	;A8  =  0.0268799415 61
  2119 DFC0 BF 04 92 78 90 80			dta		$BF, $04, $92, $78, $90, $80	;A7  = -0.0492789080 30
  2120 DFC6 3F 07 03 15 20 00			dta		$3F, $07, $03, $15, $20, $00	;A6  =  0.0703152000 33
  2121 DFCC BF 08 92 29 12 44			dta		$BF, $08, $92, $29, $12, $44	;A5  = -0.0892291243 81
  2122 DFD2 3F 11 08 40 09 11			dta		$3F, $11, $08, $40, $09, $11	;A4  =  0.1108400911 04
  2123 DFD8 BF 14 28 31 56 04			dta		$BF, $14, $28, $31, $56, $04	;A3  = -0.1428315603 76
  2124 DFDE 3F 19 99 98 77 44			dta		$3F, $19, $99, $98, $77, $44	;A2  =  0.1999987744 21
  2125 DFE4 BF 33 33 33 31 13			dta		$BF, $33, $33, $33, $31, $13	;A1  = -0.3333333112 86
  2126 DFEA			fpconst_one:
  2127 DFEA 40 01 00 00 00 00			dta		$40, $01, $00, $00, $00, $00		;1.0 (also an arctan coeff)
