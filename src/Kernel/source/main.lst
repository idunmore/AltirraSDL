    10 				.ifndef f_SIO_INC
    11 				.def f_SIO_INC
    12
    13 				SIOSuccess			= $01
    14 				SIOErrorTimeout		= $8A
    15 				SIOErrorNAK			= $8B
    16 				SIOErrorBadFrame	= $8C
    17 				SIOErrorOverrun		= $8E
    18 				SIOErrorChecksum	= $8F
