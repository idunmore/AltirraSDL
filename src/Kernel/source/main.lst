  2028 DF34 06 F8				asl		_fptemp0
  2029 DF36 66 D4				ror		fr0
  2030 DF38 20 66 DA				jsr		fadd
  2031 					
  2032 						;scale if doing log
  2033 DF3B 24 F9				bit		_fptemp1
  2034 DF3D 30 9C				bmi		xit2
