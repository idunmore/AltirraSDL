     9
    10 				;==========================================================================
    11 				; Math pack design and references
    12 				;
    13 				; The current version of the AltirraOS math pack is designed with the
    14 				; following goals:
    15 				;
    16 				; - Match the behavior, results, and memory usage of the standard math pack
    17 				;   as much as possible within reasonable constraints. This includes the
    18 				;   truncation behavior of the original math pack.
    19 				;
    20 				; - When there is a difference between the OS-B and XL math packs, prefer
    21 				;   to match the XL math pack.
    22 				;
    23 				; - Try to support undocumented code and data usage of popular programs,
    24 				;   including: Atari BASIC, Basic XL/XE, Turbo Basic XL, and MAC/65.
    25 				;
    26 				; Turbo Basic XL is the most troublesome to support. Atari BASIC mainly
    27 				; just uses the ATN() and a couple of additional constants, but TBXL
    28 				; reimplements LOG/LOG10/EXP/EXP10 internally while borrowing the
    29 				; associated constants and polynomials. This means that we must use a
    30 				; compatible algorithm with the same data for TBXL's LOG(), CLOG(), EXP(),
    31 				; ^, and SQR() functions to work.
    32 				;
    33 				; To support the above, some formulas and constants have been pulled from
    34 				; the same upstream reference used by the original math pack programmers:
    35 				;
    36 				; Ruckdeschel, F.R. (1981). BASIC Scientific Subroutines, Vol. I, BYTE/McGraw-Hill
    37 				;
    38 				; In particular, the minimax polynomials for the transcendental function
    39 				; approximations come from this book. Note that in a couple of cases the
    40 				; original math pack has mistakes where the polynomials are not evaluated
    41 				; over their proper interval; where noticed, this has been replicated here.
    42 				;
    43 				;==========================================================================
    44 				; Math pack memory usage constraints
    45 				;                                                                            INBUFF          DEGFLG
    46 				;                                                                  NSIGN  DIGRT          ZTEMP3
    47 				;                                                                EEXP  FCHRFLG       ZTEMP4        FPTR2       FPSCR
    48 				;                                                              FRX   ESIGN CIX   ZTEMP1        FLPTR     PLYARG      FPSCR1
    49 				;              $D4     $D8     $DC     $E0     $E4     $E8     $EC     $F0     $F4     $F8     $FC     | $05E0 $05E6 $05EC
    50 				;              . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . . | ..................
    51 				;              [-- FR0 --] [-- FRE --] [-- FR1 --] [-- FR2 --]               [-] [-] [-] [-]   [-] [-] |
    52 				; FADD/FSUB    M M M M M M M . . . !!! M M M M M M . . . . . . . . . ! ! . . . . . . M M M . ! . . . . |
    53 				; FMUL         M M M M M M M M M M M M M r r r r r M M M M M M M M M ! ! . . . . M M M . . . ! . . . . |
    54 				; FDIV         M M M M M M M M M M M M M r r r r r M M M M M M M M M ! ! . . . . M . M . . . ! . . . . |
    55 				; PLYEVL       M M M M M M M M M M M M M M M M M M M M M M M M M M M M ! . . . . M M M M M . ! M M M M | MMMMMM............
    56 				; EXP/EXP10    M M M M M M M M M M M M M M M M M M M M M M M M M M M M M M . . . M M M M M . ! M M M M | MMMMMM............
    57 				; LOG/LOG10    M M M M M M M M M M M M M M M M M M M M M M M M M M M M M M . . . M M M M M . ! M M M M | MMMMMMMMMMMM......
    58 				; REDRNG       M M M M M M M M M M M M M M M M M M M M M M M M M M M . . . . . . M . M . . . ! M M M M | MMMMMMMMMMMM......
    59 				;
    60 				; AFP          M M M M M M M . . . . . . . . . . . . . . . . . M M M M M M M . . . . . . . . ! . . . . |
    61 				; FASC         r r r r r r . . . . . . . . . . . . . . . . . . . M . . . . M M M . . M . . . ! . . . . |
    62 				; IFP          M M M M M M . . . . !!! . . . . . . . . . . . . . . . . . . . . . . . . M M . ! . . . . |
    63 				; FPI          M M M M M M . . . . . . !!!!!!!!!!! . . . . . . M . . . . . . . . M . M M M M ! . . . . |
    64 				;
    65 				; M = modified by original math pack
    66 				; r = read by original math pack
    67 				; ! = program known to rely on not being modified
    68 				;
    69 				; Notes:
    70 				; [1] BASIC XE relies on $DE/DF not being touched by FADD, or FOR/NEXT
    71 				;     breaks.
    72 				; [2] MAC/65 relies on $DE/DF not being touched by IFP.
    73 				; [3] DARG relies on FPI not touching FR1.
    74 				; [4] ACTris 1.2 relies on FASC not touching lower parts of FR2.
    75 				; [5] Atari BASIC SQR() uses ESIGN ($EF).
    76 				; [6] Atari BASIC SIN() uses FCHRFLG ($F0).
    77 				;
    78
    79 				;==========================================================================
    80 = 00EC			_fpcocnt = $00ec			;FP: temporary storage - polynomial coefficient counter
    81 = 00F8			_fptemp0 = $00f8			;FP: temporary storage - transcendental temporary (officially ZTEMP4+1)
    82 = 00F9			_fptemp1 = $00f9			;FP: temporary storage - transcendental temporary (officially ZTEMP3)
    83
    84 				;==========================================================================
    85 				.macro	ckaddr
    86 				.if * <> %%1
    87 						.error	'Incorrect address: ',*,' != ',%%1
    88 				.endif
    89 				.endm
    90
    91 				.macro	fixadr
    92 				.if * < %%1
    93 						.print (%%1-*),' bytes free before ',%%1
    94 						org		%%1
    95 				.elif * > %%1
    96 						.error 'Out of space: ',*,' > ',%%1,' (',*-%%1,' bytes over)'
    97 						.endif
    98 				.endm
    99
   100 				;==========================================================================
   101 				; AFP [D800]	Convert ATASCII string at INBUFF[CIX] to FR0
   102 				;
   103 				; Parses a floating point number in ATASCII starting at INBUFF[CIX] to
   104 				; FR0.
   105 				;
   106 				; Returns:
   107 				;	C = 0 and number in FR0 if successful, C = 1 if failure
   108 				;	CIX = next position after parsed number, if any
   109 				;
   110 				; A valid floating point number is of the following form:
   111 				;
   112 				;	- Zero or more spaces
   113 				;	- A single optional + or - sign
   114 				;	- A period followed by one or more digits, or one or more digits
   115 				;	  followed by a period and then zero or more digits
   116 				;	- An optional exponent consisting of a E, an optional +/- sign,
   117 				;	  and one or two digits giving a non-zero number.
   118 				;
   119 				; Additional behaviors:
   120 				;	- No spaces after leading spaces are allowed.
   121 				;	- A single period with no digits around it is not valid.
   122 				;	- Numbers of magnitude 1E+98 or larger return an error.
   123 				;	- The smallest magnitude possible is 1E-98; 1E-99 underflows to 0.
   124 				;	- Only two exponent digits at most are parsed. For instance, 1E012
   125 				;	  is parsed as 1E01 with CIX pointing to the 2.
   126 				;	- Exponents of zero are not allowed. 1E+001 is parsed as just 1 with
   127 				;	  CIX pointing to the E.
   128 				;	- Only up to 9 significant digits are parsed even though 10 can sometimes
   129 				;	  fit. However, leading and trailing zeroes don't count for this.
   130 				;	  000000123456789100 is parsed as 123456789000.
   131 				;	- Denormalized scientific notation is allowed, e.g. 0.1E+04 and 100E6.
   132 				;	  AFP can accept either scientific or non-scientific notation for any
   133 				;	  valid number, and does not require usage according to FASC's rules.
   134 				;
   135 				; Bugs:
   136 				;	- The original math pack returns an invalid signed zero when parsing
   137 				;	  -0, which is not handled by other functions in the math pack. In
   138 				;	  particular, FASC will produce garbage on a signed zero. This is a bug
   139 				;	  since the specification in the Atari OS Manual specifically says that
   140 				;	  signed zero is never generated and the exponent byte can be tested for
   141 				;	  zero to detect zero. Callers have to detect and restore a standard zero
   142 				;	  in this case.
   143 				;
   144 D800				org		$d800
   145 = D800			_afp = afp
   146 D800			.proc afp
   147 = 00E6			dotflag = fr2
   148 = 00E7			xinvert = fr2+1
   149 = 00E8			cix0 = fr2+2
   150 = 00E9			sign = fr2+3
   151 = 00EA			digit2 = fr2+4
   152
   153 					;skip initial spaces
   154 D800 20 A1 DB			jsr		skpspc
   155
   156 					;init FR0 and one extra mantissa byte
   157 D803 A9 7F			lda		#$7f
   158 D805 85 D4			sta		fr0
   159 D807 85 EA			sta		digit2
   160 					
   161 D809 A2 D5			ldx		#fr0+1
   162 D80B 20 46 DA			jsr		zf1
   163
   164 					;clear decimal flag
   165 D80E 85 E6			sta		dotflag
   166 D810 85 E9			sta		sign
   167 					
   168 					;check for sign
   169 D812 A4 F2			ldy		cix
   170 D814 B1 F3			lda		(inbuff),y
   171 D816 C9 2B			cmp		#'+'
   172 D818 F0 06			beq		isplus
   173 D81A C9 2D			cmp		#'-'
   174 D81C D0 03			bne		postsign
   175 D81E 66 E9			ror		sign
   176 D820			isplus:
   177 D820 C8				iny
   178 D821			postsign:	
   179 D821 84 E8			sty		cix0
   180
   181 					;skip leading zeroes
   182 D823 A9 30			lda		#'0'
   183 D825 20 A5 DB			jsr		fp_skipchar
   184 					
   185 					;check if next char is a dot, indicating mantissa <1
   186 D828 B1 F3			lda		(inbuff),y
   187 D82A C9 2E			cmp		#'.'
   188 D82C D0 10			bne		not_tiny
   189 D82E C8				iny
   190 					
   191 					;set dot flag
   192 D82F 66 E6			ror		dotflag
   193
   194 					;increment anchor so we don't count the dot as a digit for purposes
   195 					;of seeing if we got any digits
   196 D831 E6 E8			inc		cix0
   197 					
   198 					;skip zeroes and adjust exponent
   199 D833 A9 30			lda		#'0'
   200 D835			tiny_denorm_loop:
   201 D835 D1 F3			cmp		(inbuff),y
   202 D837 D0 05			bne		tiny_denorm_loop_exit
   203 D839 C6 D4			dec		fr0
   204 D83B C8				iny
   205 D83C D0 F7			bne		tiny_denorm_loop
   206 D83E			tiny_denorm_loop_exit:
   207 					
   208 D83E			not_tiny:
   209
   210 					;grab digits left of decimal point
   211 D83E A2 01			ldx		#1
   212 D840			nextdigit:
   213 D840 B1 F3			lda		(inbuff),y
   214 D842 C9 45			cmp		#'E'
   215 D844 F0 55			beq		isexp
   216 D846 C8				iny
   217 D847 C9 2E			cmp		#'.'
   218 D849 F0 28			beq		isdot
   219 D84B 49 30			eor		#'0'
   220 D84D C9 0A			cmp		#10
   221 D84F B0 2A			bcs		termcheck
   222 					
   223 					;write digit if we haven't exceeded digit count
   224 D851 E0 06			cpx		#6
   225 D853 B0 15			bcs		afterwrite
   226 					
   227 D855 24 EA			bit		digit2
   228 D857 10 09			bpl		writehi
   229
   230 					;clear second digit flag
   231 D859 C6 EA			dec		digit2
   232 					
   233 					;merge in low digit
   234 D85B 15 D4			ora		fr0,x
   235 D85D 95 D4			sta		fr0,x
   236 					
   237 					;advance to next byte
   238 D85F E8				inx
   239 D860 D0 08			bne		afterwrite
   240 					
   241 D862			writehi:
   242 					;set second digit flag
   243 D862 E6 EA			inc		digit2
   244 					
   245 					;shift digit to high nibble and write
   246 D864 0A				asl
   247 D865 0A				asl
   248 D866 0A				asl
   249 D867 0A				asl
   250 D868 95 D4			sta		fr0,x
   251
   252 D86A			afterwrite:
   253 					;adjust digit exponent if we haven't seen a dot yet
   254 D86A 24 E6			bit		dotflag
   255 D86C 30 02 E6 D4			smi:inc	fr0
   256 					
   257 					;go back for more
   258 D870 4C 40 D8			jmp		nextdigit
   259 					
   260 D873			isdot:
   261 D873 A5 E6			lda		dotflag
   262 D875 D0 04			bne		termcheck
   263 					
   264 					;set the dot flag and loop back for more
   265 D877 66 E6			ror		dotflag
   266 D879 D0 C5			bne		nextdigit
   267
   268 D87B			termcheck:
   269 D87B 88				dey
   270 D87C C4 E8			cpy		cix0
   271 D87E F0 1A			beq		err_carryset
   272 D880			term:
   273 					;stash offset
   274 D880 84 F2			sty		cix
   275
   276 D882			term_rollback_exp:
   277 					;divide digit exponent by two and merge in sign
   278 D882 26 E9			rol		sign
   279 D884 66 D4			ror		fr0
   280 					
   281 					;check if we need a one digit shift
   282 D886 B0 0F			bcs		nodigitshift
   283
   284 					;shift right one digit
   285 D888 A2 04			ldx		#4
   286 D88A			digitshift:
   287 D88A 46 D5			lsr		fr0+1
   288 D88C 66 D6			ror		fr0+2
   289 D88E 66 D7			ror		fr0+3
   290 D890 66 D8			ror		fr0+4
   291 D892 66 D9			ror		fr0+5
   292 D894 CA				dex
   293 D895 D0 F3			bne		digitshift
   294
   295 D897			nodigitshift:
   296 D897 4C 00 DC			jmp		fp_normalize
   297
   298 D89A			err_carryset:
   299 D89A 60				rts
   300
   301 D89B			isexp:
   302 D89B C4 E8			cpy		cix0
   303 D89D F0 FB			beq		err_carryset
   304 					
   305 					;save off this point as a fallback in case we don't actually have
   306 					;exponential notation
   307 D89F 84 F2			sty		cix
   308
   309 					;check for sign
   310 D8A1 A2 00			ldx		#0
   311 D8A3 C8				iny
   312 D8A4 B1 F3			lda		(inbuff),y
   313 D8A6 C9 2B			cmp		#'+'
   314 D8A8 F0 05			beq		isexpplus
   315 D8AA C9 2D			cmp		#'-'
   316 D8AC D0 02			bne		postexpsign
   317 D8AE CA				dex						;x=$ff
   318 D8AF			isexpplus:
   319 D8AF C8				iny
   320 D8B0			postexpsign:
   321 D8B0 86 E7			stx		xinvert
   322
   323 					;pull up to two exponent digits -- check first digit
   324 D8B2 20 B1 DB			jsr		fp_isdigit_y
   325 D8B5 C8				iny
   326 D8B6 B0 CA			bcs		term_rollback_exp
   327 					
   328 					;stash first digit
   329 D8B8 AA				tax
   330 					
   331 					;check for another digit
   332 D8B9 20 B1 DB			jsr		fp_isdigit_y
   333 D8BC B0 05			bcs		notexpzero2
   334 D8BE C8				iny
   335
   336 D8BF 7D CC DA			adc		fp_mul10,x
   337 D8C2 AA				tax
   338 D8C3			notexpzero2:
   339 D8C3 8A				txa
   340 					
   341 					;zero is not a valid exponent
   342 D8C4 F0 BC			beq		term_rollback_exp
   343 					
   344 					;apply sign to exponent
   345 D8C6 45 E7			eor		xinvert
   346 D8C8 26 E7			rol		xinvert
   347
   348 					;bias digit exponent
   349 D8CA 65 D4			adc		fr0
   350 D8CC 85 D4			sta		fr0
   351 D8CE			expterm:
   352 D8CE 4C 80 D8			jmp		term
   353
   354 				.endp
   355
   356 				;==========================================================================
   357 D8D1			.proc fp_tab_lo_100				;$0A bytes
   358 D8D1 00 64 C8 2C 90 F4 + 		dta		$00, $64, $C8, $2C, $90, $F4, $58, $BC, $20, $84
   359 				.endp
