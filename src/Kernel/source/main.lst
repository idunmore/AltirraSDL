   429 				;----------------
   430 FB74			special_set_tab:
   431 FB74 20 88 FB			jsr		special_common_tab
   432 FB77 1D A3 02			ora		tabmap,x
   433 FB7A D0 08			bne		special_common_exit_tab
   434
   435 FB7C			special_clear_tab:
   436 FB7C 20 88 FB			jsr		special_common_tab
   437 FB7F 49 FF			eor		#$ff
   438 FB81 3D A3 02			and		tabmap,x
   439 FB84			special_common_exit_tab:
   440 FB84 9D A3 02			sta		tabmap,x
   441 FB87 60				rts
   442 					
   443 FB88			special_common_tab:
   444 FB88 20 AA FD			jsr		EditorGetLogicalColumn
   445 FB8B A8				tay
   446 FB8C 4C B9 FD			jmp		EditorSetupTabIndex	
   447
   448 				;--------------------------------------------------------------------------
   449 				; Tab behavior:
   450 				;	- Moves cursor to the next tab position within the logical line.
   451 				;	- If there are no more tabs, moves cursor to beginning of next line.
   452 				;	  This may cause a scroll.
   453 				;	- Tab does NOT adjust the read row.
   454 				;
   455 FB8F			special_tab:
   456 FB8F 20 AA FD			jsr		EditorGetLogicalColumn
   457 FB92 A8				tay
   458 FB93 8A				txa
   459 FB94 38				sec
   460 FB95 65 54			adc		rowcrs
   461 FB97 85 54			sta		rowcrs
   462 					
   463 					;scan forward until we find the next bit set, or we hit position 120
   464 FB99			tab_scan_loop:
   465 FB99 C8				iny
   466 FB9A C0 78			cpy		#120
   467 FB9C B0 08			bcs		tab_found
   468 FB9E 20 B9 FD			jsr		EditorSetupTabIndex
   469 FBA1 3D A3 02			and		tabmap,x
   470 FBA4 F0 F3			beq		tab_scan_loop
   471 FBA6			tab_found:
   472 FBA6 84 55			sty		colcrs
   473 FBA8			tab_adjust_row:
   474 FBA8 A5 55			lda		colcrs
   475 FBAA 38				sec
   476 FBAB E9 28			sbc		#40							;subtract a row worth of columns
   477 FBAD 90 19			bcc		tab_adjust_done				;exit if <40
   478 FBAF 85 55			sta		colcrs
   479 FBB1 E6 54			inc		rowcrs						;next row
   480 FBB3 A5 54			lda		rowcrs						;
   481 FBB5 CD BF 02			cmp		botscr						;check if we're below the screen
   482 FBB8 B0 07			bcs		tab_adjust_scroll			;if so, do a scroll
   483 FBBA 20 86 FD			jsr		EditorTestLogicalLineBit	;check if we're on a new log line
   484 FBBD F0 E9			beq		tab_adjust_row				;if not, keep adjusting
   485 FBBF 10 03			bpl		tab_adjust_left				;position at beginning of new line
   486 					
   487 FBC1			tab_adjust_scroll:
   488 FBC1 20 D4 FC			jsr		EditorDeleteLine0
   489 FBC4			tab_adjust_left:
   490 FBC4			hmove_to_lmargn:
   491 					;move to left margin	
   492 FBC4 A6 52			ldx		lmargn
   493 FBC6			hmove_to_x:
   494 FBC6 86 55			stx		colcrs
   495 FBC8			tab_adjust_done:
   496 FBC8 60				rts
   497
   498 				;--------------------------------------------------------------------------
   499 FBC9			special_left:
   500 FBC9 A6 52			ldx		lmargn
   501 FBCB E4 55			cpx		colcrs						;lmargn-colcrs >= 0
   502 FBCD B0 03			bcs		hmove_to_rmargn				;branch if colcrs <= lmargn
   503 FBCF C6 55			dec		colcrs
   504 FBD1 60				rts
   505
   506 FBD2			hmove_to_rmargn:
   507 					;move to right margin
   508 FBD2 A6 53			ldx		rmargn
   509 FBD4 B0 F0			bcs		hmove_to_x
   510
   511 				;--------------------------------------------------------------------------
   512 FBD6			special_right:
   513 FBD6 A6 55			ldx		colcrs
   514 FBD8 E4 53			cpx		rmargn
   515 FBDA B0 E8			bcs		hmove_to_lmargn
   516
   517 					;right one char
   518 FBDC E6 55			inc		colcrs
   519 FBDE 60				rts
   520
   521 				;--------------------------------------------------------------------------
   522 				; Delete line behavior:
   523 				;	- The entire logical line that the cursor is in is deleted.
   524 				;	- The cursor is positioned at the beginning of the next logical line.
   525 				;
   526 FBDF			special_delete_line:
   527 					;delete current logical line
   528 FBDF 20 8D FD			jsr		EditorGetCurLogicalRow
   529 FBE2 4C D6 FC			jmp		EditorDeleteLine
   530
   531 				;----------------
   532 FBE5			special_insert_line:
   533 					;insert a new logical line at this point; note that this may split
   534 					;the current line
   535 FBE5 38				sec
   536 FBE6 20 93 F8			jsr		ScreenInsertLine
   537 FBE9 4C C4 FB			jmp		tab_adjust_left
   538
   539 				;--------------------------------------------------------------------------
   540 				; Delete character behavior:
   541 				;	- Erases the current character and drags in characters from the
   542 				;	  remainder of the logical line, excluding the margins.
   543 				;	- If the last physical line is blank and not the only physical line in
   544 				;	  the logical line, it is deleted and the logical line is shortened.
   545 				;	  Only one line is removed even if the last two lines are blank. The
   546 				;	  cursor does not move when this happens and may be shifted into the
   547 				;	  next logical line. This also does not change the input line!
   548 				;
   549 FBEC			special_delete_char:
   550 					;compute base address of current row (not char)
   551 FBEC A4 54			ldy		rowcrs
   552 FBEE 84 51			sty		hold1
   553 FBF0 20 7E F9			jsr		ScreenComputeToAddrX0
   554 					
   555 					;begin shifting in the first column at the current pos
   556 FBF3 A4 55			ldy		colcrs
   557 					
   558 					;delete chars to end
   559 FBF5 4C 83 FC			jmp		delete_shift_loop_entry	
   560 					
   561 				;--------------------------------------------------------------------------
   562 				; Insert character behavior:
   563 				;	- Inserts a blank at the current position and shifts characters forward
   564 				;	  within the margins.
   565 				;	- If the character shifted out of the end of the logical line is non-
   566 				;	  blank, the logical line will be extended if possible. This can cause
   567 				;	  a scroll. If the logical line is already three rows, the last
   568 				;	  character is lost.
   569 				;
   570 FBF8			special_insert_char:
   571 					;get logical line start
   572 FBF8 20 8D FD			jsr		EditorGetCurLogicalRow
   573 					
   574 					;compute line at which we cannot add another physical line
   575 FBFB 18 69 03			add		#3
   576 FBFE 85 76			sta		deltar
   577 					
   578 					;compute address of row
   579 FC00 A4 54			ldy		rowcrs
   580 FC02 84 51			sty		hold1
   581 FC04 20 7E F9			jsr		ScreenComputeToAddrX0
   582 					
   583 FC07 A4 55			ldy		colcrs				;end shift at current column
   584 FC09 A2 00			ldx		#0					;insert blank character at start
   585 FC0B F0 04			beq		insert_line_loop_entry
   586 					
   587 FC0D			insert_line_loop:
   588 FC0D A4 52			ldy		lmargn				;end shift at left column
   589 FC0F A6 50			ldx		tmpchr				;character to shift in (from last line)
   590 					
   591 FC11			insert_line_loop_entry:
   592 FC11 84 65			sty		adress+1			;stash shift origin
   593 FC13 A4 53			ldy		rmargn				;begin shift at right column
   594 FC15 B1 66			lda		(toadr),y			;get character being shifted out
   595 FC17 85 50			sta		tmpchr				;save it off to later shift in on the next row
   596 FC19			insert_shift_loop:
   597 FC19 88				dey
   598 FC1A B1 66			lda		(toadr),y
   599 FC1C C8				iny
   600 FC1D 91 66			sta		(toadr),y
   601 FC1F 88				dey
   602 FC20 C4 65			cpy		adress+1
   603 FC22 D0 F5			bne		insert_shift_loop
   604
   605 					;put character shifted out from previous line into beginning of this one
   606 FC24 8A				txa
   607 FC25 91 66			sta		(toadr),y
   608 					
   609 					;next row
   610 FC27 E6 51			inc		hold1
   611 					
   612 FC29 20 C8 FD			jsr		EditorNextLineAddr
   613 					
   614 					;check if we're at the end of the logical line
   615 FC2C A5 51			lda		hold1
   616 FC2E CD BF 02			cmp		botscr
   617 FC31 B0 05			bcs		insert_crossed_lline
   618 FC33 20 86 FD			jsr		EditorTestLogicalLineBit
   619 FC36 F0 D5			beq		insert_line_loop
   620 FC38			insert_crossed_lline:
   621
   622 					;check if we shifted out a non-blank character
   623 FC38 A5 50			lda		tmpchr
   624 FC3A F0 2D			beq		insert_done
   625 						
   626 					;save current row
   627 FC3C A5 54			lda		rowcrs
   628 FC3E 48				pha
   629 					
   630 					;check if the logical line is already 3 rows -- if so, we cannot extend and
   631 					;the last char goes into the bit bucket, but we still must scroll (!)
   632 FC3F A6 51			ldx		hold1
   633 FC41 E4 76			cpx		deltar
   634 FC43 08				php
   635 					
   636 					;move to the bottom line +1; we use ROWCRS so it stays updated with the scrolling
   637 FC44 86 54			stx		rowcrs
   638 					
   639 					;check if we are at the bottom of the screen; if so we must scroll
   640 FC46 A9 00			lda		#0
   641 FC48 85 76			sta		deltar
   642
   643 FC4A EC BF 02			cpx		botscr
   644 FC4D 90 03			bcc		insert_no_scroll
   645 					
   646 					;scroll the screen
   647 FC4F 20 D4 FC			jsr		EditorDeleteLine0
   648 					
   649 FC52			insert_no_scroll:
   650 					;if we can't extend, we are done
   651 FC52 28				plp
   652 FC53 B0 0E			bcs		insert_cant_extend
   653 					
   654 					;just insert a blank line at the end of this logical row to extend it
   655 FC55 20 92 F8			jsr		ScreenInsertPhysLine
   656 						
   657 					;restore shifted character and put it in place
   658 FC58 A4 54			ldy		rowcrs
   659 FC5A 20 7E F9			jsr		ScreenComputeToAddrX0
   660 FC5D A5 50			lda		tmpchr
   661 FC5F A4 52			ldy		lmargn
   662 FC61 91 66			sta		(toadr),y
   663 FC63			insert_cant_extend:
   664
   665 					;restore cursor row, adjusting for any scroll
   666 FC63 68				pla
   667 FC64 38				sec
   668 FC65 E5 76			sbc		deltar
   669 FC67 85 54			sta		rowcrs
   670
   671 FC69			insert_done:
   672 FC69 60				rts
   673
   674 				;---------------------------------
   675 FC6A			dispatch:
   676 FC6A A9 FB			lda		#>special_escape
   677 FC6C 48				pha
   678 FC6D BD 11 FB			lda		special_dispatch_lo_tab,x
   679 FC70 48				pha
   680 FC71 60				rts
   681
   682 				;---------------------------------
   683 FC72			delete_line_loop:
   684 					;copy first character into right margin of previous row
   685 FC72 A4 52			ldy		lmargn
   686 FC74 B1 66			lda		(toadr),y
   687 FC76 A4 53			ldy		rmargn
   688 FC78 91 68			sta		(frmadr),y
   689 					
   690 					;start shifting new row at left margin
   691 FC7A A4 52			ldy		lmargn
   692 FC7C			delete_shift_loop:	
   693 FC7C C8				iny
   694 FC7D B1 66			lda		(toadr),y
   695 FC7F 88				dey
   696 FC80 91 66			sta		(toadr),y
   697 FC82 C8				iny
   698 FC83			delete_shift_loop_entry:
   699 FC83 C4 53			cpy		rmargn
   700 FC85 D0 F5			bne		delete_shift_loop
   701 					
   702 					;next line
   703 FC87 20 C8 FD			jsr		EditorNextLineAddr
   704 					
   705 					;check if the next row is a logical line start
   706 FC8A A6 51			ldx		hold1
   707 FC8C E8				inx
   708 FC8D EC BF 02			cpx		botscr
   709 FC90 B0 08			bcs		delete_stop_shifting
   710 FC92 86 51			stx		hold1
   711 FC94 8A				txa
   712 FC95 20 86 FD			jsr		EditorTestLogicalLineBit
   713 					
   714 					;keep going if not
   715 FC98 F0 D8			beq		delete_line_loop
   716 					
   717 FC9A			delete_stop_shifting:
   718 					;blank the last character of the last line
   719 FC9A A4 53			ldy		rmargn
   720 FC9C A9 00			lda		#0
   721 FC9E 91 68			sta		(frmadr),y
   722 					
   723 					;check if the last line is blank
   724 FCA0			delete_blank_test_loop:
   725 FCA0 C4 52			cpy		lmargn
   726 FCA2 F0 06			beq		delete_blank_exit_loop
   727 FCA4 88				dey
   728 FCA5 B1 68			lda		(frmadr),y
   729 FCA7 F0 F7			beq		delete_blank_test_loop
   730 					;re-show cursor and exit
   731 FCA9 60				rts
   732
   733 FCAA			delete_blank_exit_loop:	
   734 					;the last line is blank... check if it is a logical line start
   735 FCAA C6 51			dec		hold1
   736 FCAC A5 51			lda		hold1
   737 FCAE 20 86 FD			jsr		EditorTestLogicalLineBit
   738 					
   739 					;skip if so -- we can't delete the entire logical line
   740 FCB1 D0 0B			bne		delete_not_blank
   741 					
   742 					;delete this physical line... however, do not move the cursor and
   743 					;do not change the read line even if the cursor hops to a new one
   744 FCB3 A5 55			lda		colcrs
   745 FCB5 48				pha
   746 FCB6 A5 51			lda		hold1
   747 FCB8 20 D6 FC			jsr		EditorDeleteLine
   748 FCBB 68				pla
   749 FCBC 85 55			sta		colcrs
   750 					
   751 FCBE			delete_not_blank:
   752 					;re-show cursor and exit
   753 FCBE 60				rts
   754
   755 				.endp
   756
