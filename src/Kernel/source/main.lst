  1088 						;check if divisor is zero -- must be first as 0/0 is an error
  1089 DB28 A5 E0				lda		fr1
  1090 DB2A F0 6F				beq		err
  1091
  1092 						;check if dividend is zero
  1093 DB2C A6 D4				ldx		fr0
  1094 DB2E F0 69				beq		ok
  1095 					
  1096 						;compute new exponent
  1097 DB30 49 7F				eor		#$7f
  1098 DB32 20 00 DB				jsr		fp_adjust_exponent.fdiv_entry
  1099
  1100 DB35 20 44 DF				jsr		fp_fdiv_init
  1101 DB38 D0 0F				bne		digitloop_entry		;!! - unconditional
  1102
  1103 DB3A			digitloop:
  1104 						;shift dividend
