   848 DA60			.proc fsub
   849 						;toggle sign on FR1
   850 DA60 A5 E0				lda		fr1
   851 DA62 49 80				eor		#$80
   852 DA64 85 E0				sta		fr1
   853 					
   854 						;fall through to FADD
   855 DA66					ckaddr	$da66
Macro: CKADDR [Source: source/Shared/mathpack.s]
Source: source/Shared/mathpack.s
   856 = DA66			.def :fadd
   857 						;if fr1 is zero or negative zero, we're done. Call the normalization
   858 						;routine in case FR0 is negative zero.
   859 DA66 A5 E1				lda		fr1+1
   860 DA68 F0 15				beq		norm_fr0
   861 					
   862 						;if fr0 is zero, swap; we know fr1 can't be a signed zero
   863 DA6A A5 D5				lda		fr0+1
   864 DA6C F0 14				beq		return_fr1
   865
   866 DA6E			fr0_nonzero:
   867 						;compute difference in exponents, ignoring sign
   868 DA6E A5 E0				lda		fr1			;load fr1 sign
   869 DA70 45 D4				eor		fr0			;compute fr0 ^ fr1 signs
   870 DA72 29 80				and		#$80		;mask to just sign
   871 DA74 AA					tax					;store add/subtract flag
   872 DA75 45 E0				eor		fr1			;flip fr1 sign to match fr0
   873 DA77 18					clc
   874 DA78 E5 D4				sbc		fr0			;compute difference in exponents
   875 DA7A 90 09				bcc		noswap		;jump if FR1 exponent <= FR0 exponent
   876 					
   877 DA7C			swap:
   878 DA7C 4C 54 DC				jmp		fp_reverse_addsub
   879
   880 DA7F			norm_fr0:
   881 DA7F 4C 00 DC				jmp		fp_normalize
   882
   883 DA82			return_fr1:
   884 DA82 4C 49 DC				jmp		fp_rmove
   885
   886 DA85			noswap:	
   887 						;A = FR1 - FR0 - 1
   888 						;X = add/sub flag
   889
   890 						;compute positions for add/subtract	
   891 DA85 69 05				adc		#5			;A = (FR1) - (FR0) + 4   !! carry is clear coming in
   892 DA87 A8					tay
   893 					
   894 						;check if FR1 is too small in magnitude to matter
   895 DA88 30 32				bmi		sum_xit
   896 					
   897 						;jump to decimal mode and prepare for add/sub loops
   898 DA8A F8					sed
   899
   900 						;check if we are doing a sum or a difference
   901 DA8B E0 80				cpx		#$80
   902 DA8D A2 05				ldx		#5
   903 DA8F B0 2D				bcs		do_subtract
   904 							
   905 						;add mantissas
   906 DA91			add_loop:
   907 DA91 B9 E1 00				lda		fr1+1,y
   908 DA94 75 D4				adc		fr0,x
   909 DA96 95 D4				sta		fr0,x
   910 DA98 CA					dex
   911 DA99 88					dey
   912 DA9A 10 F5				bpl		add_loop
   913 DA9C 30 06				bmi		sum_carryloop_start
   914
   915 DA9E			sum_carryloop:
   916 DA9E B5 D5				lda		fr0+1,x
   917 DAA0 69 00				adc		#0
   918 DAA2 95 D5				sta		fr0+1,x
   919 DAA4			sum_carryloop_start:
   920 DAA4 90 16				bcc		sum_xit
   921 DAA6 CA					dex
   922 DAA7 10 F5				bpl		sum_carryloop
   923
   924 DAA9			sum_finalize:
   925 						;adjust exponent
   926 DAA9 E6 D4				inc		fr0
   927
   928 						;shift down FR0
   929 DAAB A2 04				ldx		#4
   930 DAAD			sum_shiftloop:
   931 DAAD B5 D4				lda		fr0,x
   932 DAAF 95 D5				sta		fr0+1,x
   933 DAB1 CA					dex
   934 DAB2 D0 F9				bne		sum_shiftloop
   935 					
   936 						;add a $01 at the top
   937 DAB4 E8					inx
   938 DAB5 86 D5				stx		fr0+1
   939
   940 						;turn off decimal mode
   941
   942 						;signal overflow if we hit 1E+98 or higher in magnitude
   943 DAB7 A5 D4				lda		fr0
   944 DAB9 0A					asl
   945 DABA C9 E2				cmp		#(64+49)*2
   946 DABC			sum_xit:
   947 DABC D8					cld
   948 DABD 60					rts
   949 					
   950 DABE			do_subtract:
   951 						;subtract FR0 and FR1 mantissas (!! carry is set coming in)
   952 DABE			sub_loop:
   953 DABE B5 D4				lda		fr0,x
   954 DAC0 F9 E1 00				sbc		fr1+1,y
   955 DAC3 95 D4				sta		fr0,x
   956 DAC5 CA					dex
   957 DAC6 88					dey
   958 DAC7 10 F5				bpl		sub_loop
   959 DAC9 4C 30 DC				jmp		fp_fsub_cont.entry
   960 				.endp
