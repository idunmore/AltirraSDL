  1025 DAFB			.proc fp_adjust_exponent
  1026 DAFB			underflow_overflow:
  1027 DAFB 68				pla
  1028 DAFC 68				pla
  1029 = DAFD			.def :fp_exit_zero
  1030 DAFD 4C 44 DA			jmp		zfr0
  1031
  1032 DB00			fdiv_entry:
  1033 DB00 38				sec
  1034 DB01			fmul_entry:
  1035 					;stash modified exp1
  1036 DB01 AA				tax
  1037 					
  1038 					;compute new sign
  1039 DB02 45 D4			eor		fr0
  1040 DB04 29 80			and		#$80
  1041 DB06 85 E0			sta		fr1
  1042 					
  1043 					;merge exponents
  1044 DB08 8A				txa
  1045 DB09 65 D4			adc		fr0
  1046 DB0B AA				tax
  1047 DB0C 45 E0			eor		fr1
  1048 					
  1049 					;check for underflow/overflow
  1050 DB0E C9 4F			cmp		#128-49
  1051 DB10 90 E9			bcc		underflow_overflow
  1052 					
  1053 DB12 C9 B1			cmp		#128+49
  1054 DB14 B0 E5			bcs		underflow_overflow
  1055 					
  1056 					;rebias exponent
  1057 DB16 8A				txa
  1058 DB17 E9 3F			sbc		#$40-1		;!! - C=0 from bcs fail
  1059 DB19 85 D4			sta		fr0
  1060 = DB1B			.def :fp_exit
  1061 DB1B 60				rts
  1062 				.endp
