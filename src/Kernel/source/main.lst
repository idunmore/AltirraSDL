   239 				;==========================================================================
   240 				;==========================================================================
   241
   242 					;Many compilation disks rely on ScreenOpen being at $F3F6.
   243 					
   244 				.if *>$f3f6-8
   245 					.error	'ROM overflow into Screen Handler region: ',*,' > $F3EE.'
   246 				.endif
   247
   248 				.ifdef _KERNEL_REPORT_MODULE_PAD_ADJUST
   249 F2E1				_KERNEL_REPORT_MODULE_PAD_ADJUST [$f3f6-8]-*
Macro: _KERNEL_REPORT_MODULE_PAD_ADJUST [Source: source/main.xasm]
     1 = F360				.def ?@_kernel_lastpt = ?@_kernel_lastpt + [$F3F6-8]-*
Source: source/Shared/screen.s
   250 				.endif
   251
   252 F2E1				org		$f3f6-8
   253
   254 				;==========================================================================
   255 				;==========================================================================
   256
   257 				;==========================================================================
   258 				;
   259 				; Return:
   260 				;	MEMTOP = first byte used by display
   261 				;
   262 				; Errors:
   263 				;	- If there is not enough memory (MEMTOP > APPMHI), GR.0 is reopened
   264 				;	  automatically and an error is returned.
   265 				;
   266 				; Notes:
   267 				;	- Resets character base (CHBAS).
   268 				;	- Resets character attributes (CHACT).
   269 				;	- Resets playfield colors (COLOR0-COLOR4).
   270 				;	- Resets tab map, even if the mode does not have a text window.
   271 				;	- Resets logical line map, even if the mode does not have a text window.
   272 				;	- Does NOT reset P/M colors (PCOLR0-PCOLR3).
   273 				;	- Does NOT reset margins (LMARGN/RMARGN).
   274 				;	- Sets up fine scrolling if FINE bit 7 is set. Note that this is
   275 				;	  different than the scroll logic itself, which tests the whole byte.
   276 				;	- Returns error $80 if BREAK has been pressed.
   277 				;	- If clear is bypassed, ROWCRS and COLCRS are preserved.
   278 				;
   279 				; Modified:
   280 				;	- FRMADR: used for bitflags
   281 				;		bit 7 = skip clear
   282 				;		bit 6 = split screen
   283 				;		bit 0 = fine scrolling (XL/XE only)
   284 				;	- ADRESS: temporary addressing
   285 				;
   286 = F3F6			ScreenOpen = ScreenOpenGr0.use_iocb
   287 = F3F2			ScreenOpenMode0 = ScreenOpenGr0.use_mode0
   288 F3EE			.proc	ScreenOpenGr0
   289 F3EE A9 0C 85 2A			mva		#12 icax1z
   290 F3F2			use_mode0:
   291 F3F2 A9 00 85 2B			mva		#0 icax2z
   292 F3F6			use_iocb:
   293 					;shut off ANTIC playfield and instruction DMA
   294 F3F6 AD 2F 02			lda		sdmctl
   295 F3F9 29 DC			and		#$dc
   296 F3FB 8D 2F 02			sta		sdmctl
   297 F3FE 8D 00 D4			sta		dmactl
   298 					
   299 					;reset cursor parameters
   300 F401 A2 0B			ldx		#11
   301 F403 A9 00			lda		#0
   302 F405			clear_parms:
   303 F405 95 54			sta		rowcrs,x
   304 F407 9D 90 02			sta		txtrow,x
   305 F40A CA				dex
   306 F40B D0 F8			bne		clear_parms
   307
   308 					;mark us as being in main screen context
   309 F40D 86 7B			stx		swpflg	
   310 					
   311 					;copy mode value to dindex
   312 F40F A5 2B			lda		icax2z
   313 F411 29 0F			and		#15
   314 F413 85 57			sta		dindex
   315 F415 AA				tax
   316 					
   317 					;poke PRIOR value (saves us some time to do it now)
   318 					;note that we must preserve bits 0-5 of GPRIOR or else Wayout shows logo artifacts
   319 F416 BD 89 F2			lda		ScreenModeTable,x
   320 F419 4D 6F 02			eor		gprior
   321 F41C 29 C0			and		#$c0
   322 F41E 4D 6F 02			eor		gprior
   323 F421 8D 6F 02			sta		gprior
   324 					
   325 					;if a GTIA mode is active, force off split mode
   326 					;if we're in mode 0, force off the no-clear flag (per OS Manual p.57)
   327 F424 C9 40			cmp		#$40		;test for GTIA mode and store in carry
   328 F426 8A				txa					;test for GR.0
   329 F427 F0 06			beq		is_gr0		;disable split screen and no-clear for GR.0
   330
   331 F429 A5 2A			lda		icax1z
   332 F42B 90 02 29 EF			scc:and	#$ef		;disable split screen for GTIA mode
   333 F42F			is_gr0:
   334
   335 					;save off the split screen and clear flags in a more convenient form
   336 F42F 0A				asl
   337 F430 0A				asl
   338 F431 85 68			sta		frmadr
   339 					
   340 					;compute number of mode lines that we're going to have and save it off
   341 F433 BC 99 F2			ldy		ScreenHeightShifts,x
   342 F436 BE A9 F2			ldx		ScreenHeights,y
   343 F439 0A				asl
   344 F43A 10 03 BE BE F2		spl:ldx	ScreenHeightsSplit,y
   345 F43F 86 69			stx		frmadr+1
   346
   347 					;attempt to allocate playfield memory
   348 F441 A5 6A			lda		ramtop
   349 F443 A6 57			ldx		dindex
   350 F445 18				clc
   351 F446 7D 79 F2			adc		ScreenPlayfieldSizesHi,x
   352 F449 B0 09			bcs		pf_alloc_ok
   353
   354 F44B			alloc_fail:
   355 					;we ran out of memory -- attempt to reopen with gr.0 if we aren't
   356 					;already (to prevent recursion), and exit with an error
   357 F44B 8A				txa
   358 F44C F0 03			beq		cant_reopen_gr0
   359 					
   360 F44E 20 EE F3			jsr		ScreenOpenGr0	
   361 F451			cant_reopen_gr0:
   362 F451 A0 93			ldy		#CIOStatOutOfMemory
   363 F453 60				rts
   364 					
   365 F454			pf_alloc_ok:
   366 F454 85 59			sta		savmsc+1
   367 F456 BC 69 F2			ldy		ScreenPlayfieldSizesLo,x
   368 F459 84 58			sty		savmsc
   369
   370 					;Gr. modes 7 and 14 consume enough space for the playfield that there
   371 					;is not enough space left between the playfield and the next 1K
   372 					;boundary to contain the display list. In these cases, we preallocate
   373 					;to the 1K boundary to prevent a DL crossing error. Gr.8-11 and 15
   374 					;do this too -- I have no idea why, as it's not like the OS correctly
   375 					;handles moving the 4K page split for those modes if RAMTOP is
   376 					;misaligned.
   377 F45B BD 89 F2			lda		ScreenModeTable,x
   378 F45E A6 59			ldx		savmsc+1
   379 F460 29 30			and		#$30
   380 F462 F0 03			beq		no_dlist_page_crossing
   381 F464 A0 00			ldy		#0
   382 F466 CA				dex
   383 F467			no_dlist_page_crossing:
   384 F467 84 70			sty		rowac
   385 F469 8E E6 02			stx		memtop+1
   386 F46C 86 71			stx		rowac+1
   387 F46E 8E 31 02			stx		sdlsth
   388 						
   389 					;Compute display list size.
   390 					;
   391 					; We need:
   392 					;	- 8 fixed bytes (24 blank lines, LMS address, JVB)
   393 					;	- N bytes for mode lines
   394 					;	- 2 bytes for LMS split address (ANTIC modes E-F only)
   395 					;	- 6 bytes for split
   396 					;
   397 					;Note that the display list never crosses a page boundary. This is
   398 					;conservative, as the display list only can't cross 1K boundaries.
   399 					
   400 F471 C9 20			cmp		#$20				;test 4K hop bit (bit 5)
   401 F473 A9 F8			lda		#$f8				;start with -8 (if carry is clear after test)
   402 F475 90 02 A9 F5			scc:lda	#$f5				;use -11 if so (carry is set)
   403 F479 E5 69			sbc		frmadr+1			;subtract mode line count
   404 F47B 24 68			bit		frmadr
   405 F47D 50 02 E9 06			svc:sbc	#6					;subtract 6 bytes for a split
   406 					
   407 				.if _KERNEL_XLXE
   408 F481 A0 01			ldy		#1
   409 F483 CC 6E 02			cpy		fine				;clear carry to alloc +1 byte if fine scrolling is enabled
   410 				.endif
   411
   412 F486 65 70			adc		rowac				;allocate dl bytes (note that carry is set!)
   413 F488 8D E5 02			sta		memtop
   414 F48B 85 70			sta		rowac
   415 F48D 8D 30 02			sta		sdlstl
   416 					
   417 					;check if we're below APPMHI
   418 F490 E4 0F			cpx		appmhi+1
   419 F492 90 B7			bcc		alloc_fail
   420 F494 D0 04			bne		alloc_ok
   421 F496 C5 0E			cmp		appmhi
   422 F498 90 B1			bcc		alloc_fail
   423 					
   424 F49A			alloc_ok:
   425 					;MEMTOP is -1 from first used byte; we cheat here with the knowledge that
   426 					;the low byte of MEMTOP is never $00
   427 F49A CE E5 02			dec		memtop
   428
   429 					;set up text window address (-160 from top)
   430 F49D A6 6A			ldx		ramtop
   431 F49F CA				dex
   432 F4A0 8E 95 02			stx		txtmsc+1
   433 F4A3 A9 60 8D 94 02		mva		#$60 txtmsc
   434
   435 					;Turn on keyboard and break interrupts; note that this is done both for S:
   436 					;and E: opens. Close does not do this.
   437 F4A8 08				php
   438 F4A9 78				sei
   439 F4AA 0A				asl							;!! - A = $C0
   440 F4AB 05 10			ora		pokmsk
   441 F4AD 85 10			sta		pokmsk
   442 F4AF 8D 0E D2			sta		irqen
   443 F4B2 28				plp
   444
   445 					;Set row count: 24 for full-screen. We will fix up the split case to 4 later
   446 					;while we are writing the display list. Mapping the Atari incorrectly states
   447 					;that this value is set to 0 when no text window is present; this is wrong
   448 					;and in fact BAYPILOT.BAS relies on this being set to 24 for a GR.7+16
   449 					;screen since it later aliases it to GR.0.
   450 F4B3 A0 18			ldy		#24
   451 F4B5 8C BF 02			sty		botscr
   452
   453 					;init colors -- note that we do NOT overwrite pcolr0-3!
   454 F4B8 A0 05			ldy		#5
   455 F4BA B9 BA F5 99 C3 02 + 	mva:rne	standard_colors-1,y color0-1,y-
   456
   457 F4C3 8C F0 02			sty		crsinh				;!! - Y=0 for this and for write index
   458 					
   459 					;add 24 blank lines
   460 F4C6 A9 70			lda		#$70
   461 F4C8 A2 03			ldx		#3
   462 F4CA 20 84 F5			jsr		write_repeat
   463
   464 					;override COLOR4 (background) to $06 for GR.11 so it isn't dark
   465 F4CD A5 57			lda		dindex
   466 F4CF C9 0B			cmp		#11
   467 F4D1 D0 05			bne		not_gr11
   468 F4D3 A9 06			lda		#$06
   469 F4D5 8D C8 02			sta		color4
   470 F4D8			not_gr11:
   471 					
   472 					;add in the main screen
   473 F4D8 20 3A F5			jsr		setup_display
   474 					
   475 					;save off the DL ptr
   476 F4DB 84 7E			sty		countr
   477 					
   478 					;clear it if necessary
   479 F4DD 20 B4 F5			jsr		try_clear
   480 					
   481 					;check if we are doing a split
   482 F4E0 24 68			bit		frmadr
   483 F4E2 50 12			bvc		nosplit
   484
   485 					;change text screen height to four lines
   486 F4E4 A2 04			ldx		#4
   487 F4E6 8E BF 02			stx		botscr
   488
   489 					;swap to the text screen
   490 F4E9 20 46 F9			jsr		EditorSwapToText
   491 					
   492 					;add text screen dlist
   493 F4EC A4 7E			ldy		countr
   494 F4EE 20 3A F5			jsr		setup_display
   495 F4F1 84 7E			sty		countr
   496 						
   497 					;clear the split screen
   498 F4F3 20 B4 F5			jsr		try_clear
   499
   500 F4F6			nosplit:
   501 F4F6 A9 02 8D F3 02		mva		#2		chact
   502
   503 					;init tab map to every 8 columns
   504 F4FB A2 0F			ldx		#15
   505 F4FD 4A				lsr								;!! A=1
   506 F4FE 9D A2 02 CA D0 FA		sta:rne	tabmap-1,x-
   507
   508 					;reset line status
   509 F504 86 6B			stx		bufcnt
   510 					
   511 					;init character set
   512 F506 A2 E0 8E F4 02		mvx		#$e0	chbas			;!! - also used for NMIEN
   513
   514 					;enable VBI; note that we have not yet enabled display DMA
   515 				.if _KERNEL_XLXE
   516 F50B 24 68			bit		frmadr
   517 F50D D0 02 A2 40			sne:ldx	#$40
   518 				.else
   519 					ldx		#$40
   520 				.endif
   521 F511 8E 0E D4			stx		nmien
   522 					
   523 					;terminate display list with jvb
   524 F514 A4 7E			ldy		countr
   525 F516 A2 70			ldx		#rowac
   526 F518 A9 41			lda		#$41
   527 F51A 20 A6 F5			jsr		write_with_zp_address
   528 					
   529 					;init display list and playfield dma
   530 F51D AD 2F 02			lda		sdmctl
   531 F520 09 22			ora		#$22
   532 F522 8D 2F 02			sta		sdmctl
   533 					
   534 					;wait for screen to establish (necessary for Timewise splash screen to render)
   535 F525 A5 14			lda		rtclok+2
   536 F527 C5 14 F0 FC			cmp:req	rtclok+2
   537
   538 					;If we're in screen mode 0, show the cursor; otherwise, skip it and wait for
   539 					;E: to do so. We need to skip this even if a split screen is present, or else
   540 					;ACTris 2.1 displays a bogus cursor. Unfortunately we may have swapped to the
   541 					;split screen, so the mode we need may be in either DINDEX or TINDEX; it's
   542 					;easier for us just to re-check AUX2 bits 0-3.
   543 F52B A5 2B			lda		icax2z
   544 F52D 29 0F			and		#$0f
   545 F52F D0 03			bne		no_cursor
   546
   547 					;show cursor
   548 F531 20 BA F6			jsr		ScreenPutByte.recompute_show_cursor_exit
   549 F534			no_cursor:
   550 					;swap back to main context
   551 F534 20 9F FD			jsr		EditorSwapToScreen_Y1
   552 					
   553 					;exit
   554 F537 A2 00			ldx		#0				;required by Qix (v3)
   555 F539 60				rts
   556 					
   557 					
   558 				;--------------------------------------------------------
   559 F53A			setup_display:
   560 					;Add initial mode line with LMS, and check if we need to do an LMS
   561 					;split (playfield exceeds 4K). As it turns out, this only happens if
   562 					;we're using ANTIC mode E or F.
   563 F53A A6 57			ldx		dindex
   564 F53C BD 89 F2			lda		ScreenModeTable,x
   565 F53F 29 0F			and		#$0f
   566
   567 				.if _KERNEL_XLXE
   568 					;check if we are doing fine scrolling and set the vscrol bit if so
   569 F541 A6 57			ldx		dindex
   570 F543 D0 07			bne		nofine
   571 F545 AE 6E 02			ldx		fine
   572 F548 F0 02			beq		nofine
   573 F54A 09 20			ora		#$20
   574 F54C			nofine:
   575 				.endif
   576
   577 F54C 48				pha
   578 F54D 09 40			ora		#$40
   579 F54F A2 58			ldx		#savmsc
   580 F551 20 A6 F5			jsr		write_with_zp_address
   581
   582 					;retrieve row count
   583 F554 A6 69			ldx		frmadr+1
   584 F556 A5 57			lda		dindex
   585 F558 D0 03 AE BF 02		sne:ldx	botscr
   586 					
   587 					;dec row count since we already did the LMS
   588 F55D CA				dex
   589 F55E 68				pla
   590 					
   591 				.if _KERNEL_XLXE
   592 					;subtract two rows if we are fine scrolling, as we need to do DLI
   593 					;and non-vscrolled row
   594 F55F C9 22			cmp		#$22
   595 F561 F0 28			beq		dofine
   596 				.endif
   597 					
   598 					;check if this is a split mode
   599 F563 C9 0E			cmp		#$0e
   600 F565 90 1D			bcc		no_lms_split
   601 					
   602 					;yes it is -- write 93 lines
   603 F567 A2 5D			ldx		#93
   604 F569 20 84 F5			jsr		write_repeat
   605 					
   606 					;write LMS to jump over 4K boundary
   607 F56C 48				pha
   608 F56D 09 40			ora		#$40
   609 F56F 91 70 C8			sta		(rowac),y+
   610 F572 A9 00			lda		#0
   611 F574 91 70 C8			sta		(rowac),y+
   612 F577 A5 59			lda		savmsc+1
   613 F579 69 0E			adc		#$0f-1				;!! - C=1 from bcc above
   614 F57B 91 70 C8			sta		(rowac),y+
   615 					
   616 					;set up to write 95 fewer lines (note that carry is cleared)
   617 F57E A5 69			lda		frmadr+1
   618 F580 E9 5E			sbc		#94
   619 F582 AA				tax
   620 F583 68				pla
   621 					
   622 					;write mode lines and return
   623 F584			no_lms_split:
   624 F584			write_repeat:
   625 F584 91 70 C8			sta		(rowac),y+
   626 F587 CA				dex
   627 F588 D0 FA			bne		write_repeat
   628 F58A			no_clear:
   629 F58A 60				rts
   630
   631 				.if _KERNEL_XLXE
   632 F58B			dofine:
   633 					;write the regular lines (22 or 2)
   634 F58B CA				dex
   635 F58C 20 84 F5			jsr		write_repeat
   636
   637 					;write DLI line
   638 F58F 09 80			ora		#$80
   639 F591 91 70 C8			sta		(rowac),y+
   640 					
   641 					;write non-scrolled line
   642 F594 29 5F			and		#$5f
   643 F596 91 70 C8			sta		(rowac),y+
   644 					
   645 					;indicate to mainline that DLIs should be turned on
   646 F599 E6 68			inc		frmadr
   647 					
   648 					;set up DLI routine
   649 F59B A2 E1			ldx		#<ScreenFineScrollDLI
   650 F59D A9 FD			lda		#>ScreenFineScrollDLI
   651 F59F			write_vdslst:
   652 F59F 8E 00 02			stx		vdslst
   653 F5A2 8D 01 02			sta		vdslst+1
   654 F5A5 60				rts
   655 				.endif
   656
   657 				;--------------------------------------------------------
   658 F5A6			write_with_zp_address:
   659 F5A6 91 70 C8			sta		(rowac),y+
   660 F5A9 B5 00			lda		0,x
   661 F5AB 91 70 C8			sta		(rowac),y+
   662 F5AE B5 01			lda		1,x
   663 F5B0 A2 01			ldx		#1
   664 F5B2 D0 D0			bne		write_repeat		;!! - unconditional
   665 					
   666 F5B4			try_clear:
   667 F5B4 24 68			bit		frmadr
   668 F5B6 30 D2			bmi		no_clear
   669 F5B8 4C 4F F8			jmp		ScreenClear
   670 					
   671 				;--------------------------------------------------------
   672 F5BB			standard_colors:
   673 F5BB 28				dta		$28
   674 F5BC CA				dta		$ca
   675 F5BD 94				dta		$94
   676 F5BE 46				dta		$46
   677 = F5BF			.def :ScreenBitposFlipTab
   678 F5BF 00				dta		$00			;!! - shared value between tables
   679 F5C0 01				dta		$01
   680 F5C1 03				dta		$03
   681 F5C2 07				dta		$07
   682
   683 				.endp
   684
   685 				;==========================================================================
   686 F5C3			.proc	ScreenInit
   687 F5C3 AD E6 02 85 6A		mva		memtop+1 ramtop
   688 					
   689 					.ifdef _KERNEL_816
   690 					stz		colrsh
   691 					.else
   692 F5C8 A9 00 85 4F			mva		#0	colrsh
   693 					.endif
   694
   695 F5CC A9 FE 85 4E			mva		#$FE	drkmsk
   696 F5D0 60				rts
   697 				.endp
   698
   699 				;==========================================================================
   700 				; Behavior in gr.0:
   701 				;	- Reading char advances to next position, but cursor is not moved
   702 				;	- Cursor is picked up ($A0)
   703 				;	- Wrapping from end goes to left margin on next row
   704 				;	- Cursor may be outside of horizontal margins
   705 				;	- Error 141 (cursor out of range) if out of range
   706 				;	- Cursor will wrap to out of range if at end of screen (no automatic
   707 				;	  vertical wrap)
   708 				;	- Does NOT update OLDROW/OLDCOL
   709 				;
   710 				; Behavior in all modes:
   711 				;	- DOES update OLDADR
   712 				;
   713 				; Dependencies:
   714 				;	- Darg relies on a Get Byte changing OLDADR so the next Put Byte
   715 				;	  doesn't overwrite the last location when restoring the cursor.
   716 				;
   717 F5D1			.proc ScreenGetByte
   718 F5D1 20 FF F8			jsr		ScreenCheckPosition
   719 F5D4 30 40			bmi		xit
   720 					
   721 					;compute addressing
   722 F5D6 A5 55			lda		colcrs
   723 F5D8 A6 57			ldx		dindex
   724 F5DA BC C9 F2			ldy		ScreenEncodingTab,x
   725 F5DD 59 BF F5			eor		ScreenBitposFlipTab,y
   726 F5E0 AA				tax
   727 F5E1 A5 56			lda		colcrs+1
   728 F5E3 20 C6 F9			jsr		ScreenSetupPixelAddr.phase2
   729 F5E6 86 68			stx		frmadr
   730 F5E8 A4 54			ldy		rowcrs
   731 F5EA A6 6F			ldx		shfamt
   732 F5EC 20 CC FC			jsr		ScreenComputeAddrToOldAdr
   733 					
   734 					;retrieve byte containing pixel
   735 F5EF A0 00			ldy		#0
   736 F5F1 B1 5E			lda		(oldadr),y
   737 					
   738 					;shift down
   739 F5F3 A6 68			ldx		frmadr
   740 F5F5 20 B3 F9			jsr		ScreenAlignPixel
   741
   742 					;convert from Internal to ATASCII - must be done before we mask
   743 					;Internal	ATASCII
   744 					;00-1F		20-3F
   745 					;20-3F		40-5F
   746 					;40-5F		00-1F
   747 					;60-7F		60-7F
   748 F5F8 0A				asl
   749 F5F9 08				php
   750 F5FA 10 02 49 40			spl:eor	#$40		;00>20, 20>40, 40>60, 60>40
   751 F5FE 69 40			adc		#$40		;00>20, 20>40, 40>00, 60>60
   752 F600 28				plp
   753 F601 6A				ror
   754
   755 					;mask using right-justified pixel mask for mode
   756 F602 A6 57			ldx		dindex
   757 F604 BC C9 F2			ldy		ScreenEncodingTab,x
   758 F607 39 D9 F2			and		ScreenPixelMasks,y
   759 					
   760 					;advance to next position
   761 F60A A6 57			ldx		dindex
   762 F60C F0 03			beq		mode0
   763 F60E 4C DE F9			jmp		ScreenAdvancePosNonMode0
   764 F611			mode0:
   765 F611 20 0B FE			jsr		ScreenAdvancePosMode0
   766 F614 A0 01			ldy		#1
   767 F616			xit:
   768 F616 60				rts
   769 				.endp
   770
   771 				;==========================================================================
   772 				; Common behavior:
   773 				;	- Output is suspended if SSFLAG is set for non-clear and non-EOL chars
   774 				;	- Clear screen ($7D) and EOL ($9B) are always handled
   775 				;	- ESCFLG and DSPFLG are ignored (they are E: features)
   776 				;
   777 				; Behavior in gr.0:
   778 				;	- Logical lines are extended
   779 				;	- Scrolling occurs if bottom is hit
   780 				;	- Control chars other than clear and EOL are NOT handled by S:
   781 				;	- ROWCRS or COLCRS out of range results in an error.
   782 				;	- COLCRS in left margin is ignored and prints within margin.
   783 				;	- COLCRS in right margin prints one char and then does EOL.
   784 				;	- Previous cursor is not erased by S:, regardless of CRSINH state
   785 				;	- New cursor is drawn if CRSINH=0
   786 				;
   787 				; Behavior in gr.1+:
   788 				;	- No cursor is displayed
   789 				;	- LMARGN/RMARGN are ignored
   790 				;	- Cursor wraps from right side to next line
   791 				;	- ROWCRS may be below split screen boundary as long as it is within the
   792 				;	  full screen size.
   793 				;
   794 F617			.proc ScreenPutByte
   795 F617 8D FB 02			sta		atachr
   796 F61A 20 FF F8			jsr		ScreenCheckPosition
   797 F61D 30 0C			bmi		error
   798
   799 					;check for screen clear
   800 F61F AD FB 02			lda		atachr
   801 F622 C9 7D			cmp		#$7d
   802 F624 D0 0E			bne		not_clear_2
   803 F626 20 4F F8			jsr		ScreenClear
   804 F629 A0 01			ldy		#1
   805 F62B			error:
   806 F62B 60				rts
   807 					
   808 F62C			graphics_eol:
   809 F62C 4C F7 F9			jmp		ScreenAdvancePosNonMode0.graphics_eol
   810
   811 					;*** ENTRY POINT FROM EDITOR FOR ESC HANDLING ***
   812 F62F			not_clear:
   813 F62F 20 FF F8			jsr		ScreenCheckPosition
   814 F632 30 F7			bmi		error
   815 					
   816 F634			not_clear_2:	
   817 					;set old position now (used by setup code for plot pixel)
   818 F634 20 01 FE			jsr		ScreenSetLastPosition
   819 					
   820 					;restore char
   821 F637 AD FB 02			lda		atachr
   822 					
   823 					;check if we're in gr.0
   824 F63A A6 57			ldx		dindex
   825 F63C F0 1E			beq		mode_0
   826 					
   827 					;nope, we're in a graphics mode... that makes this easier.
   828 					;check if it's an EOL
   829 F63E C9 9B			cmp		#$9b
   830 F640 F0 EA			beq		graphics_eol
   831 					
   832 					;check for display suspend (ctrl+1) and wait until it is cleared
   833 F642 AE FF 02 D0 FB		ldx:rne	ssflag
   834 					
   835 					;fold the pixel, compute masks, and convert ATASCII to Internal
   836 F647 20 D3 F6			jsr		ScreenFoldColor
   837 F64A 48				pha
   838
   839 					;compute addressing and shift mask
   840 F64B 20 AE F9			jsr		ScreenSetupPlotPixel
   841 					
   842 F64E 68				pla
   843 F64F A4 6F			ldy		shfamt
   844 F651 51 66			eor		(toadr),y
   845 F653 25 6E			and		bitmsk
   846 F655 51 66			eor		(toadr),y
   847 F657 91 66			sta		(toadr),y
   848
   849 					;advance cursor position and exit
   850 F659 4C DE F9			jmp		ScreenAdvancePosNonMode0
   851 					
   852 F65C			mode_0:
   853 					;check for EOL, which bypasses the ESC check
   854 F65C C9 9B			cmp		#$9b
   855 F65E D0 18			bne		not_eol
   856 					
   857 					;it's an EOL
   858 F660 A5 52			lda		lmargn
   859 F662 85 55			sta		colcrs
   860 F664 E6 54			inc		rowcrs
   861 F666 A5 54			lda		rowcrs
   862 F668 CD BF 02			cmp		botscr
   863 F66B 90 08			bcc		noywrap
   864 					
   865 					;We've gone over -- delete logical line 0 to make room.
   866 					;Note that we need to set ROWCRS here first because the scroll may
   867 					;delete more than one physical line.
   868 F66D AE BF 02			ldx		botscr
   869 F670 86 54			stx		rowcrs
   870 					
   871 F672 20 D4 FC			jsr		EditorDeleteLine0
   872 F675			noywrap:
   873 F675 4C BA F6			jmp		recompute_show_cursor_exit
   874
   875 F678			not_eol:
   876 					;check for display suspend (ctrl+1) and wait until it is cleared
   877 F678 AE FF 02 D0 FB		ldx:rne	ssflag
   878 					
   879 F67D 48				pha
   880 F67E 20 C8 FC			jsr		EditorRecomputeCursorAddr
   881 F681 68				pla
   882 F682 20 F0 F6			jsr		ScreenConvertATASCIIToInternal
   883 					
   884 					;plot character
   885 F685 A0 00			ldy		#0
   886 F687 91 5E			sta		(oldadr),y
   887 					
   888 					;inc pos
   889 F689 E6 5E D0 02 E6 5F		inw		oldadr
   890 F68F 20 0B FE			jsr		ScreenAdvancePosMode0
   891 					
   892 					;check if we've gone beyond the right margin
   893 F692 B0 29			bcs		nowrap
   894 					
   895 					;check if we're beyond the bottom of the screen
   896 F694 A5 54			lda		rowcrs
   897 F696 CD BF 02			cmp		botscr
   898 F699 90 12			bcc		no_scroll
   899 					
   900 					;yes -- scroll up
   901 F69B 20 D4 FC			jsr		EditorDeleteLine0
   902
   903 					;check if we can extend the current logical line -- 3 rows max.
   904 F69E 20 C0 F6			jsr		check_extend
   905
   906 					;Mark the current physical line as part of the last logical line.
   907 					;
   908 					;NOTE: There is a subtlety here in that we may delete multiple physical
   909 					;      lines if the top logical line is more than one line long, but we
   910 					;      only want to add one physical line onto our current logical line.
   911 F6A1 20 77 FD			jsr		EditorGetCurLogicalLineInfo
   912 F6A4 59 B2 02			eor		logmap,y
   913 F6A7 99 B2 02			sta		logmap,y
   914
   915 F6AA 4C BA F6			jmp		post_scroll
   916 					
   917 F6AD			no_scroll:
   918 					;check if we can extend the current logical line -- 3 rows max.
   919 F6AD 20 C0 F6			jsr		check_extend
   920
   921 					;okay, here's the fun part -- we didn't scroll beyond, but we might
   922 					;be on another logical line, in which case we need to scroll everything
   923 					;down to extend it.
   924 F6B0 A5 54			lda		rowcrs
   925 F6B2 20 86 FD			jsr		EditorTestLogicalLineBit
   926 F6B5 F0 03			beq		post_scroll
   927 					
   928 					;yup, insert a physical line
   929 F6B7 20 92 F8			jsr		ScreenInsertPhysLine
   930
   931 F6BA			recompute_show_cursor_exit:
   932 F6BA			post_scroll:
   933 F6BA 20 C8 FC			jsr		EditorRecomputeCursorAddr
   934 F6BD			nowrap:
   935 F6BD 4C 1A FE			jmp		ScreenShowCursorAndXitOK
   936 					
   937 F6C0			check_extend:
   938 F6C0 A6 54			ldx		rowcrs
   939 F6C2 CA				dex
   940 F6C3 8A				txa
   941 F6C4 20 8F FD			jsr		EditorPhysToLogicalRow
   942
   943 				.ifdef _KERNEL_816
   944 					inc
   945 					inc
   946 				.else
   947 F6C7 18				clc
   948 F6C8 69 02			adc		#2
   949 				.endif
   950
   951 F6CA C5 54			cmp		rowcrs
   952 F6CC 90 01 60			scc:rts
   953 F6CF 68				pla
   954 F6D0 68				pla
   955 F6D1 90 E7			bcc		post_scroll
   956 				.endp
