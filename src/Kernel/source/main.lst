  1702 				;==========================================================================
  1703 				; EXP [DDC0]	Compute e^x
  1704 				; EXP10 [DDCC]	Compute 10^x
  1705 				;
  1706 				; Algorithm is based on Ruckdeschel, Table VI.13, Series approximation
  1707 				; for 10^X over the interval 0 <= X <= 1, using a minimax polynomial:
  1708 				;
  1709 				;	10^X = (1 + A1*X + A2*X^3 + A3*X^5 + A4*X^7 + A5*X^9 + A6*X^11
  1710 				;		+ A7*X^13 + A8*X^15 + A9*X^17)^2
  1711 				;
  1712 				; The input X value is split into integer and fraction, integer/2 is added
  1713 				; to the final exponent, and an additional x10 multipled if integer is odd.
  1714 				;
  1715 				; There are, however, adjustments to match precise behavior in the standard
  1716 				; math pack, including quirks:
  1717 				;
  1718 				;	- The polynomial is biased down slightly from the original minimax by
  1719 				;	  1 ulp.
  1720 				;
  1721 				;	- If the input exponent is negative, 1/10^|X| is computed. This is
  1722 				;	  terrible, but needed to match.
  1723 				;
  1724 				;	- Smaller negative exponents underflow to 0 in the original math pack,
  1725 				;	  but some larger negative exponents produce an error.
  1726 				;
  1727 				;	- The integer is computed by _rounding_ instead of truncation. This
  1728 				;	  causes the polynomial to be evaluated over [-0.5, 0.5] instead
  1729 				;	  of the [0, 1] region it was optimized over. This is also terrible,
  1730 				;	  but we need to do it to match.
  1731 				;
  1732 				;	- A bug in the math pack causes inputs of |X| > 65535.5 to give incorrect
  1733 				;	  results instead of an overflow. We don't currently replicate this
  1734 				;	  bug.
  1735 				;
  1736 DDC0				fixadr	$ddc0
Macro: FIXADR [Source: source/Shared/mathpack.s]
Source: source/Shared/mathpack.s
  1737 = DDCC			exp10 = exp._exp10
  1738 DDC0			.proc exp
  1739 DDC0 A2 89				ldx		#<fpconst_log10_e
  1740 DDC2 A0 DE				ldy		#>fpconst_log10_e
  1741 DDC4 20 98 DD				jsr		fld1r		;we could use fp_fld1r_fmul, but then we have a hole :(
  1742 DDC7 20 DB DA				jsr		fmul
  1743 DDCA B0 6C				bcs		err2
  1744
  1745 DDCC					ckaddr	$ddcc
Macro: CKADDR [Source: source/Shared/mathpack.s]
Source: source/Shared/mathpack.s
  1746 DDCC			_exp10:
  1747 						;check if the input is negative
  1748 DDCC A6 D4				ldx		fr0
  1749 DDCE 10 19				bpl		input_positive
  1750
  1751 						;input is negative -- compute absolute, then invert
  1752 DDD0 06 D4				asl		fr0
  1753 DDD2 46 D4				lsr		fr0
  1754 DDD4 20 CC DD				jsr		_exp10
  1755 DDD7 B0 0D				bcs		underflow
  1756
  1757 DDD9 20 B6 DD				jsr		fmove
  1758 DDDC A2 EA				ldx		#<fpconst_one
  1759 DDDE A0 DF				ldy		#>fpconst_one
  1760 DDE0 20 89 DD				jsr		fld0r
  1761 DDE3 4C 28 DB				jmp		fdiv
  1762
  1763 DDE6			underflow:
  1764 DDE6 4C 43 DA				jmp		fp_clc_zfr0
  1765
  1766 DDE9			input_positive:
  1767 						;set up FR1 for round(X)
  1768 DDE9 A9 00				lda		#0
  1769 DDEB 85 E2				sta		fr1+2
  1770 DDED 85 E3				sta		fr1+3
  1771 DDEF 85 E4				sta		fr1+4
  1772 DDF1 85 E5				sta		fr1+5
  1773
  1774 						;check exponent to detect input < 0.01 or >= 100
  1775 DDF3 E0 40				cpx		#$40
  1776
  1777 						;jump if round(x) must be zero
  1778 DDF5 90 0C				bcc		tiny_input
  1779
  1780 						;check for input >= 100; this will always overflow
  1781 DDF7 D0 3F				bne		err2
  1782
  1783 						;load integer digit pair if in [1, 100), and round up based on the fraction
  1784 DDF9 F8					sed
  1785 DDFA A6 D6				ldx		fr0+2
  1786 DDFC E0 50				cpx		#$50
  1787 DDFE 65 D5				adc		fr0+1
  1788 DE00 D8					cld
  1789
  1790 						;if we carried, the integer is at least 99 and we are guaranteed to overflow
  1791 DE01 B0 35				bcs		err2
  1792
  1793 DE03			tiny_input:
  1794 						;write integer digit pair to FR1
  1795 DE03 85 E1				sta		fr1+1
  1796
  1797 						;convert to binary and save it
  1798 DE05 20 DD D8				jsr		fp_dectobin
  1799 DE08 F9 F6 DF				sbc		fp_dectobin_tab,y
  1800
  1801 						;save integer portion to adjust exponent later
  1802 DE0B 85 F8				sta		_fptemp0
  1803
  1804 						;skip subtraction if it's zero
  1805 DE0D F0 07				beq		no_integer
  1806
  1807 						;compute y = frac(x)
  1808 DE0F A2 40				ldx		#$40
  1809 DE11 86 E0				stx		fr1
  1810 DE13 20 60 DA				jsr		fsub
  1811
  1812 DE16			no_integer:
  1813 						;evaluate f(y)
  1814 DE16 A2 4D				ldx		#<fpconst_exp10_coeff
  1815 DE18 A0 DE				ldy		#>fpconst_exp10_coeff
  1816 DE1A 20 3E DD				jsr		fp_plyevl_10
  1817
  1818 						;square result
  1819 DE1D 20 B6 DD				jsr		fmove
  1820 DE20 20 DB DA				jsr		fmul
  1821 					
  1822 						;halve integer portion to compute exponent adjustment
  1823 DE23 46 F8				lsr		_fptemp0
  1824 					
  1825 						;scale by 10 if necessary
  1826 DE25 90 09				bcc		even
  1827 DE27 A2 8F				ldx		#<fpconst_ten
  1828 DE29 A0 DE				ldy		#>fpconst_ten
  1829 DE2B 20 D8 DA				jsr		fp_fld1r_fmul
  1830 DE2E B0 08				bcs		err2
  1831 DE30			even:
  1832
  1833 						;bias exponent
  1834 DE30 A5 F8				lda		_fptemp0
  1835 DE32 65 D4				adc		fr0
  1836 DE34 C9 71				cmp		#64+49			;set error flag if overflow
  1837 DE36 85 D4				sta		fr0
  1838
  1839 DE38			err2:
  1840 DE38			xit2:
  1841 DE38 60					rts
  1842 				.endp	
