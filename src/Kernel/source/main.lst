   361 				;==========================================================================
   362 				; BCD to binary conversion helper.
   363 				;
   364 				; Entry:
   365 				;	A = BCD value (fp_dectobin)
   366 				;
   367 				; Exit:
   368 				;	A = unmodified or loaded BCD byte
   369 				;	Y = MSB nibble (digit)
   370 				;
   371 				; Preserved:
   372 				;	X
   373 				;
   374 D8DB			fp_ldfr0p1_dectobin:		;$0B bytes
   375 D8DB B5 D5				lda		fr0+1,x
   376 D8DD			fp_dectobin:
   377 D8DD 48					pha
   378 D8DE 4A					lsr
   379 D8DF 4A					lsr
   380 D8E0 4A					lsr
   381 D8E1 4A					lsr
   382 D8E2 A8					tay
   383 D8E3 68					pla
   384 D8E4 18					clc
   385 D8E5 60					rts
   386
   387 				;==========================================================================
   388 				; FASC [D8E6]		Floating Point to ASCII conversion
   389 				;
   390 				; Converts an FP number in FR0 to an ASCII representation in LBUFF, setting
   391 				; INBUFF to the start of the string and with bit 7 set on the last
   392 				; character.
   393 				;
   394 				; Negative values are preceded by '-', followed by at least one decimal
   395 				; digit -- so values smaller than 1.0 in magnitude start with "0.".
   396 				; Exponential notation is used for values <0.01 or >=10^10, with the
   397 				; form m.mmmmmmmmE+nn; trailing zeroes on the mantissa are trimmed, along
   398 				; with the . if there are no non-zero digits after it.
   399 				;
   400 				; Quirks:
   401 				;	- INBUFF does not always point to LBUFF. It can be up to two bytes prior
   402 				;	  to LBUFF and one byte after LBUFF:
   403 				;		* +1 if the leading digit of the mantissa is trimmed off
   404 				;		* -1 if 0. is prefixed for magnitude in [0.01, 1), or odd exponents
   405 				;		  in scientific notation
   406 				;		* -1 if - prefixed for negative number
   407 				;
   408 				;	- One decimal digit is always printed for odd exponents, but not for
   409 				;	  even exponents, e.g. 1E+10 and 1.0E+11.
   410 				;
   411 				; Compatibility issues:
   412 				;	- Darg ignores INBUFF and requires integers to be validly parsable starting
   413 				;	  at LBUFF. This means that LBUFF[0] must contain a zero if INBUFF is
   414 				;	  beyond it.
   415 				;
   416 D8E6					fixadr	$d8e6
Macro: FIXADR [Source: source/Shared/mathpack.s]
Source: source/Shared/mathpack.s
   417
   418 D8E6			.proc	fasc
   419 = 00F7			dotcntr	= ztemp4
   420 = 00F8			expval	= ztemp4+1
   421 = 00F9			trimbase = ztemp4+2
   422
   423 D8E6 20 51 DA			jsr		ldbufa
   424
   425 					;init starting output index
   426 D8E9 A0 00			ldy		#0
   427
   428 					;start with no exponent to display
   429 D8EB 84 F8			sty		expval
   430 D8ED 84 F9			sty		trimbase
   431
   432 					;write a zero to the start of the buffer
   433 D8EF A9 30			lda		#$30
   434 D8F1 91 F3			sta		(inbuff),y
   435
   436 					;read exponent and check if number is zero
   437 D8F3 A5 D4			lda		fr0
   438 D8F5 F0 5F			beq		is_zero
   439 					
   440 					;set up for 5 mantissa bytes
   441 D8F7 A2 FB			ldx		#-5
   442
   443 					;compute digit offset to place dot
   444 					;  0.001 (10.0E-04) = 3E 10 00 00 00 00 -> -1
   445 					;   0.01 ( 1.0E-02) = 3F 01 00 00 00 00 -> 1
   446 					;    0.1 (10.0E-02) = 3F 10 00 00 00 00 -> 1
   447 					;    1.0 ( 1.0E+00) = 40 01 00 00 00 00 -> 3
   448 					;   10.0 (10.0E+00) = 40 10 00 00 00 00 -> 3
   449 					;  100.0 ( 1.0E+02) = 40 01 00 00 00 00 -> 5
   450 					; 1000.0 (10.0E+02) = 40 10 00 00 00 00 -> 5
   451
   452 D8F9 0A				asl
   453 D8FA 38				sec
   454 D8FB E9 7D			sbc		#125
   455
   456 					;check if we should go to exponential form (exp >= 10 or <=-3)
   457 D8FD C9 0C			cmp		#12
   458 D8FF 90 08			bcc		noexp
   459
   460 					;yes - compute and stash explicit exponent
   461 D901 E9 02			sbc		#2				;!! - carry set from BCC fail
   462 D903 85 F8			sta		expval			;$0A <= expval < $FE
   463
   464 					;reset dot counter
   465 D905 A9 02			lda		#2
   466
   467 					;exclude first two digits from zero trim
   468 D907 85 F9			sta		trimbase
   469
   470 D909			noexp:		
   471 D909 85 F7			sta		dotcntr			;$02 <= dotcntr < $0C
   472
   473 					;check if number is less than 1.0
   474 D90B C9 02			cmp		#2
   475 D90D B0 7C			bcs		not_tiny
   476 					
   477 					;At this point A = 1 and expval = 0, so the value is
   478 					;at least 0.01 and less than 1.0 and we are guaranteed to
   479 					;need 0. inserted in front.
   480
   481 					;shift buffer ahead one
   482 D90F C6 F3			dec		inbuff
   483
   484 D911 CA				dex
   485 D912 C6 F9			dec		trimbase
   486 D914 4A				lsr						;A=0
   487 D915 F0 21			beq		writelowz		;!! - unconditional
   488
   489 					;write out mantissa digits
   490 D917			digitloop:
   491 D917 C6 F7			dec		dotcntr
   492 D919 D0 05			bne		no_hidot
   493 D91B A9 2E			lda		#'.'
   494 D91D 91 F3			sta		(inbuff),y
   495 D91F C8				iny
   496 D920			no_hidot:
   497
   498 					;write out high digit
   499 D920 B5 DA			lda		fr0+6,x
   500 D922 4A				lsr
   501 D923 4A				lsr
   502 D924 4A				lsr
   503 D925 4A				lsr
   504 D926 09 30			ora		#$30
   505 D928 91 F3			sta		(inbuff),y
   506 D92A C8				iny
   507 					
   508 D92B			writelow:
   509 					;write out low digit
   510 D92B C6 F7			dec		dotcntr
   511 D92D D0 05			bne		no_lodot
   512 D92F A9 2E			lda		#'.'
   513 D931 91 F3			sta		(inbuff),y
   514 D933 C8				iny
   515 D934			no_lodot:
   516 					
   517 D934 B5 DA			lda		fr0+6,x
   518 D936 29 0F			and		#$0f
   519 D938			writelowz:
   520 D938 09 30			ora		#$30
   521 D93A 91 F3			sta		(inbuff),y
   522 D93C C8				iny
   523
   524 					;next digit
   525 D93D E8				inx
   526 D93E D0 D7			bne		digitloop
   527
   528 					;skip trim if dot hasn't been written
   529 D940 A5 F7			lda		dotcntr
   530 D942 10 11			bpl		skip_zero_trim	
   531 					
   532 					;trim off trailing zeroes
   533 D944 A9 30			lda		#'0'
   534 D946			lzloop:
   535 D946 C4 F9			cpy		trimbase
   536 D948 F0 05			beq		stop_zero_trim
   537 D94A 88				dey
   538 D94B D1 F3			cmp		(inbuff),y
   539 D94D F0 F7			beq		lzloop
   540
   541 					;trim off dot
   542 D94F			stop_zero_trim:
   543 D94F B1 F3			lda		(inbuff),y
   544 D951 C9 2E			cmp		#'.'
   545 D953 D0 03			bne		no_trailing_dot
   546
   547 D955			skip_zero_trim:
   548 D955 88				dey
   549 D956			is_zero:
   550 D956 B1 F3			lda		(inbuff),y
   551 D958			no_trailing_dot:
   552
   553 					;check if we have an exponent to deal with
   554 D958 A6 F8			ldx		expval
   555 D95A F0 26			beq		noexp2
   556 					
   557 					;print an 'E'
   558 D95C A9 45			lda		#'E'
   559 D95E C8				iny
   560 D95F 91 F3			sta		(inbuff),y
   561 					
   562 					;check for a negative exponent
   563 D961 8A				txa
   564 D962 10 07			bpl		exppos
   565 D964 49 FF			eor		#$ff
   566 D966 AA				tax
   567 D967 E8				inx
   568 D968 A9 2D			lda		#'-'
   569 D96A 2C				dta		{bit $0100}
   570 D96B			exppos:
   571 D96B A9 2B			lda		#'+'
   572 D96D			expneg:
   573 D96D C8				iny
   574 D96E 91 F3			sta		(inbuff),y
   575 					
   576 					;print tens digit, if any
   577 D970 8A				txa
   578 D971 38				sec
   579 D972 A2 2F			ldx		#$2f
   580 D974			tensloop:
   581 D974 E8				inx
   582 D975 E9 0A			sbc		#10
   583 D977 B0 FB			bcs		tensloop
   584 D979 48				pha
   585 D97A 8A				txa
   586 D97B C8				iny
   587 D97C 91 F3			sta		(inbuff),y
   588 D97E 68				pla
   589 D97F 69 3A			adc		#$3a
   590 D981 C8				iny
   591 D982			noexp2:
   592 					;set high bit on last char
   593 D982 09 80			ora		#$80
   594 D984 91 F3			sta		(inbuff),y
   595
   596 					;prepend minus sign for negative number (must decrement INBUFF)
   597 D986 A5 D4			lda		fr0
   598 D988 30 15			bmi		negative
   599 D98A 60				rts
   600
   601 D98B			not_tiny:
   602 					;check if number begins with a leading zero
   603 D98B B5 DA			lda		fr0+6,x
   604 D98D C9 10			cmp		#$10
   605 D98F B0 86			bcs		digitloop
   606
   607 D991 C6 F9			dec		trimbase
   608
   609 					;yes - skip the high digit
   610 D993 E6 F3			inc		inbuff
   611 D995 46 F8			lsr		expval
   612 D997 06 F8			asl		expval
   613 D999 D0 90			bne		writelow
   614 D99B C6 F7			dec		dotcntr
   615 D99D 90 8C			bcc		writelow		;!! - unconditional
   616
   617 D99F			negative:
   618 D99F A9 2D			lda		#'-'
   619 D9A1 AA				tax
   620 D9A2 C6 F3			dec		inbuff
   621 D9A4 81 C6			sta		(inbuff-'-',x)
   622 D9A6 60				rts
   623 				.endp
   624
   625 				;==========================================================================
   626 				; IFP [D9AA]	Convert 16-bit integer at FR0 to FP
   627 				;
   628 				; Converts the 16-bit unsigned binary number with LSB in FR0 and MSB in
   629 				; FR0+1 to a floating point number in FR0. This always succeeds since all
   630 				; 65536 values are representable.
   631 				;
   632 				; !NOTE! Cannot use FR2/FR3 -- MAC/65 requires that $DE-DF be preserved.
   633 				;
   634 D9A7				fixadr	$d9aa
Macro: FIXADR [Source: source/Shared/mathpack.s]
     2 						.print ($D9AA-*),' bytes free before ',$D9AA
     2 				$0003 bytes free before $D9AA
     3 D9A7					org		$D9AA
Source: source/Shared/mathpack.s
   635 D9AA			.proc ifp
   636 						;clear remainder of mantissa
   637 D9AA A9 00				lda		#0
   638 D9AC 85 D6				sta		fr0+2
   639 D9AE 85 D7				sta		fr0+3
   640 D9B0 85 D8				sta		fr0+4
   641 D9B2 85 D9				sta		fr0+5
   642 					
   643 						;prepare to shift up to 16 bits
   644 D9B4 A0 10				ldy		#16
   645
   646 						;swap around bytes so that MSB is in FR0 -- this allows FR0+1 to
   647 						;take carries out of the BCD shift for the 5th digit
   648 D9B6 A6 D4				ldx		fr0
   649 D9B8 A5 D5				lda		fr0+1
   650 D9BA D0 05				bne		big
   651 D9BC A0 08				ldy		#8
   652 D9BE 8A					txa
   653 D9BF A2 00				ldx		#0
   654 D9C1			big:
   655 D9C1 86 D5				stx		fr0+1
   656
   657 						;shift until we get the first set bit
   658 D9C3			find_loop:
   659 D9C3 06 D5				asl		fr0+1
   660 D9C5 2A					rol
   661 D9C6 B0 04				bcs		found_leading_bit
   662 D9C8 88					dey
   663 D9C9 D0 F8				bne		find_loop
   664 D9CB 60					rts
   665
   666 D9CC			found_leading_bit:
   667 D9CC F8					sed
   668 D9CD 85 D4				sta		fr0
   669 D9CF 4C E8 DB				jmp		ifp_cont
   670 				.endp
   671
   672 				;==========================================================================
   673 				; FPI [D9D2]	Convert FR0 to 16-bit integer at FR0 with rounding
   674 				;
   675 				; This cannot overwrite FR1. Darg relies on being able to stash a value
   676 				; there across a call to FPI in its startup.
   677 				;
   678 				; Errors:
   679 				;	- Error if input negative or >= 65536.
   680 				;
   681 				; Quirks:
   682 				;	- Negative numbers in [-0.5, 0) cause an error instead of being
   683 				;	  rounded up to 0.
   684 				;	- Numbers in [65535, 65536) are rounded up to 65536 and then
   685 				;	  truncated to 0 without error.
   686 				;
   687 D9D2				fixadr	$d9d2
Macro: FIXADR [Source: source/Shared/mathpack.s]
Source: source/Shared/mathpack.s
   688 D9D2			.nowarn .proc fpi
   689 = 00E6			_acc0 = fr2
   690 = 00E7			_acc1 = fr2+1
   691 					
   692 					;error out if it's guaranteed to be too big or negative (>999999)
   693 D9D2 A5 D4			lda		fr0
   694 D9D4 C9 43			cmp		#$43
   695 D9D6 B0 66			bcs		err
   696
   697 					;zero number if it's guaranteed to be too small (<0.01)
   698 D9D8 E9 3E			sbc		#$3f-1			;!!- carry is clear
   699 D9DA 90 68			bcc		zfr0
   700
   701 D9DC AA				tax
   702 					
   703 					;clear temp accum and set up rounding
   704 D9DD A9 00			lda		#0
   705 D9DF B4 D5			ldy		fr0+1,x
   706 D9E1 C0 50			cpy		#$50
   707 D9E3 2A				rol						;!! - clears carry too
   708 D9E4 85 D4			sta		fr0
   709 D9E6 A9 00			lda		#0
   710
   711 					;check for [0.01, 1)
   712 D9E8 CA				dex
   713 D9E9 30 51			bmi		done
   714
   715 					;convert ones/tens digit pair to binary (one result byte: 0-100)
   716 D9EB 20 DB D8			jsr		fp_ldfr0p1_dectobin
   717 D9EE 65 D4			adc		fr0
   718 D9F0 F9 F6 DF			sbc		fp_dectobin_tab,y
   719 D9F3 18				clc
   720 D9F4 85 D4			sta		fr0
   721 D9F6 A9 00			lda		#0
   722
   723 					;check if we're done
   724 D9F8 CA				dex
   725 D9F9 30 41			bmi		done
   726
   727 					;convert hundreds/thousands digit pair to binary (two result bytes: 0-10000)
   728 D9FB 20 DB D8			jsr		fp_ldfr0p1_dectobin
   729 D9FE A5 D4			lda		fr0
   730 DA00 79 39 DE			adc		fp_tab_lo_1000,y
   731 DA03 85 D4			sta		fr0
   732 DA05 B9 43 DE			lda		fp_tab_hi_1000,y
   733 DA08 69 00			adc		#0
   734 DA0A 48				pha
   735 DA0B B5 D5			lda		fr0+1,x
   736 DA0D 29 0F			and		#$0f
   737 DA0F A8				tay
   738 DA10 A5 D4			lda		fr0
   739 DA12 79 D1 D8			adc		fp_tab_lo_100,y
   740 DA15 85 D4			sta		fr0
   741 DA17 68				pla
   742 DA18 79 10 DD			adc		fp_tab_hi_100,y
   743
   744 					;check if we're done
   745 DA1B CA				dex
   746 DA1C 30 1E			bmi		done
   747
   748 					;convert ten thousands digit pair to binary (two result bytes: 0-100000, overflow possible)
   749 					;LSB = digit * 16
   750 					;MSB = digit * 39.0625
   751 DA1E AA				tax
   752 DA1F A4 D5			ldy		fr0+1
   753 DA21 C0 07			cpy		#$07
   754 DA23 B0 19			bcs		err
   755 DA25 98				tya
   756 DA26 0A				asl
   757 DA27 0A				asl
   758 DA28 0A				asl
   759 DA29 0A				asl
   760 DA2A 65 D4			adc		fr0
   761 DA2C 85 D4			sta		fr0
   762 DA2E 8A				txa
   763 DA2F 79 1B DB			adc		fp_tab_hi_10000-1,y
   764
   765 					;Bug compat -- if we had an overflow error, clear it if the value was
   766 					;exactly rounded up to 0. We can only enter this path if the value was
   767 					;between [10000, 70000), so if the high byte is 0, the only possible
   768 					;way is a source value of [65535.5, 65791.5).
   769 DA32 D0 08			bne		done
   770 DA34 A6 D4			ldx		fr0
   771 DA36 D0 04			bne		done
   772 DA38 A2 4F			ldx		#$4f
   773 DA3A E4 D8			cpx		fr0+4
   774
   775 DA3C			done:
   776 					;move result back to FR0, with rounding
   777 DA3C 85 D5			sta		fr0+1
   778 DA3E			err:
   779 DA3E 60				rts
   780 				.endp
