  1960 DEDC 0A					asl
  1961 DEDD 49 80				eor		#$80
  1962 DEDF 85 F8				sta		_fptemp0
  1963 					
  1964 						;reset exponent so we are in 1 <= z < 100
  1965 DEE1 A2 40				ldx		#$40
