Macro: _KERNEL_REPORT_MODULE_SIZE [Source: source/main.xasm]
     1 					.echo	'    ', *, ' -> ', *-?@_kernel_lastpt, '(', $EF41-$EE78, ')', '    ', 'Printer Handler'
     1 				    $ED14 -> $0092($00C9)    Printer Handler
