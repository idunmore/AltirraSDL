Source: source/main.xasm
   256 					
   257 ED14				icl		'cassette.s'
Source: source/Shared/cassette.s
     1 				;	Altirra - Atari 800/800XL/5200 emulator
     2 				;	Modular Kernel ROM - Cassette tape support
     3 				;	Copyright (C) 2008-2016 Avery Lee
     4 				;
     5 				;	Copying and distribution of this file, with or without modification,
     6 				;	are permitted in any medium without royalty provided the copyright
     7 				;	notice and this notice are preserved.  This file is offered as-is,
     8 				;	without any warranty.
     9
    10 				;==========================================================================
    11 ED14			.proc CassetteInit
    12 						;Set CBAUDL/CBAUDH to $05CC, the nominal POKEY divisor for 600
    13 						;baud. We don't care about this, but it's documented in the OS
    14 						;Manual.
    15 ED14 A9 CC 8D EE 02 A9 + 		mwa		#$05CC cbaudl
    16 ED1E 60					rts
    17 				.endp
    18
    19 				;==========================================================================
    20 				; Cassette open routine.
    21 				;
    22 				; XL/XE OS behavior notes:
    23 				;	- Attempting to open for none (AUX1=$00) or read/write (AUX1=$0C)
    24 				;	  results in a Not Supported error (146).
    25 				;	- Open for read gives one beep, while open for write gives two beeps.
    26 				;	- Break will break out of the wait.
    27 				;	- Ctrl+3 during the keypress causes an EOF error (!). This is a side
    28 				;	  effect of reusing the keyboard handler.
    29 				;
    30 				; CSOPIV behavior:
    31 				;	- Does NOT set FTYPE (continuous mode flag).
    32 				;	- Sets read mode (WMODE).
    33 				;	- Does NOT require ICAX1Z or ICAX2Z to be set.
    34 				;
    35 = ED32			CassetteOpenRead = CassetteOpen.do_open_read
    36 ED1F			.proc CassetteOpen
    37 					;stash continuous mode flag
    38 ED1F A5 2B			lda		icax2z			;!! FIRST TWO BYTES CHECKED BY ARCHON
    39 ED21 85 3E			sta		ftype
    40 					
    41 					;check mode byte for read/write modes
    42 ED23 A2 80			ldx		#$80
    43 ED25 A5 2A			lda		icax1z
    44 ED27 29 0C			and		#$0c
    45 ED29 C9 04			cmp		#$04			;read?
    46 ED2B F0 05			beq		found_read_mode
    47 ED2D C9 08			cmp		#$08			;write?
    48 ED2F F0 03			beq		found_write_mode
    49 					
    50 					;invalid mode -- return not supported
    51 ED31 60				rts
    52 					
    53 ED32			do_open_read:
    54 ED32			found_read_mode:
    55 ED32 A2 00			ldx		#$00
    56 ED34			found_write_mode:
    57 ED34 8E 89 02			stx		wmode
    58
    59 					;set cassette buffer size to 128 bytes and mark it empty
    60 ED37 A9 80			lda		#$80
    61 ED39 85 3D			sta		bptr
    62 ED3B 8D 8A 02			sta		blim
    63 					
    64 					;clear EOF flag
    65 ED3E 0A				asl
    66 ED3F 85 3F			sta		feof
    67 					
    68 					;request one beep for read, or two for write
    69 ED41 2C 89 02			bit		wmode
    70 ED44 10 05			bpl		one_ping_only
    71 					
    72 ED46 06 3D			asl		bptr			;!! - set bptr=0 when starting write
    73
    74 ED48 20 89 EE			jsr		CassetteBell
    75
    76 ED4B			one_ping_only:
    77 ED4B 20 89 EE			jsr		CassetteBell
    78 					
    79 					;wait for a key press
    80 ED4E 20 6C FE			jsr		KeyboardGetByte
    81 ED51 30 20			bmi		aborted
    82
    83 					;need to set up POKEY for writes now to write leader
    84 ED53 2C 89 02			bit		wmode
    85 ED56 10 08			bpl		no_write_init
    86 ED58 A9 FF			lda		#$ff
    87 ED5A 8D 0F 03			sta		casflg
    88 ED5D 20 55 E9			jsr		SIOSendEnable.no_irq_setup
    89 ED60			no_write_init:
    90 					
    91 					;turn on motor (continuous mode or not)
    92 ED60 A9 34			lda		#$34
    93 ED62 8D 02 D3			sta		pactl
    94 					
    95 					;wait for leader (9.6 seconds read, 19.2s write)
    96 ED65 A2 00			ldx		#0
    97 ED67 2C 89 02			bit		wmode
    98 ED6A 30 02 A2 01			smi:ldx	#1
    99 ED6E 20 63 EE			jsr		CassetteWait
   100 					
   101 					;all done
   102 ED71 A0 01			ldy		#1
   103 ED73			aborted:
   104 ED73 60				rts
   105 				.endp
   106
   107 				;==========================================================================
   108 ED74			.proc CassetteClose
   109 					;check if we are in write mode
   110 ED74 AD 89 02			lda		wmode			;!! FIRST TWO BYTES CHECKED BY ARCHON
   111 ED77 10 0A			bpl		notwrite
   112 					
   113 					;check if we have data to write
   114 ED79 A5 3D			lda		bptr
   115 ED7B F0 03			beq		nopartial
   116 					
   117 					;flush partial record ($FA)
   118 ED7D 20 E6 ED			jsr		CassetteFlush
   119 						
   120 ED80			nopartial:
   121 					;write EOF record ($FE)
   122 ED80 20 E6 ED			jsr		CassetteFlush
   123 					
   124 ED83			notwrite:
   125 					;stop the motor
   126 ED83 A9 3C			lda		#$3c
   127 ED85 8D 02 D3			sta		pactl
   128 					
   129 					;kill audio
   130 ED88 A0 00			ldy		#0
   131 ED8A 8C 01 D2			sty		audc1
   132 ED8D 8C 03 D2			sty		audc2
   133 ED90 8C 07 D2			sty		audc4
   134 					
   135 					;all done
   136 ED93 C8				iny
   137 ED94 60				rts
   138 				.endp
   139
   140 				;==========================================================================
   141 				; CassetteReadBlock
   142 				;
   143 				; Read the next block from the C: device, and then fetch the next character
   144 				; from the cassette buffer. Pointed to by RBLOKV.
   145 				;
   146 				; Input:
   147 				;	- FTYPE bit 7 set to stop motor afterward (short IRG), cleared to leave
   148 				;	  motor running.
   149 				;
   150 				; Output:
   151 				;	- Block read to CASBUF.
   152 				;	- FEOF set to $FF if end block found ($FE), otherwise unchanged.
   153 				;	- BPTR set to $01 on success, $00 on EOF
   154 				;	- BLIM set to block length on success, $00 on EOF, otherwise unchanged.
   155 				;	- A = next character read from buffer, if successful.
   156 				;
   157 				; Notes:
   158 				;	- If the motor is not already running, it is started.
   159 				;	- It is possible for this to read another block, if an empty block is
   160 				;	  read ($FA/$00).
   161 				;
   162 				;==========================================================================
   163 				; CassetteGetByte
   164 				;
   165 				; Get Byte handler for C: device.
   166 				;
   167 ED95			.proc CassetteGetByte
   168 					;check if we have an EOF condition
   169 ED95 A5 3F			lda		feof			;!! FIRST TWO BYTES CHECKED BY ARCHON
   170 ED97 D0 17			bne		xit_eof
   171 					
   172 ED99			fetchbyte:
   173 					;check if we can still fetch a byte
   174 ED99 A6 3D			ldx		bptr
   175 ED9B EC 8A 02			cpx		blim
   176 ED9E F0 13			beq		nobytes
   177
   178 EDA0 BD 00 04			lda		casbuf+3,x
   179 EDA3 E6 3D			inc		bptr
   180 EDA5 A0 01			ldy		#1
   181 EDA7			error:
   182 EDA7 60				rts
   183
   184 EDA8			eof:
   185 					;set EOF flag
   186 EDA8 A0 FF 84 3F			mvy		#$ff feof
   187
   188 					;clear buffer length
   189 EDAC C8				iny
   190 EDAD 8C 8A 02			sty		blim
   191
   192 					;return EOF status
   193 EDB0			xit_eof:
   194 EDB0 A0 88			ldy		#CIOStatEndOfFile
   195 EDB2 60				rts
   196
   197 EDB3			nobytes:
   198 					;fetch more bytes
   199 = EDB3			.def :CassetteReadBlock
   200 EDB3 A2 40			ldx		#$40
   201 EDB5 A0 52			ldy		#'R'
   202
   203 EDB7 20 16 EE			jsr		CassetteDoIO
   204 EDBA 30 EB			bmi		error
   205
   206 					;reset buffer pointer
   207 EDBC A9 00 85 3D			mva		#$00 bptr
   208
   209 					;check for EOF
   210 EDC0 AD FF 03			lda		casbuf+2
   211 EDC3 C9 FE			cmp		#$fe
   212 EDC5 F0 E1			beq		eof
   213
   214 EDC7			init_block:
   215 					;assume full block first (128 bytes)
   216 EDC7 A2 80			ldx		#$80
   217 					
   218 					;check if it actually is one -- officially $fc is complete (128 bytes)
   219 					;and $fa is partial, but all other values are treated as $fc
   220 EDC9 C9 FA			cmp		#$fa
   221 EDCB D0 03			bne		full_block
   222
   223 					;set length of partial block
   224 EDCD AE 7F 04			ldx		casbuf+130
   225 					
   226 EDD0			full_block:
   227 					;reset block length and loop back
   228 EDD0 8E 8A 02			stx		blim
   229 EDD3 4C 99 ED			jmp		fetchbyte
   230 				.endp
   231
   232 				;==========================================================================
   233 EDD6			.proc CassettePutByte
   234 					;put a byte into the buffer
   235 EDD6 A6 3D			ldx		bptr			;!! FIRST TWO BYTES CHECKED BY ARCHON
   236 EDD8 9D 00 04			sta		casbuf+3,x
   237 					
   238 					;bump and check if it's time to write
   239 EDDB E8				inx
   240 EDDC 86 3D			stx		bptr
   241 EDDE EC 8A 02			cpx		blim
   242 EDE1 B0 03			bcs		CassetteFlush
   243 					
   244 					;all done
   245 EDE3 A0 01			ldy		#1
   246 EDE5 60				rts
   247 				.endp
   248
   249 				;==========================================================================
   250 EDE6			.proc CassetteFlush
   251 EDE6 A9 00			lda		#0
   252
   253 					;set control byte based on buffer level
   254 EDE8 A2 FE			ldx		#$fe			;empty -> EOF
   255 EDEA A4 3D			ldy		bptr			;get buffer level
   256 EDEC D0 08			bne		not_empty		;skip not empty
   257 					
   258 					;clear buffer for EOF
   259 EDEE 99 00 04 C8 10 FA		sta:rpl	casbuf+3,y+
   260 EDF4 30 0C			bmi		is_empty		;!! - unconditional
   261 					
   262 EDF6			not_empty:
   263 EDF6 A2 FC			ldx		#$fc			;load complete code
   264 EDF8 CC 8A 02			cpy		blim			;check if buffer is full
   265 EDFB B0 05			bcs		is_complete		;skip if so
   266 EDFD A2 FA			ldx		#$fa			;load partial code
   267 EDFF 8C 7F 04			sty		casbuf+130		;store level in last byte
   268 EE02			is_complete:
   269 EE02			is_empty:
   270
   271 					;store code
   272 EE02 8E FF 03			stx		casbuf+2
   273 					
   274 					;reset buffer level
   275 EE05 85 3D			sta		bptr
   276 					
   277 					;setup sync bytes
   278 EE07 A9 55			lda		#$55
   279 EE09 8D FD 03			sta		casbuf
   280 EE0C 8D FE 03			sta		casbuf+1
   281 					
   282 					;issue write request and exit
   283 EE0F A2 80			ldx		#$80
   284 EE11 A0 50			ldy		#'P'
   285 EE13 4C 16 EE			jmp		CassetteDoIO
   286 				.endp
   287
   288 				;==========================================================================
   289 = E4C9			CassetteGetStatus = CIOExitSuccess
   290 = E4CB			CassetteSpecial = CIOExitNotSupported
   291
   292 				;==========================================================================
   293 				; CassetteDoIO
   294 				;
   295 				;	X = DSTATS value
   296 				;	Y = SIO command byte
   297 				;
   298 				; Note that SOUNDR must take effect each time a cassette I/O operation
   299 				; occurs.
   300 				;
   301 EE16			.proc CassetteDoIO
   302 					;start the motor if not already running
   303 EE16 A9 34			lda		#$34
   304 EE18 8D 02 D3			sta		pactl
   305
   306 					;set up SIO read/write
   307 EE1B 8E 03 03			stx		dstats
   308 EE1E 8C 02 03			sty		dcomnd
   309 EE21 A9 FD 8D 04 03 A9 + 	mwa		#casbuf dbuflo
   310 EE2B A9 83 8D 08 03 A9 + 	mwa		#131 dbytlo
   311 EE35 A9 60 8D 00 03		mva		#$60 ddevic
   312 EE3A A9 00 8D 01 03		mva		#0 dunit
   313 EE3F A5 3E 8D 0B 03		mva		ftype daux2
   314
   315 					;do it
   316 EE44 20 59 E4			jsr		siov
   317 					
   318 					;check if we are in continuous mode (again)
   319 EE47 A5 3E			lda		ftype
   320 EE49 30 0F			bmi		rolling_stop
   321 					
   322 					;not in continuous mode -- wait for post-write tone if writing
   323 EE4B 2C 89 02			bit		wmode
   324 EE4E 10 05			bpl		no_pwt
   325 EE50 A2 06			ldx		#6
   326 EE52 20 63 EE			jsr		CassetteWait
   327 EE55			no_pwt:
   328 					
   329 					;stop the motor
   330 EE55 A9 3C			lda		#$3c
   331 EE57 8D 02 D3			sta		pactl
   332 					
   333 EE5A			rolling_stop:
   334 EE5A A4 30			ldy		status
   335 EE5C 60				rts
   336 				.endp
   337
   338 				;==========================================================================
   339 				;Entry:
   340 				;	X = delay type
   341 				;
   342 = EE63			CassetteWait = CassetteWaitLongShortCheck.normal_entry
   343 EE5D			.proc CassetteWaitLongShortCheck
   344 EE5D 2C 0B 03			bit		daux2
   345 EE60 10 01 E8			spl:inx
   346 EE63			normal_entry:
   347 EE63 20 16 E9			jsr		SIOSetTimeoutVector
   348 EE66 BC 7B EE			ldy		wait_table_lo,x
   349 EE69 BD 82 EE			lda		wait_table_hi,x
   350 EE6C AA				tax
   351 EE6D A9 01			lda		#1
   352 EE6F 8D 17 03			sta		timflg
   353 EE72 20 5D C1			jsr		VBISetVector
   354 EE75 AD 17 03 D0 FB		lda:rne	timflg
   355 EE7A 60				rts
   356 					
   357 EE7B			wait_table_lo:
   358 EE7B 80				dta		<$0480			;$00 - write file leader (19.2 seconds NTSC)
   359 EE7C 40				dta		<$0240			;$01 - read leader delay (9.6 seconds NTSC)
   360 EE7D B4				dta		<$00B4			;$02 - long pre-record write tone (3.0s NTSC)
   361 EE7E 0F				dta		<$000F			;$03 - short pre-record write tone (0.25s NTSC)
   362 EE7F 78				dta		<$0078			;$04 - long read IRG (2.0s NTSC)
   363 EE80 0A				dta		<$000A			;$05 - short read IRG (0.16s NTSC)
   364 EE81 3C				dta		<$003C			;$06 - post record gap (1s NTSC)
   365
   366 EE82			wait_table_hi:
   367 EE82 04				dta		>$0480			;$00 - write file leader (19.2 seconds NTSC)
   368 EE83 02				dta		>$0240			;$01 - read leader delay (9.6 seconds NTSC)
   369 EE84 00				dta		>$00B4			;$02 - long pre-record write tone (3.0s NTSC)
   370 EE85 00				dta		>$000F			;$03 - short pre-record write tone (0.25s NTSC)
   371 EE86 00				dta		>$0078			;$04 - long read IRG (2.0s NTSC)
   372 EE87 00				dta		>$000A			;$05 - short read IRG (0.16s NTSC)
   373 EE88 00				dta		>$003C			;$06 - post record gap (1s NTSC)
   374 				.endp
   375
   376 				;==========================================================================
   377 				; Sound a bell using the console speaker (cassette version)
   378 				;
   379 				; Modified:
   380 				;	A, X, Y
   381 				;
   382 EE89			.proc CassetteBell
   383 EE89 A0 00			ldy		#0
   384 EE8B 98				tya
   385 EE8C			soundloop:
   386 EE8C A2 0A			ldx		#10
   387 EE8E 48				pha
   388 EE8F			delay:
   389 EE8F AD 0B D4			lda		vcount
   390 EE92 CD 0B D4 F0 FB		cmp:req	vcount
   391 EE97 CA				dex
   392 EE98 D0 F5			bne		delay
   393 EE9A 68				pla
   394 EE9B 49 08			eor		#$08
   395 EE9D 8D 1F D0			sta		consol
   396 EEA0 D0 EA			bne		soundloop
   397 EEA2 88				dey
   398 EEA3 D0 E7			bne		soundloop
   399 EEA5 60				rts
   400 				.endp
