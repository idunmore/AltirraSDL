    16 EEA9			.proc InitHandlerTable
    17 EEA9 50 30 E4			dta		c'P',a(printv)
    18 EEAC 43 40 E4			dta		c'C',a(casetv)
    19 EEAF 45 00 E4			dta		c'E',a(editrv)
    20 EEB2 53 10 E4			dta		c'S',a(screnv)
    21 EEB5 4B 20 E4			dta		c'K',a(keybdv)
