    10 				;==========================================================================
    11 FA02			.proc	EditorOpen
    12 FA02 20 EE FD			jsr		ScreenResetLogicalLineMap
    13 FA05 8E FE 02			stx		dspflg		;!! relies on X=0 from ScreenResetLogicalLineMap
    14 FA08 8E A2 02			stx		escflg
    15 					
    16 					;we must force mode 0 here -- ACTION calls this with $0C in AUX2 and
    17 					;expects mode 0 to be set
    18 FA0B 4C F2 F3			jmp		ScreenOpenMode0
    19 				.endp
    20
    21 				;==========================================================================
    22 = FE2B			EditorClose = ScreenClose
    23
    24 				;==========================================================================
    25 				;
    26 				; === Forced read mode ===
    27 				;
    28 				; If bit 0 if AUX1 is set on the IOCB, it means to read in forced read
    29 				; mode. In forced read mode, no keyboard input is fetched and instead
    30 				; line read immediately commences, as if ENTER were pressed.
    31 				;
    32 				; Note that since AUX1 is tested on the IOCB used, it is possible to have
    33 				; E: open on more than one IOCB with different forced read modes.
    34 				;
    35 				; Despite what the OS Manual says, the forced read mode is actually a
    36 				; feature of K: and not E:, and can also be activated when directly
    37 				; using K:.
    38 				;
    39 FA0E			.proc	EditorGetByte
    40 					;check if we have anything left in the current line
    41 FA0E A5 6B			lda		bufcnt
    42 FA10 D0 06			bne		have_line
    43 					
    44 					;nope, fetch a line
    45 FA12 20 2E FA			jsr		EditorGetLine
    46 FA15 10 01			bpl		have_line
    47 FA17 60				rts
    48 					
    49 FA18			have_line:
    50 					;swap to text context
    51 FA18 20 46 F9			jsr		EditorSwapToText
    52 					
    53 					;subtract off a char
    54 FA1B C6 6B			dec		bufcnt
    55 					
    56 					;check if we're at the EOL
    57 FA1D D0 09			bne		have_char
    58 					
    59 					;yes, we're at the EOL -- print it and return it (this will re-enable
    60 					;the cursor, too)
    61 FA1F A9 9B			lda		#$9b
    62 FA21 20 17 F6			jsr		ScreenPutByte
    63
    64 FA24 A9 9B			lda		#$9b
    65 FA26 D0 03			bne		done
    66 					
    67 FA28			have_char:
    68 					;read a char from the screen
    69 FA28 20 D1 F5			jsr		ScreenGetByte
    70 FA2B			done:
    71 FA2B 4C A1 FD			jmp		EditorSwapToScreen
    72 				.endp
    73
    74 				;==========================================================================
    75 				; This behavior is quite complex:
    76 				;	- The editor remembers the cursor position within the initial logical
    77 				;	  line. Only contents beyond the initial position are returned. This
    78 				;	  is true even if the cursor is moved out of the logical line and back
    79 				;	  in again.
    80 				;	- Margins are not included.
    81 				;	- Trailing spaces at the end of a logical line are not returned even
    82 				;	  if the cursor is after them.
    83 				;	- If the cursor is moved to another logical line, that logical line is
    84 				;	  read instead. There is no memory of the line start for previous
    85 				;	  logical lines, so if there was a prompt on that line it will be
    86 				;	  picked up too.
    87 				;	- If the logical line length is exceeded, a beep sounds near the end
    88 				;	  and after three lines (120ch) the logical line is terminated and a
    89 				;	  new logical line is started. However, the previous logical line that
    90 				;	  was overflowed is still returned. This still happens if the new
    91 				;	  logical line extends to more than one physical line or even if
    92 				;	  itself overflows (!). If the physical line is changed with up/down,
    93 				;	  this memory is lost, but left/right don't do this.
    94 				;	- If a logical line extends exactly to the end of a physical line, an
    95 				;	  extra blank line is printed on EOL.
    96 				;	- If a logical line extends exactly to the end of the screen, a cursor
    97 				;	  out of bounds error results. (We currently do not implement this...
    98 				;	  feature.)
    99 				;
   100 				; === The BUFSTR variable ===
   101 				;
   102 				; The BUFSTR variable is critical to the way that the get line algorithm
   103 				; works. It actually consists of two bytes, the row followed by the column
   104 				; of the origin of the line to be read. This is updated whenever a read
   105 				; request arrives that starts a new line or whenever the cursor is moved
   106 				; to a different logical line. This is how the screen editor knows to
   107 				; read at the end of a prompt or from a different line that you have moved
   108 				; to, and how it tracks that when scrolling occurs. It does not, however,
   109 				; get updated when regular characters are typed, even when spilling to a
   110 				; new logical line.
   111 				;
   112 				; === BUFCNT ===
   113 				;
   114 				; BUFCNT contains the number of characters left to return before we have
   115 				; to get a new line: $00 means we will wait for keys, $01 is the EOL, and
   116 				; >$01 returns a typed character. We need to follow this convention or
   117 				; else the combination of S_VBXE.SYS + CON.SYS /E from SDX 4.46 acts
   118 				; strangely on launch.
   119 				;
   120 FA2E			.proc	EditorGetLine
   121 = 006D			_start_x equ bufstr+1
   122 = 006C			_start_y equ bufstr
   123
   124 					;Set line buffer start to current position (NOT the start of the logical
   125 					;line -- this is a special case).
   126 FA2E 20 46 F9			jsr		EditorSwapToText
   127 FA31 A5 55 85 6D			mva		colcrs _start_x
   128 FA35 A5 54 85 6C			mva		rowcrs _start_y
   129 FA39 20 A1 FD			jsr		EditorSwapToScreen
   130
   131 FA3C			read_loop:
   132 					;get a character
   133 FA3C 20 6C FE			jsr		KeyboardGetByte
   134 FA3F 10 01			bpl		read_ok
   135 FA41			read_error:
   136 FA41 60				rts
   137 					
   138 FA42			read_ok:
   139 FA42 C9 9B			cmp		#$9b
   140 FA44 F0 1D			beq		is_eol	
   141
   142 					;echo the character	
   143 FA46 20 BB FA			jsr		EditorPutByte
   144 FA49 30 F6			bmi		read_error
   145 					
   146 					;check if we've hit the warning point (logical pos 113)
   147 FA4B A5 55			lda		colcrs
   148 FA4D C9 21			cmp		#33
   149 FA4F D0 EB			bne		read_loop
   150 					
   151 					;convert current row to logical start row
   152 FA51 20 8D FD			jsr		EditorGetCurLogicalRow
   153 					
   154 					;check if we're on the third row
   155 FA54 18				clc
   156 FA55 69 02			adc		#2
   157 FA57 C5 54			cmp		rowcrs
   158 					
   159 					;if so, sound the bell
   160 FA59 D0 E1			bne		read_loop
   161 FA5B 20 6F FB			jsr		EditorBell
   162 					
   163 FA5E 4C 3C FA			jmp		read_loop
   164
   165 FA61			do_eol:
   166 FA61 A9 9B			lda		#$9b
   167 FA63			is_eol:
   168 					;echo the character	
   169 FA63 20 BB FA			jsr		EditorPutByte
   170 FA66 30 D9			bmi		read_error
   171
   172 					;swap to text screen context
   173 FA68 20 46 F9			jsr		EditorSwapToText
   174 					
   175 					;hide the cursor so we can scan text properly
   176 FA6B 20 F6 F8			jsr		ScreenHideCursor
   177 						
   178 					;compute address
   179 FA6E A2 00			ldx		#0
   180 FA70 86 63			stx		logcol
   181 FA72 A4 6C			ldy		_start_y
   182 FA74 84 54			sty		rowcrs
   183 FA76 20 80 F9			jsr		ScreenComputeToAddr
   184 					
   185 FA79 A4 6D			ldy		_start_x
   186 FA7B			char_loop:
   187 FA7B E6 63			inc		logcol
   188 FA7D B1 66			lda		(toadr),y
   189 FA7F F0 04			beq		blank
   190 FA81 A5 63 85 6B			mva		logcol bufcnt
   191 FA85			blank:
   192 FA85 C4 53			cpy		rmargn
   193 FA87 C8				iny
   194 FA88 90 F1			bcc		char_loop
   195 FA8A 20 C8 FD			jsr		EditorNextLineAddr
   196 					
   197 					;check if we're at the bottom of the screen
   198 FA8D E6 54			inc		rowcrs
   199 FA8F A5 54			lda		rowcrs
   200 FA91 CD BF 02			cmp		botscr
   201 FA94 B0 0A			bcs		scan_scroll
   202 					
   203 					;check if we're at the end of the logical line
   204 FA96 20 86 FD			jsr		EditorTestLogicalLineBit
   205 FA99 D0 08			bne		scan_done
   206 					
   207 FA9B A4 52			ldy		lmargn
   208 FA9D 4C 7B FA			jmp		char_loop
   209 					
   210 FAA0			scan_scroll:
   211 					;we're below the screen... need to scroll up
   212 FAA0 20 D4 FC			jsr		EditorDeleteLine0
   213 					
   214 FAA3			scan_done:
   215 					;adjust BUFCNT so it is the number of chars to read (scanned + EOL)
   216 FAA3 E6 6B			inc		bufcnt
   217
   218 					;mark this as the start of a new logical line, trimming off any extra
   219 					;blank lines
   220 FAA5 A5 54			lda		rowcrs
   221 FAA7 20 79 FD			jsr		EditorGetLogicalLineInfo
   222 FAAA 19 B2 02			ora		logmap,y
   223 FAAD 99 B2 02			sta		logmap,y
   224
   225 					;reset cursor to line start, but leave the cursor off
   226 FAB0 A6 6D 86 55			mvx		_start_x colcrs
   227 FAB4 A4 6C 84 54			mvy		_start_y rowcrs
   228
   229 					;swap back to main context and exit successfully
   230 FAB8 4C 9F FD			jmp		EditorSwapToScreen_Y1
   231 				.endp
   232
   233 				;==========================================================================
   234 				; This routine must NOT write BUFADR -- doing so breaks the DLT flasher.
   235 				;
   236 				; Behavior notes:
   237 				;	- Ctrl+1 (suspend display) does not affect control codes handled only
   238 				;	  by E:. In particular, EOL, move up/down/left/right, ESC, insert, and
   239 				;	  delete are not affected by it. CLEAR on the other hand, is, because
   240 				;	  it's handled by S:.
   241 				;
   242 FABB			.proc	EditorPutByte
   243 					;open the text screen if it is not open already
   244 FABB A4 57			ldy		dindex
   245 FABD F0 0C			beq		screenok
   246 FABF AC BF 02			ldy		botscr
   247 FAC2 C0 04			cpy		#4
   248 FAC4 F0 05			beq		screenok
   249
   250 FAC6 48				pha
   251 FAC7 20 EE F3			jsr		ScreenOpenGr0
   252 FACA 68				pla
   253 FACB			screenok:
   254
   255 					;swap to text context
   256 FACB 20 46 F9			jsr		EditorSwapToText
   257
   258 					;hide the cursor -- this must be done before we suspend display on
   259 					;Ctrl+1.
   260 FACE 20 F6 F8			jsr		ScreenHideCursor
   261
   262 					;save off character to free up acc
   263 FAD1 A8				tay
   264
   265 					;Check if [esc] is active
   266 					;
   267 					;Note that the ASL trick relies on ESCFLG being $80 when set; this
   268 					;is in fact guaranteed by the spec in the OS Manual, Appendix L, B26.
   269 					;
   270 FAD2 0E A2 02			asl		escflg					;test and clear escape flag
   271 FAD5 B0 1E			bcs		not_special
   272
   273 					;check if this might be a special character
   274 FAD7 29 1F			and		#$1f
   275 FAD9 C9 1B			cmp		#$1b
   276 FADB 90 18			bcc		not_special
   277
   278 					;might be special, but not EOL... search the special char table
   279 FADD A2 0E			ldx		#special_code_tab_end-special_code_tab-1
   280 FADF 98				tya
   281 FAE0 20 BF FC			jsr		EditorIsSpecial
   282 FAE3 D0 10			bne		not_special
   283 					
   284 FAE5			special_found:
   285 					;check if display of control codes is desired; if so, we need to ignore this
   286 FAE5 AD FE 02			lda		dspflg
   287 FAE8 D0 0B			bne		not_special
   288
   289 					;jump to routine
   290 FAEA 20 6A FC			jsr		dispatch
   291 FAED 20 C8 FC			jsr		EditorRecomputeCursorAddr
   292 FAF0 20 1A FE			jsr		ScreenShowCursorAndXitOK
   293 FAF3 10 06			bpl		xit2				;!! - unconditional jump
   294
   295 FAF5			not_special:
   296 					;ok, just put the char to the screen
   297 FAF5 8C FB 02			sty		atachr
   298 FAF8 20 2F F6			jsr		ScreenPutByte.not_clear
   299 FAFB			xit2:
   300 					;swap back to main context and exit
   301 FAFB AD FB 02			lda		atachr				;required by Monkey Wrench II
   302 FAFE 4C A1 FD			jmp		EditorSwapToScreen
   303
   304 				;---------------
   305 FB01			special_code_tab:
   306 FB01 1B				dta		$1b
   307 FB02 1C				dta		$1c
   308 FB03 1D				dta		$1d
   309 FB04 1E				dta		$1e
   310 FB05 1F				dta		$1f
   311 FB06 7D				dta		$7d
   312 FB07 7E				dta		$7e
   313 FB08 7F				dta		$7f
   314 FB09 9C				dta		$9c
   315 FB0A 9D				dta		$9d
   316 FB0B 9E				dta		$9e
   317 FB0C 9F				dta		$9f
   318 FB0D FD				dta		$fd
   319 FB0E FE				dta		$fe
   320 FB0F FF				dta		$ff
   321 FB10			special_code_tab_end:
   322 FB10 9B				dta		$9b				;this is only for the K: check
   323 FB11			special_code_tab_end_2:
   324
   325 				;----------------
   326
   327 FB11			special_dispatch_lo_tab:
   328 FB11 1F				dta		<(special_escape-1)
   329 FB12 28				dta		<(special_up-1)
   330 FB13 32				dta		<(special_down-1)
   331 FB14 C8				dta		<(special_left-1)
   332 FB15 D5				dta		<(special_right-1)
   333 FB16 25				dta		<(special_clear-1)
   334 FB17 4D				dta		<(special_backspace-1)
   335 FB18 8E				dta		<(special_tab-1)
   336 FB19 DE				dta		<(special_delete_line-1)
   337 FB1A E4				dta		<(special_insert_line-1)
   338 FB1B 7B				dta		<(special_clear_tab-1)
   339 FB1C 73				dta		<(special_set_tab-1)
   340 FB1D 6E				dta		<(special_bell-1)
   341 FB1E EB				dta		<(special_delete_char-1)
   342 FB1F F7				dta		<(special_insert_char-1)
   343 					
   344 				.if [((special_escape-1)^(special_insert_char-1))&$ff00]
   345 					.error 'Special character routines cross a page boundary: ',special_escape,'-',special_insert_char
   346 				.endif
   347
   348 				;---------------
   349 FB20			special_escape:
   350 FB20 A9 80 8D A2 02		mva		#$80 escflg
   351 FB25 60				rts
   352
   353 				;---------------
   354 FB26			special_clear:
   355 FB26 4C 4F F8			jmp		ScreenClear
   356 					
   357 				;---------------
   358 FB29			special_up:
   359 FB29 A6 54			ldx		rowcrs
   360 FB2B D0 03			bne		isup2
   361 FB2D AE BF 02			ldx		botscr
   362 FB30			isup2:
   363 FB30 CA				dex
   364 FB31 10 0A			bpl		vmoveexit
   365 					
   366 				;---------------
   367 FB33			special_down:
   368 FB33 A6 54			ldx		rowcrs
   369 FB35 E8				inx
   370 FB36 EC BF 02			cpx		botscr
   371 FB39 90 02 A2 00			scc:ldx	#0
   372 					
   373 FB3D			vmoveexit:
   374 FB3D 86 54			stx		rowcrs
   375 					
   376 					;check if we have moved into a different logical line -- if so,
   377 					;we need to reset the read row
   378 FB3F 8A				txa
   379 FB40 20 8F FD			jsr		EditorPhysToLogicalRow
   380 FB43 C5 6C			cmp		bufstr
   381 FB45 F0 06			beq		moveexit
   382 					
   383 					;we switched rows -- reset read row
   384 FB47 85 6C			sta		bufstr
   385 FB49 A5 52 85 6D			mva		lmargn bufstr+1
   386 					
   387 FB4D			moveexit:
   388 FB4D 60				rts
   389
   390 				;---------------
   391 FB4E			special_backspace:
   392 					;check if we are at the left column
   393 FB4E A5 52			lda		lmargn
   394 FB50 C5 55			cmp		colcrs
   395 FB52 B0 0B			bcs		sbks_wrap
   396 					
   397 					;nope, we can just back up
   398 FB54 C6 55			dec		colcrs
   399 					
   400 					;recompute pos and clear character
   401 FB56			sbks_recomp:
   402 FB56 20 C8 FC			jsr		EditorRecomputeCursorAddr
   403 FB59 A0 00			ldy		#0
   404 FB5B 98				tya
   405 FB5C 91 5E			sta		(oldadr),y
   406 FB5E			sbks_xit:
   407 FB5E 60				rts
   408 					
   409 FB5F			sbks_wrap:
   410 					;check if we're at the start of the logical line
   411 FB5F A5 54			lda		rowcrs
   412 FB61 20 86 FD			jsr		EditorTestLogicalLineBit
   413 FB64 D0 F8			bne		sbks_xit
   414 					
   415 					;no, so we need to wrap to the right column of the prev line...
   416 FB66 C6 54			dec		rowcrs
   417 FB68 A5 53			lda		rmargn
   418 FB6A 85 55			sta		colcrs
   419 					
   420 					;recompute everything and exit
   421 FB6C 4C 56 FB			jmp		sbks_recomp
