  1115 DB49			digitloop_entry:
  1116 						;start with 0 for the tens digit
  1117 DB49 A2 00				ldx		#0
  1118
  1119 						;subtract 10x divisor and increment quotient tens digit until underflow
  1120 DB4B 38					sec
  1121 DB4C 20 BA DB				jsr		fp_fdiv_decloop.entry
  1122
  1123 DB4F AA					tax
  1124
  1125 						;add 1x divisor and decrement quotient ones digit until overflow
  1126 						;note - C=0 from shift in decloop
  1127
  1128 DB50			incloop:
  1129 						;decrement quotient mantissa byte
  1130 DB50 CA					dex
  1131 					
  1132 						;add 1x divisor
  1133 						.rept 5
  1134 							LDA		FR0+(5-#)
  1135 							ADC		FR1+(5-#)
  1136 							STA		FR0+(5-#)
  1137 						.endr
