<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>AltirraSDL @PROJECT_VERSION@ — WebAssembly</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      background: #111;
      color: #ddd;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
                   Roboto, sans-serif;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── Top bar ────────────────────────────────────────────────── */
    header {
      flex: 0 0 auto;
      width: 100%;
      background: #1a1a1a;
      border-bottom: 1px solid #333;
      padding: 6px 10px;
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }
    h1 {
      font-size: 0.95rem;
      color: #7db2ff;
      margin: 0;
      flex: 0 0 auto;
    }
    header button {
      background: #2a2a2a;
      color: #ddd;
      border: 1px solid #444;
      padding: 4px 10px;
      font-size: 0.85rem;
      cursor: pointer;
      border-radius: 3px;
    }
    header button:hover { background: #333; }
    header button:disabled {
      color: #555;
      border-color: #2a2a2a;
      cursor: not-allowed;
    }
    /* Status pushes everything after it (log toggle) to the right. */
    #status {
      flex: 1 1 auto;
      text-align: right;
      font-size: 0.8rem;
      color: #9fd89f;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      padding-right: 8px;
    }
    .log-toggle {
      flex: 0 0 auto;
      font-size: 0.8rem;
      color: #888;
      cursor: pointer;
      user-select: none;
      border: 1px solid transparent;
      padding: 3px 8px;
      border-radius: 3px;
    }
    .log-toggle:hover { color: #ddd; border-color: #444; }

    /* ── Canvas area — fills all remaining space, letterboxes ───── */
    #canvas-wrap {
      flex: 1 1 auto;
      position: relative;
      min-height: 0;          /* allow shrinking below content size */
      display: flex;
      align-items: center;
      justify-content: center;
      background: #000;
    }
    canvas {
      display: block;
      /* Maintain an Atari 4:3 aspect; scale to fit available area
         without cropping.  The GPU framebuffer stays at whatever the
         SDL_Renderer backbuffer was created at (typically 800x600);
         the browser's CSS layer rescales that to the computed size. */
      max-width: 100%;
      max-height: 100%;
      aspect-ratio: 4 / 3;
      width: auto;
      height: 100%;
      background: #000;
      outline: none;
    }
    #drop-overlay {
      position: absolute;
      inset: 0;
      pointer-events: none;
      border: 3px dashed #7db2ff;
      background: rgba(125, 178, 255, 0.12);
      color: #7db2ff;
      font-size: 1.2rem;
      display: none;
      align-items: center;
      justify-content: center;
    }
    #drop-overlay.active { display: flex; }

    /* ── Log panel — hidden by default, bottom of viewport ──────── */
    #log {
      flex: 0 0 auto;
      width: 100%;
      max-height: 30vh;
      min-height: 120px;
      overflow-y: auto;
      white-space: pre;
      background: #000;
      border-top: 1px solid #333;
      color: #aaa;
      padding: 6px 10px;
      font-size: 0.75rem;
      font-family: "SF Mono", Menlo, Consolas, monospace;
    }
    #log.hidden { display: none; }
  </style>
</head>
<body>
  <header>
    <h1>AltirraSDL @PROJECT_VERSION@</h1>
    <button id="btn-upload-game" disabled>Upload Game…</button>
    <button id="btn-upload-firmware" disabled>Upload Firmware…</button>
    <button id="btn-save-library" disabled>Save Library</button>
    <div id="status">Loading…</div>
    <div class="log-toggle" id="log-toggle" role="button" tabindex="0">▸ Show log</div>
  </header>

  <div id="canvas-wrap">
    <canvas id="canvas" tabindex="-1" oncontextmenu="event.preventDefault()"></canvas>
    <div id="drop-overlay">Drop files here to upload</div>
  </div>

  <div id="log" class="hidden"></div>

  <!-- File input elements (hidden; driven by toolbar buttons). -->
  <input type="file" id="file-game" accept=".xex,.atr,.atx,.cas,.car,.rom,.bin,.zip,.sap"
         multiple hidden>
  <input type="file" id="file-firmware" accept=".rom,.bin" multiple hidden>

  <script>
  (() => {
    // ───────────────────────────────────────────────────────────────────────
    //  Persistence root
    //
    //  We mount IDBFS at /home/web_user — the same path Emscripten sets
    //  $HOME to by default.  That single mount covers:
    //
    //    /home/web_user/.config/altirra/settings.ini   (emulator settings,
    //       computed by registry_sdl3.cpp via $HOME or $XDG_CONFIG_HOME)
    //    /home/web_user/games/*                        (uploaded cartridges)
    //    /home/web_user/firmware/*                     (uploaded OS ROMs)
    //
    //  Using a single mount means one syncfs flush persists everything
    //  (settings + uploads) to the per-origin IndexedDB in one shot.
    // ───────────────────────────────────────────────────────────────────────
    const PERSIST_ROOT  = '/home/web_user';
    const GAMES_DIR     = PERSIST_ROOT + '/games';
    const FIRMWARE_DIR  = PERSIST_ROOT + '/firmware';

    // ───────────────────────────────────────────────────────────────────────
    //  DOM handles
    // ───────────────────────────────────────────────────────────────────────
    const canvas      = document.getElementById('canvas');
    const statusEl    = document.getElementById('status');
    const logEl       = document.getElementById('log');
    const logToggle   = document.getElementById('log-toggle');
    const dropOverlay = document.getElementById('drop-overlay');
    const canvasWrap  = document.getElementById('canvas-wrap');
    const btnGame     = document.getElementById('btn-upload-game');
    const btnFirmware = document.getElementById('btn-upload-firmware');
    const btnSave     = document.getElementById('btn-save-library');
    const fileGame    = document.getElementById('file-game');
    const fileFw      = document.getElementById('file-firmware');
    const cacheBust   = Date.now().toString();

    function appendLog(line) {
      logEl.textContent += line + '\n';
      logEl.scrollTop = logEl.scrollHeight;
    }

    function toggleLog() {
      logEl.classList.toggle('hidden');
      logToggle.textContent =
        logEl.classList.contains('hidden') ? '▸ Show log' : '▾ Hide log';
    }
    logToggle.addEventListener('click', toggleLog);
    logToggle.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleLog(); }
    });

    // ───────────────────────────────────────────────────────────────────────
    //  IDBFS persistence helpers
    // ───────────────────────────────────────────────────────────────────────
    async function syncFsIn() {
      return new Promise((resolve) => {
        Module.FS.syncfs(true, (err) => {
          if (err) appendLog('[fs] syncfs(in) failed: ' + err);
          resolve();
        });
      });
    }
    async function syncFsOut() {
      return new Promise((resolve) => {
        Module.FS.syncfs(false, (err) => {
          if (err) appendLog('[fs] syncfs(out) failed: ' + err);
          resolve();
        });
      });
    }

    // ───────────────────────────────────────────────────────────────────────
    //  Upload handling
    //
    //  Writes the file bytes into the IDBFS-backed tree, flushes to
    //  IndexedDB, and notifies the native bridge via
    //  Module._ATWasmOnFileUploaded so the emulator can cold-boot the
    //  first game (or merely see new firmware).
    // ───────────────────────────────────────────────────────────────────────
    async function readFileAsBytes(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload  = () => resolve(new Uint8Array(reader.result));
        reader.onerror = () => reject(reader.error);
        reader.readAsArrayBuffer(file);
      });
    }

    function sanitize(name) {
      // Strip any path components a browser might hand us; collapse any
      // character that could confuse Emscripten's VFS path parser.
      const base = name.replace(/^.*[\\\/]/, '');
      return base.replace(/[^A-Za-z0-9._\- ]/g, '_');
    }

    async function uploadFiles(files, kind) {
      if (!Module || !Module.FS) {
        appendLog('[upload] runtime not ready');
        return;
      }
      const dir = (kind === 'firmware') ? FIRMWARE_DIR : GAMES_DIR;
      try { Module.FS.mkdirTree(dir); } catch (e) {}

      let wrote = 0;
      let firstGamePath = null;
      const lastWrittenPaths = [];

      for (const f of files) {
        try {
          const bytes = await readFileAsBytes(f);
          const path  = dir + '/' + sanitize(f.name);
          Module.FS.writeFile(path, bytes);
          appendLog('[upload] wrote ' + path + ' (' + bytes.length + ' bytes)');
          wrote++;
          lastWrittenPaths.push(path);
          if (kind !== 'firmware' && !firstGamePath)
            firstGamePath = path;
        } catch (err) {
          appendLog('[upload] failed for ' + f.name + ': ' + err);
        }
      }

      if (wrote > 0) {
        await syncFsOut();
        statusEl.textContent = 'Uploaded ' + wrote + ' file(s)';

        try {
          if (Module._ATWasmOnFileUploaded) {
            for (const p of lastWrittenPaths) {
              const bootFlag = (p === firstGamePath) ? 1 : 0;
              const lenBytes = Module.lengthBytesUTF8(p) + 1;
              const cstr = Module._malloc(lenBytes);
              Module.stringToUTF8(p, cstr, lenBytes);
              Module._ATWasmOnFileUploaded(cstr, bootFlag);
              Module._free(cstr);
            }
          }
        } catch (err) {
          appendLog('[upload] bridge call failed: ' + err);
        }
      }
    }

    btnGame.addEventListener('click',     () => fileGame.click());
    btnFirmware.addEventListener('click', () => fileFw.click());
    btnSave.addEventListener('click', async () => {
      await syncFsOut();
      statusEl.textContent = 'Library saved';
    });

    fileGame.addEventListener('change', (e) => {
      uploadFiles(Array.from(e.target.files), 'game');
      e.target.value = '';
    });
    fileFw.addEventListener('change', (e) => {
      uploadFiles(Array.from(e.target.files), 'firmware');
      e.target.value = '';
    });

    // Drag-drop anywhere on the canvas area — including the letterbox
    // margins around it — feels more forgiving than forcing the user to
    // hit the video rectangle precisely.
    ['dragenter', 'dragover'].forEach((evt) => {
      canvasWrap.addEventListener(evt, (e) => {
        e.preventDefault();
        dropOverlay.classList.add('active');
      });
    });
    ['dragleave', 'drop'].forEach((evt) => {
      canvasWrap.addEventListener(evt, (e) => {
        e.preventDefault();
        dropOverlay.classList.remove('active');
      });
    });
    canvasWrap.addEventListener('drop', (e) => {
      if (e.dataTransfer && e.dataTransfer.files.length) {
        uploadFiles(Array.from(e.dataTransfer.files), 'game');
      }
    });

    // ───────────────────────────────────────────────────────────────────────
    //  Auto-flush on page hide.  Browsers fire `pagehide` (and
    //  `visibilitychange` to hidden) before closing / navigating, which
    //  is our last chance to persist any in-memory-only changes to
    //  IndexedDB.  Best-effort — we can't await async work here, but
    //  syncfs(false) kicks off the IDB transaction and the browser
    //  usually lets it finish before tearing down the page.
    // ───────────────────────────────────────────────────────────────────────
    window.addEventListener('pagehide', () => {
      if (Module && Module.FS && Module.FS.syncfs) {
        Module.FS.syncfs(false, () => {});
      }
    });

    // ───────────────────────────────────────────────────────────────────────
    //  Emscripten Module configuration
    // ───────────────────────────────────────────────────────────────────────
    window.Module = {
      canvas: canvas,
      noInitialRun: false,
      print:    (t) => appendLog('[stdout] ' + t),
      printErr: (t) => appendLog('[stderr] ' + t),
      setStatus: (t) => { statusEl.textContent = t || 'Running'; },
      locateFile: (path) => {
        if (path && path.endsWith('.wasm'))
          return path + '?v=' + cacheBust;
        return path;
      },
      preRun: [function () {
        // Mount IDBFS at the default $HOME.  /home/web_user is created
        // by Emscripten's MEMFS during startup, so the mkdir is
        // idempotent — we just replace the MEMFS mount at that path
        // with IDBFS.  FS.syncfs(true) copies IndexedDB contents into
        // the memory-backed view before main() runs.
        try {
          // The directory may or may not exist yet depending on the
          // Emscripten version; mkdir-if-missing covers both.
          try { Module.FS.mkdir(PERSIST_ROOT); } catch (e) {}
          Module.FS.mount(Module.IDBFS, {}, PERSIST_ROOT);
        } catch (e) {
          appendLog('[fs] mount error: ' + e);
        }
        Module.addRunDependency('idbfs-populate');
        Module.FS.syncfs(true, (err) => {
          if (err) appendLog('[fs] initial syncfs failed: ' + err);
          try { Module.FS.mkdirTree(GAMES_DIR); } catch (e) {}
          try { Module.FS.mkdirTree(FIRMWARE_DIR); } catch (e) {}
          try { Module.FS.mkdirTree(PERSIST_ROOT + '/.config/altirra'); } catch (e) {}
          Module.removeRunDependency('idbfs-populate');
        });
      }],
      onRuntimeInitialized: () => {
        statusEl.textContent = 'Running';
        btnGame.disabled = false;
        btnFirmware.disabled = false;
        btnSave.disabled = false;
        canvas.focus();
      },
      totalDependencies: 0,
      monitorRunDependencies: (left) => {
        Module.totalDependencies =
          Math.max(Module.totalDependencies, left);
        if (left) {
          statusEl.textContent = 'Preparing… (' +
            (Module.totalDependencies - left) + '/' +
            Module.totalDependencies + ')';
        }
      },
    };

    window.addEventListener('error', (ev) => {
      appendLog('[onerror] ' + ev.message +
                ' (' + (ev.filename || '?') + ':' + (ev.lineno || '?') + ')');
    });

    // Load the generated Emscripten JS glue.
    const script = document.createElement('script');
    script.src = 'AltirraSDL.js?v=' + cacheBust;
    script.onerror = () => appendLog('[script] failed to load AltirraSDL.js');
    document.body.appendChild(script);
  })();
  </script>
</body>
</html>
